###> symfony/mercure-bundle ###
# Hub Mercure (ex. Docker : docker run -e MERCURE_PUBLISHER_JWT_KEY="..." -e MERCURE_SUBSCRIBER_JWT_KEY="..." -p 3000:80 dunglas/mercure)
# La valeur de MERCURE_JWT_SECRET doit correspondre aux clés JWT du hub.
MERCURE_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

###> symfony/mailer ###
# Dev : aucun envoi réel tant que MAILER_DSN reste sur null://null.
# Pour Gmail, surcharger dans .env.local (voir exemple ci-dessous).
MAILER_DSN=null://null
# Mode livraison code reset: auto | email | screen
# - auto: e-mail si SMTP configuré, sinon affichage du code à l'écran en dev
RESET_PASSWORD_DELIVERY=auto
# Expéditeur des e-mails (souvent la même adresse que le compte Gmail utilisé pour SMTP).
MAILER_FROM="SyfonuRH <noreply@example.com>"
# Exemple .env.local (ne pas commiter) — mot de passe = mot de passe d’application Google (16 caractères, sans espaces), URL-encodé si besoin :
# MAILER_DSN="smtp://VOTRE_EMAIL%40gmail.com:VOTRE_MOT_DE_PASSE_APP@smtp.gmail.com:465"
# MAILER_FROM="SyfonuRH <VOTRE_EMAIL@gmail.com>"
###< symfony/mailer ###

