{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié | SyfonuRH{% endblock %}

{% block body %}
<main class="d-flex flex-column justify-content-center vh-100">
    <section>
        <div class="container">
            <div class="row mb-8">
                <div class="col-xl-4 offset-xl-4 col-md-12 col-12">
                    <div class="text-center">
                        <a href="{{ path('app_home') }}" class="fs-2 fw-bold d-flex align-items-center gap-2 justify-content-center mb-6">
                            <img src="{{ asset('dasher/images/brand/logo/logo-icon.svg') }}" alt="Logo"/>
                            <span>SyfonuRH</span>
                        </a>
                        <h1 class="mb-1">Mot de passe oublié</h1>
                        <p class="mb-0 text-secondary">Nous vous enverrons un code à 6 chiffres par e-mail. Ensuite vous le saisirez : s’il est correct, vous pourrez choisir un nouveau mot de passe.</p>
                    </div>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <div class="mb-4">{% include '_flashes.html.twig' %}</div>
                    <div class="card card-lg mb-6">
                        <div class="card-body p-6">
                            <form method="post" action="{{ path('app_forgot_password') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">
                                <div class="mb-3">
                                    <label for="fpEmail" class="form-label">E-mail du compte <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" id="fpEmail" name="email" required autocomplete="email" value="{{ app.request.query.get('email')|default('') }}">
                                </div>
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary">Envoyer le code</button>
                                    <a href="{{ path('app_reset_password') }}" class="btn btn-outline-secondary btn-sm">J’ai déjà un code</a>
                                    <a href="{{ path('app_login') }}" class="btn btn-link btn-sm">Retour à la connexion</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}
