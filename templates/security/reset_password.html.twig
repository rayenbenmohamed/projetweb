{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe | SyfonuRH{% endblock %}

{% block body %}
<main class="d-flex flex-column justify-content-center vh-100">
    <section>
        <div class="container">
            <div class="row mb-8">
                <div class="col-xl-4 offset-xl-4 col-md-12 col-12">
                    <div class="text-center">
                        <a href="{{ path('app_home') }}" class="fs-2 fw-bold d-flex align-items-center gap-2 justify-content-center mb-6">
                            <img src="{{ asset('dasher/images/brand/logo/logo-icon.svg') }}" alt="Logo"/>
                            <span>SyfonuRH</span>
                        </a>
                        {% if show_password_step|default(false) %}
                            <h1 class="mb-1">Nouveau mot de passe</h1>
                            <p class="mb-0 text-secondary">Choisissez un mot de passe sécurisé pour le compte <strong>{{ verified_email }}</strong>.</p>
                        {% else %}
                            <h1 class="mb-1">Vérifier le code</h1>
                            <p class="mb-0 text-secondary">Saisissez l’e-mail du compte et le code à 6 chiffres reçu par e-mail. Si le code est correct, vous pourrez changer votre mot de passe à l’étape suivante.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <div class="mb-4">{% include '_flashes.html.twig' %}</div>
                    <div class="card card-lg mb-6">
                        <div class="card-body p-6">
                            {% if show_password_step|default(false) %}
                                <form method="post" action="{{ path('app_reset_password') }}">
                                    <input type="hidden" name="step" value="password">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reset_password_final') }}">
                                    <div class="mb-3">
                                        <label for="rpPass" class="form-label">Nouveau mot de passe <span class="text-danger">*</span></label>
                                        <input type="password" class="form-control" id="rpPass" name="password" required minlength="6" autocomplete="new-password">
                                    </div>
                                    <div class="mb-4">
                                        <label for="rpPass2" class="form-label">Confirmer le mot de passe <span class="text-danger">*</span></label>
                                        <input type="password" class="form-control" id="rpPass2" name="password_confirm" required minlength="6" autocomplete="new-password">
                                    </div>
                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-primary">Enregistrer le mot de passe</button>
                                        <a href="{{ path('app_reset_password', {cancel: 1}) }}" class="btn btn-outline-secondary btn-sm">Annuler — saisir un autre code</a>
                                        <a href="{{ path('app_login') }}" class="btn btn-link btn-sm">Connexion</a>
                                    </div>
                                </form>
                            {% else %}
                                <form method="post" action="{{ path('app_reset_password') }}">
                                    <input type="hidden" name="step" value="verify">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reset_password_verify') }}">
                                    <div class="mb-3">
                                        <label for="rpEmail" class="form-label">E-mail du compte <span class="text-danger">*</span></label>
                                        <input type="email" class="form-control" id="rpEmail" name="email" required autocomplete="email">
                                    </div>
                                    <div class="mb-4">
                                        <label for="rpCode" class="form-label">Code à 6 chiffres <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="rpCode" name="code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" autocomplete="one-time-code">
                                    </div>
                                    <div class="d-grid gap-2">
                                        <button type="submit" class="btn btn-primary">Vérifier le code</button>
                                        <a href="{{ path('app_forgot_password') }}" class="btn btn-link btn-sm">Demander un nouveau code</a>
                                        <a href="{{ path('app_login') }}" class="btn btn-link btn-sm">Connexion</a>
                                    </div>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{% block javascripts %}
    <script src="{{ asset('dasher/js/vendors/password.js') }}"></script>
{% endblock %}
{% endblock %}
