{% extends 'layout/admin.html.twig' %}

{% block title %}Forum des Discussions{% endblock %}
{% block page_title %}Communauté & Forum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .forum-header-bg {
            background: linear-gradient(135deg, #A29BFE 0%, #6C5CE7 100%);
            border-radius: 20px;
            padding: 3rem 2rem;
            color: white;
            box-shadow: 0 10px 30px rgba(108, 92, 231, 0.3);
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
        }
        .forum-header-bg::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3z' fill='%23ffffff' fill-opacity='0.1' fill-rule='evenodd'/%3E%3C/svg%3E");
            opacity: 0.5;
        }
        .post-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 16px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
        }
        .post-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }
        .post-title {
            font-weight: 800;
            color: #2b2b2b;
            font-size: 1.25rem;
            margin-bottom: 1rem;
        }
        .post-content-preview {
            color: #636e72;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        .action-btn {
            border-radius: 8px;
            padding: 8px 16px;
            font-weight: 600;
            transition: all 0.2s ease;
        }
        .btn-glow-primary {
            background: linear-gradient(135deg, #00b894, #00cec9);
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 184, 148, 0.3);
        }
        .btn-glow-primary:hover {
            transform: scale(1.05);
            color: white;
            box-shadow: 0 6px 20px rgba(0, 184, 148, 0.4);
        }
        .badge-category {
            background-color: #ffeaa7;
            color: #fdcb6e;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
        }
    </style>
{% endblock %}

{% block content %}
<div class="container-fluid mb-5">
    <form method="get" action="{{ path('app_forum_index') }}" class="card border-0 shadow-sm mb-4 p-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Search posts</label>
                <input type="text" class="form-control" name="q" value="{{ filters.q }}" placeholder="Title or content...">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Category filter</label>
                <select class="form-select" name="category">
                    <option value="">All categories</option>
                    {% for category in categories %}
                        <option value="{{ category.id }}" {{ filters.category == category.id ? 'selected' : '' }}>{{ category.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Sort</label>
                <select class="form-select" name="sort">
                    <option value="recent" {{ filters.sort == 'recent' ? 'selected' : '' }}>Recent</option>
                    <option value="popular" {{ filters.sort == 'popular' ? 'selected' : '' }}>Most discussed</option>
                    <option value="most_liked" {{ filters.sort == 'most_liked' ? 'selected' : '' }}>Most liked</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100">Apply</button>
                <a href="{{ path('app_forum_index') }}" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </form>
    
    <div class="forum-header-bg d-flex justify-content-between align-items-center flex-wrap gap-4">
        <div style="z-index: 1;">
            <h1 class="text-white fw-bold mb-2">Discussions Publiques</h1>
            <p class="text-white-50 mb-0 fs-5">Rejoignez la conversation et partagez vos idées !</p>
        </div>
        <div style="z-index: 1;">
            <a href="{{ path('app_forum_post_new') }}" class="btn btn-light btn-lg text-primary fw-bold px-4 rounded-pill shadow-sm">
                ✨ Démarrer une discussion
            </a>
        </div>
    </div>

    <div class="row g-4">
        {% for post in posts %}
        <div class="col-lg-4 col-md-6">
            <div class="post-card d-flex flex-column p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                        {{ post.category ? post.category.name : 'Général' }}
                    </span>
                    <small class="text-muted fw-semibold">{{ post.createdAt|date('d M Y') }}</small>
                </div>
                
                <h3 class="post-title">{{ post.title }}</h3>
                <p class="post-content-preview flex-grow-1">
                    {{ post.content|striptags|slice(0, 120) }}{{ post.content|length > 120 ? '...' : '' }}
                </p>
                <div class="d-flex gap-3 mb-3 text-muted small">
                    <span>💬 {{ post.comments|length }}</span>
                    <span>❤️ {{ post.likes|length }}</span>
                </div>
                
                <div class="d-flex gap-2 mt-auto pt-3 border-top border-light">
                    <a href="{{ path('app_forum_post_show', {'id': post.id}) }}" class="btn btn-primary action-btn flex-grow-1">Lire</a>
                    <a href="{{ path('app_forum_post_edit', {'id': post.id}) }}" class="btn btn-outline-secondary action-btn">📝</a>
                    
                    <form method="post" action="{{ path('app_forum_post_delete', {'id': post.id}) }}" class="m-0" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ceci ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button class="btn btn-outline-danger action-btn">🗑️</button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <div class="text-center py-5">
                <div class="fs-1 mb-3">📭</div>
                <h3 class="text-secondary fw-bold">Aucune discussion</h3>
                <p class="text-muted">Il n'y a actuellement aucun post dans le forum. Soyez le premier !</p>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
