{% extends 'layout/admin.html.twig' %}
{% block title %}Catégories du Forum{% endblock %}
{% block page_title %}Gérer les Catégories{% endblock %}

{% block content %}
<div class="card shadow-sm border-0 rounded-4 mb-4 mt-2">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h3 class="card-title fw-bold text-dark">Liste des Catégories</h3>
        <a href="{{ path('app_forum_category_new') }}" class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold">✨ Nouvelle Catégorie</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3 border-0 rounded-start">ID</th>
                        <th class="border-0">Titre</th>
                        <th class="border-0 w-50">Description</th>
                        <th class="border-0 text-end pe-3 rounded-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                {% for forum_category in forum_categories %}
                    <tr>
                        <td class="ps-3 fw-bold text-muted">#{{ forum_category.id }}</td>
                        <td class="fw-bolder text-dark">{{ forum_category.name }}</td>
                        <td class="text-secondary text-truncate" style="max-width: 300px;">{{ forum_category.description }}</td>
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-2">
                                <a href="{{ path('app_forum_category_show', {'id': forum_category.id}) }}" class="btn btn-sm btn-light text-primary fw-bold px-3 rounded-pill transition-all">Aperçu</a>
                                <a href="{{ path('app_forum_category_edit', {'id': forum_category.id}) }}" class="btn btn-sm btn-light text-warning fw-bold px-3 rounded-pill transition-all">Modifier</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <div class="display-4 mb-3">📁</div>
                            <h4 class="fw-bold">Aucune catégorie</h4>
                            <p>Créez votre première catégorie pour organiser les discussions.</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
