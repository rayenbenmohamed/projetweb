{% extends 'layout/admin.html.twig' %}

{% block title %}Détails de la Catégorie{% endblock %}
{% block page_title %}Aperçu Catégorie{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="card shadow-sm border-0 rounded-4 mx-auto" style="max-width: 600px; margin-top: 2rem;">
        <div class="card-body p-5 text-center">
            <div class="display-1 mb-3">📁</div>
            <h1 class="fw-bold text-dark mb-1">{{ forum_category.name }}</h1>
            <span class="badge bg-primary-subtle text-primary rounded-pill mb-4 px-3 py-2">ID: #{{ forum_category.id }}</span>
            
            <div class="bg-light p-4 rounded-4 mb-4 text-start">
                <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Description</h6>
                <p class="mb-0 text-secondary lh-lg fs-5">{{ forum_category.description|default('Aucune description fournie.') }}</p>
            </div>

            <div class="d-flex justify-content-center align-items-center gap-3">
                <a href="{{ path('app_forum_category_index') }}" class="btn btn-light text-secondary rounded-pill px-4 shadow-sm fw-semibold">Retour</a>
                <a href="{{ path('app_forum_category_edit', {'id': forum_category.id}) }}" class="btn btn-warning text-dark rounded-pill px-4 shadow-sm fw-bold">Modifier</a>
                <div class="m-0 p-0">
                    {{ include('forum_category/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
