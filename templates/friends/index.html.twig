{% extends 'layout/front.html.twig' %}

{% block title %}Amis | SyfonuRH{% endblock %}
{% block page_title %}Amis &amp; demandes{% endblock %}

{% block content %}
{% if is_granted('ROLE_ADMIN') %}
<div class="alert alert-light border d-flex flex-wrap align-items-center justify-content-between gap-2 mb-0">
    <span class="small text-secondary">Vous êtes connecté en administrateur.</span>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-outline-dark">Retour au back-office</a>
</div>
{% endif %}

<div class="card card-lg mb-4 mt-1">
    <div class="card-body py-3">
        <form method="get" action="{{ path('app_friends_index') }}" class="row g-2 align-items-end" role="search">
            <div class="col-md-8 col-lg-6">
                <label for="friendSearchInput" class="form-label small text-secondary mb-1">Rechercher des membres ou filtrer vos amis</label>
                <div class="input-group">
                    <span class="input-group-text bg-body-secondary border-end-0"><i class="ti ti-search"></i></span>
                    <input type="search" id="friendSearchInput" name="q" value="{{ search_query }}"
                           class="form-control border-start-0"
                           placeholder="Prénom, nom ou e-mail…" autocomplete="off" maxlength="120">
                    {% if search_query != '' %}
                        <a href="{{ path('app_friends_index') }}" class="btn btn-outline-secondary" type="button">Effacer</a>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <button type="submit" class="btn btn-primary w-100">Rechercher</button>
            </div>
            {% if search_query != '' %}
                <div class="col-12 small text-secondary">
                    Filtre actif : <strong>{{ search_query }}</strong>
                    — {{ friends|length }} ami(s) affiché(s), {{ directory|length }} profil(s) dans l’annuaire.
                </div>
            {% endif %}
        </form>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-5">
        <div class="card card-lg h-100" id="section-incoming-requests">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">Demandes reçues</h5>
                {% if incoming_requests|length > 0 %}
                    <span class="badge bg-primary rounded-pill">{{ incoming_requests|length }}</span>
                {% endif %}
            </div>
            <div class="list-group list-group-flush">
                {% for r in incoming_requests %}
                    <div class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <div>
                            <strong>{{ r.sender.firstName|default('') }} {{ r.sender.lastName|default('') }}</strong>
                            <span class="text-secondary small d-block">{{ r.sender.email }}</span>
                        </div>
                        <div class="d-flex gap-1">
                            <form method="post" action="{{ path('app_friends_accept', {id: r.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('friend_accept' ~ r.id) }}">
                                <button type="submit" class="btn btn-sm btn-success">Accepter</button>
                            </form>
                            <form method="post" action="{{ path('app_friends_reject', {id: r.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('friend_reject' ~ r.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Refuser</button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="list-group-item text-secondary small">Aucune demande en attente.</div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card card-lg mb-4" id="section-friends">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Mes amis</h5>
            </div>
            <ul class="list-group list-group-flush">
                {% for f in friends %}
                    <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <strong>{{ f.firstName|default('') }} {{ f.lastName|default('') }}</strong>
                            <span class="text-secondary small d-block">{{ f.email }}</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            {% set unread = unread_by_friend[f.id] ?? 0 %}
                            {% if unread > 0 %}
                                <span class="badge bg-danger rounded-pill" title="Messages non lus">{{ unread > 99 ? '99+' : unread }}</span>
                            {% endif %}
                            <a href="{{ path('app_chat_with', {id: f.id}) }}" class="btn btn-sm btn-primary">Discuter</a>
                        </div>
                    </li>
                {% else %}
                    <li class="list-group-item text-secondary small">
                        {% if search_query != '' %}
                            Aucun ami ne correspond à « {{ search_query }} ».
                        {% else %}
                            Pas encore d’amis — envoyez une demande ci-dessous.
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>

        <div class="card card-lg mb-4">
            <div class="card-header">
                <h5 class="mb-0">En attente (envoyées)</h5>
            </div>
            <ul class="list-group list-group-flush">
                {% for r in outgoing_requests %}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>{{ r.receiver.email }}</span>
                        <form method="post" action="{{ path('app_friends_cancel', {id: r.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('friend_cancel' ~ r.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Annuler</button>
                        </form>
                    </li>
                {% else %}
                    <li class="list-group-item text-secondary small">Aucune demande envoyée en attente.</li>
                {% endfor %}
            </ul>
        </div>

        <div class="card card-lg" id="section-directory">
            <div class="card-header">
                <h5 class="mb-0">Trouver des personnes</h5>
                <p class="small text-secondary mb-0 mt-1">Envoyer une demande d’ami (si la personne vous a déjà invité, accepter se fait automatiquement).</p>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Membre</th><th></th></tr>
                    </thead>
                    <tbody>
                        {% for u in directory %}
                            <tr>
                                <td>
                                    <strong>{{ u.firstName|default('') }} {{ u.lastName|default('') }}</strong>
                                    <span class="text-secondary small d-block">{{ u.email }}</span>
                                </td>
                                <td class="text-end">
                                    {% if friend_id_set[u.id] is defined %}
                                        <a href="{{ path('app_chat_with', {id: u.id}) }}" class="btn btn-sm btn-primary">Chat</a>
                                    {% elseif pending_to_me[u.id] is defined %}
                                        <form method="post" action="{{ path('app_friends_accept', {id: pending_to_me[u.id].id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('friend_accept' ~ pending_to_me[u.id].id) }}">
                                            <button type="submit" class="btn btn-sm btn-success">Accepter</button>
                                        </form>
                                    {% elseif pending_from_me[u.id] is defined %}
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis">En attente</span>
                                    {% else %}
                                        <form method="post" action="{{ path('app_friends_request', {id: u.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('friend_request' ~ u.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Ajouter</button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="2" class="text-secondary small">
                                {% if search_query != '' %}
                                    Aucun autre membre ne correspond à « {{ search_query }} ».
                                {% else %}
                                    Aucun autre utilisateur.
                                {% endif %}
                            </td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
