{% extends 'layout/front.html.twig' %}

{% block title %}Discussion avec {{ peer.email }} | SyfonuRH{% endblock %}
{% block page_title %}Discussion{% endblock %}

{% block content %}
{% if is_granted('ROLE_ADMIN') %}
<div class="alert alert-light border d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <span class="small text-secondary">Mode administrateur</span>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-outline-dark">Back-office</a>
</div>
{% endif %}
<div class="card card-lg mt-1">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h5 class="mb-0">{{ peer.firstName|default('') }} {{ peer.lastName|default('') }}</h5>
            <span class="text-secondary small">{{ peer.email }}</span>
        </div>
        <a href="{{ path('app_friends_index') }}" class="btn btn-sm btn-outline-secondary">← Amis</a>
    </div>
    <div class="card-body border-bottom bg-body-secondary" style="min-height: 320px; max-height: 55vh; overflow-y: auto;">
        {% for m in messages %}
            {% set mine = m.sender.id == app.user.id %}
            <div class="d-flex mb-3 {{ mine ? 'justify-content-end' : 'justify-content-start' }}">
                <div class="rounded-3 px-3 py-2 {{ mine ? 'bg-primary text-white' : 'bg-white border' }}" style="max-width: 85%;">
                    <div class="small {{ mine ? 'text-white-50' : 'text-secondary' }}">{{ m.createdAt|date('d/m/Y H:i') }}</div>
                    <div class="message-content">{{ m.content|e|nl2br }}</div>
                </div>
            </div>
        {% else %}
            <p class="text-secondary small mb-0">Aucun message pour l’instant. Dites bonjour !</p>
        {% endfor %}
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('friend_chat' ~ peer.id) }}">
            <div class="mb-2">
                <label class="form-label visually-hidden">Message</label>
                <textarea name="content" class="form-control" rows="3" required maxlength="5000" placeholder="Votre message…"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Envoyer</button>
        </form>
    </div>
</div>
{% endblock %}
