{% extends 'layout/admin.html.twig' %}

{% block title %}Gestion des Contrats | SyfonuRH{% endblock %}
{% block page_title %}Gestion des Contrats{% endblock %}

{% block content %}
<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    }
    .hero-gradient {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        color: white;
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
    }
    .table-premium thead th {
        background: rgba(99, 102, 241, 0.1);
        color: #4f46e5;
        border-bottom: 2px solid #6366f1;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05rem;
    }
    .table-premium tbody tr {
        transition: all 0.3s ease;
    }
    .table-premium tbody tr:hover {
        background: rgba(99, 102, 241, 0.05);
        transform: translateY(-2px);
    }
    .btn-premium {
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-premium:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    .status-badge {
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-weight: 500;
    }
</style>

<div class="container mt-4">
    <div class="hero-gradient d-flex justify-content-between align-items-center">
        <div>
            <h1 class="display-5 fw-bold mb-0">Gestion des Contrats</h1>
            <p class="lead opacity-75">Visualisez, filtrez et gérez tous les contrats RH</p>
        </div>
        <div>
            <a href="{{ path('app_contract_new') }}" class="btn btn-light btn-premium shadow-sm">
                <i class="fas fa-plus me-2"></i>Nouveau Contrat
            </a>
        </div>
    </div>

    {# Filter Bar #}
    <div class="glass-card p-4 mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-bold text-muted">Rechercher</label>
                <input type="text" name="search" class="form-control border-0 bg-light-subtle shadow-sm" 
                       placeholder="Candidat, Offre..." value="{{ current_search }}">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Statut</label>
                <select name="status" class="form-select border-0 bg-light-subtle shadow-sm">
                    <option value="">Tous les statuts</option>
                    <option value="Actif" {{ current_status == 'Actif' ? 'selected' }}>Actif</option>
                    <option value="Expire" {{ current_status == 'Expire' ? 'selected' }}>Expiré</option>
                    <option value="Annule" {{ current_status == 'Annule' ? 'selected' }}>Annulé</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted">Type de Contrat</label>
                <select name="type" class="form-select border-0 bg-light-subtle shadow-sm">
                    <option value="">Tous les types</option>
                    {% for type in types %}
                        <option value="{{ type.id }}" {{ current_type == type.id ? 'selected' }}>{{ type.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary btn-premium">
                    <i class="fas fa-filter me-2"></i>Filtrer
                </button>
            </div>
        </form>
    </div>

    {# Table Card #}
    <div class="glass-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-premium align-middle mb-0">
                <thead>
                    <tr>
                        <th>Candidat</th>
                        <th>Offre d'emploi</th>
                        <th>Type</th>
                        <th>Début</th>
                        <th>Salaire Brut</th>
                        <th>Statut</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for contract in contracts %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-primary-subtle rounded-circle p-2 me-2">
                                    <i class="fas fa-user text-primary"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">{{ contract.candidate ? contract.candidate.email : 'N/A' }}</div>
                                    <div class="small text-muted">ID: {{ contract.candidate ? contract.candidate.id : 'N/A' }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-secondary-subtle text-secondary-emphasis fw-normal">
                                {{ contract.jobOffre ? contract.jobOffre.title : 'N/A' }}
                            </span>
                        </td>
                        <td>
                            <span class="fw-bold">{{ contract.typeContrat ? contract.typeContrat.name : 'N/A' }}</span>
                        </td>
                        <td>{{ contract.startDate ? contract.startDate|date('d M Y') : '—' }}</td>
                        <td class="fw-bold text-primary">{{ contract.salary|number_format(0, ',', ' ') }} DT</td>
                        <td>
                            {% set status_class = 'bg-warning-subtle text-warning-emphasis' %}
                            {% if contract.status == 'Actif' %}{% set status_class = 'bg-success-subtle text-success-emphasis' %}
                            {% elseif contract.status == 'Expire' %}{% set status_class = 'bg-danger-subtle text-danger-emphasis' %}
                            {% endif %}
                            <span class="status-badge {{ status_class }}">{{ contract.status }}</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded">
                                <a href="{{ path('app_contract_show', {'id': contract.id}) }}" class="btn btn-white btn-sm" title="Voir">
                                    <i class="fas fa-eye text-info"></i>
                                </a>
                                <a href="{{ path('app_contract_edit', {'id': contract.id}) }}" class="btn btn-white btn-sm" title="Modifier">
                                    <i class="fas fa-edit text-warning"></i>
                                </a>
                                {{ include('contract/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i>
                                <p class="lead">Aucun contrat trouvé.</p>
                                <a href="{{ path('app_contract_new') }}" class="btn btn-link">Créer le premier contrat</a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-4 d-flex justify-content-between align-items-center mb-5">
        <a href="{{ path('app_dashboard') }}" class="btn btn-outline-secondary btn-premium">
            <i class="fas fa-arrow-left me-2"></i>Retour Dashboard
        </a>
        
        {# Pagination UI #}
        {% if total_pages > 1 %}
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-premium mb-0">
                <li class="page-item {{ current_page == 1 ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_contract_index', app.request.query.all|merge({'page': current_page - 1})) }}" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                {% for i in 1..total_pages %}
                    <li class="page-item {{ current_page == i ? 'active' }}">
                        <a class="page-link" href="{{ path('app_contract_index', app.request.query.all|merge({'page': i})) }}">{{ i }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ current_page == total_pages ? 'disabled' }}">
                    <a class="page-link" href="{{ path('app_contract_index', app.request.query.all|merge({'page': current_page + 1})) }}" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
        {% endif %}

        <div class="text-muted small">
            Affichage de <strong>{{ contracts|length }}</strong> sur <strong>{{ total_contracts }}</strong> contrat(s)
        </div>
    </div>
</div>

<style>
    .pagination-premium .page-link {
        border: none;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(5px);
        margin: 0 3px;
        border-radius: 8px !important;
        color: #6366f1;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .pagination-premium .page-item.active .page-link {
        background: #6366f1;
        color: white;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    }
    .pagination-premium .page-link:hover {
        background: rgba(99, 102, 241, 0.1);
        transform: translateY(-2px);
    }
</style>
{% endblock %}
