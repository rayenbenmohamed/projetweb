{% extends 'layout/admin.html.twig' %}

{% block title %}Flux des Contrats | SyfonuRH{% endblock %}
{% block page_title %}Tableau de Bord des Contrats{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
  {# Top Section: Horizontal Filters #}
  <div class="col-12 mb-2">
     <div class="card shadow-sm border-0" style="border-radius: 12px; border: 1px solid #eef2f6 !important;">
        <div class="card-body p-4">
           <form method="get" id="contractFilters" class="row g-3 align-items-end">
              <div class="col-lg-3 col-md-6">
                 <label class="form-label small fw-bold text-secondary mb-1">Recherche Globale</label>
                 <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="ti ti-search text-muted"></i></span>
                    <input class="form-control border-start-0 ps-0" type="text" name="q" value="{{ filters.q }}" placeholder="Nom, email, offre..." data-autosubmit>
                 </div>
              </div>
              <div class="col-lg-3 col-md-6">
                 <label class="form-label small fw-bold text-secondary mb-1">Type de Contrat</label>
                 <select class="form-select form-select-sm" name="type" data-autosubmit>
                    <option value="">Tous les types</option>
                    {% for t in types %}
                       <option value="{{ t.id }}" {{ filters.type == t.id ? 'selected' : '' }}>{{ t.name }}</option>
                    {% endfor %}
                 </select>
              </div>
              <div class="col-lg-3 col-md-6">
                 <label class="form-label small fw-bold text-secondary mb-1">Statut du Dossier</label>
                 <select class="form-select form-select-sm" name="status" data-autosubmit>
                    <option value="">Tous les statuts</option>
                    {% for s in ['En Attente','Actif','Suspendu','Terminé'] %}
                       <option value="{{ s }}" {{ filters.status == s ? 'selected' : '' }}>{{ s }}</option>
                    {% endfor %}
                 </select>
              </div>
              <div class="col-lg-3 col-md-6 d-flex gap-2">
                 <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="ti ti-filter me-1"></i> Filtrer
                 </button>
                 <a href="{{ path('app_contract_index') }}" class="btn btn-outline-secondary btn-sm px-3" title="Réinitialiser">
                    <i class="ti ti-rotate-clockwise"></i>
                 </a>
              </div>
           </form>
        </div>
     </div>
  </div>

  {# Main Feed Section: Expanded #}
  <div class="col-lg-9">
     <div class="d-flex justify-content-between align-items-center mb-6 px-1">
        <h5 class="mb-0 fw-bold">Flux des Contrats <span class="badge bg-light text-primary ms-2 fw-normal fs-6">{{ contracts|length }} affichés</span></h5>
        <a href="{{ path('app_contract_new') }}" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
           <i class="ti ti-plus fs-5"></i> Nouveau Contrat
        </a>
     </div>

     <div class="contract-feed">
        {% for contract in contracts %}
           <div class="card border-0 shadow-sm mb-6 animate__animated animate__fadeInUp" style="border-radius: 16px; transition: transform 0.2s;">
              {# Post Header #}
              <div class="card-header bg-white border-0 p-4 pb-0 d-flex justify-content-between align-items-start">
                 <div class="d-flex align-items-center gap-3">
                    <div class="avatar-ph rounded-circle d-flex align-items-center justify-content-center text-white fw-bold fs-5 shadow-sm" 
                         style="width: 48px; height: 48px; background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);">
                       {{ contract.candidate ? (contract.candidate.firstName|first|upper) : 'U' }}
                    </div>
                    <div>
                       <h6 class="mb-0 fw-bold">{{ contract.candidate.firstName ?? 'Candidat' }} {{ contract.candidate.lastName ?? '' }}</h6>
                       <div class="small text-secondary d-flex align-items-center gap-1">
                          <i class="ti ti-world small"></i> 
                          Généré le {{ contract.startDate ? contract.startDate|date('d M Y') : '—' }}
                       </div>
                    </div>
                 </div>
                 <div class="dropdown">
                    <button class="btn btn-ghost btn-icon btn-sm rounded-circle" data-bs-toggle="dropdown">
                       <i class="ti ti-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                       <li><a class="dropdown-item" href="{{ path('app_contract_edit', {id: contract.id}) }}"><i class="ti ti-edit me-2"></i>Modifier</a></li>
                       <li><hr class="dropdown-divider"></li>
                       <li>
                          <form method="post" action="{{ path('app_contract_delete', {id: contract.id}) }}" onsubmit="return confirm('Supprimer ce contrat ?');">
                             <input type="hidden" name="_token" value="{{ csrf_token('delete_contract_' ~ contract.id) }}">
                             <button class="dropdown-item text-danger"><i class="ti ti-trash me-2"></i>Supprimer</button>
                          </form>
                       </li>
                    </ul>
                 </div>
              </div>

              {# Post Body #}
              <div class="card-body p-4">
                 <div class="p-4 rounded-3 border bg-light-subtle mb-4">
                    <div class="row align-items-center">
                       <div class="col">
                          <span class="badge bg-primary-subtle text-primary mb-2 text-uppercase tracking-wider px-3" style="font-size: 0.7rem;">
                             {{ contract.typeContrat ? contract.typeContrat.name : 'Contrat' }}
                          </span>
                          <h4 class="mb-1 text-dark fw-bolder">{{ contract.jobOffre ? contract.jobOffre.title : 'Offre non spécifiée' }}</h4>
                          <p class="text-secondary small mb-0"><i class="ti ti-map-pin me-1"></i> SyfonuRH Corp — Tunis, TN</p>
                       </div>
                       <div class="col-auto text-end">
                          <div class="fw-bold text-success fs-4">{{ contract.salary ? contract.salary|number_format(0, ',', ' ') ~ ' DT' : '—' }}</div>
                          <div class="small text-secondary text-uppercase tracking-tighter" style="font-size: 0.65rem;">Salaire Brut Mensuel</div>
                       </div>
                    </div>
                 </div>

                 {% if contract.content %}
                    <p class="text-dark small mb-4 px-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                       {{ contract.content }}
                    </p>
                 {% endif %}

                 {# Visual Meta #}
                 <div class="d-flex flex-wrap gap-2">
                    <div class="badge bg-light text-dark border p-2 px-3 fw-normal d-flex align-items-center gap-2">
                       <i class="ti ti-calendar-event text-primary"></i> Fin: {{ contract.endDate ? contract.endDate|date('d/m/Y') : 'CDI' }}
                    </div>
                    <div class="badge bg-light text-dark border p-2 px-3 fw-normal d-flex align-items-center gap-2">
                       <i class="ti ti-shield-check {{ contract.signed ? 'text-success' : 'text-warning' }}"></i> {{ contract.signed ? 'Certifié' : 'En attente signature' }}
                    </div>
                 </div>
              </div>

              {# Post Footer #}
              <div class="card-footer bg-white border-top-0 p-4 pt-0 d-flex gap-2">
                 <a href="{{ path('app_contract_show', {id: contract.id}) }}" class="btn btn-primary flex-grow-1 d-flex align-items-center justify-content-center gap-2 shadow-sm">
                    <i class="ti ti-info-circle fs-5"></i> Voir les détails
                 </a>
                 <button onclick="saveAsPdf('{{ path('app_contract_pdf', {id: contract.id, filename: 'contrat-' ~ contract.id ~ '.pdf'}) }}', 'contrat-{{ contract.id }}.pdf', this)" 
                         class="btn btn-outline-primary px-3 py-2 d-flex flex-column align-items-center gap-1" title="Télécharger PDF">
                    <i class="ti ti-file-download fs-5"></i>
                    <span style="font-size: 0.6rem; font-weight: bold; text-transform: uppercase;">Export</span>
                 </button>
                 <button class="btn btn-ghost-secondary px-3 py-2 btn-preview-pdf d-flex flex-column align-items-center gap-1" 
                         data-url="{{ path('app_contract_pdf_preview', {id: contract.id}) }}" 
                         data-download-url="{{ path('app_contract_pdf', {id: contract.id, filename: 'contrat-' ~ contract.id ~ '.pdf'}) }}"
                         title="Aperçu rapide">
                    <i class="ti ti-eye fs-5"></i>
                    <span style="font-size: 0.6rem; font-weight: bold; text-transform: uppercase;">Aperçu</span>
                 </button>
              </div>
           </div>
        {% else %}
           <div class="text-center py-10">
              <div class="bg-light p-5 rounded-circle d-inline-block mb-4">
                 <i class="ti ti-file-off fs-1 text-secondary"></i>
              </div>
              <h5 class="text-secondary">Aucun contrat ne correspond à votre flux.</h5>
           </div>
        {% endfor %}

        {# Pagination Style FB #}
        {% if pages > 1 %}
           <div class="d-flex justify-content-center mt-6">
              <nav>
                 <ul class="pagination pagination-rounded gap-2">
                    <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                       <a class="page-link border-0 shadow-sm" href="{{ path('app_contract_index', filters|merge({page: page-1})) }}"><i class="ti ti-chevron-left"></i></a>
                    </li>
                    {% for p in 1..pages %}
                       {% if p == 1 or p == pages or (p >= page-1 and p <= page+1) %}
                          <li class="page-item {{ p == page ? 'active' : '' }}">
                             <a class="page-link border-0 shadow-sm" href="{{ path('app_contract_index', filters|merge({page: p})) }}">{{ p }}</a>
                          </li>
                       {% endif %}
                    {% endfor %}
                    <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
                       <a class="page-link border-0 shadow-sm" href="{{ path('app_contract_index', filters|merge({page: page+1})) }}"><i class="ti ti-chevron-right"></i></a>
                    </li>
                 </ul>
              </nav>
           </div>
        {% endif %}
     </div>
  </div>

  {# Right Sidebar: Important Stats Only #}
  <div class="col-lg-3">
     <div class="sticky-top" style="top: 2rem;">
        <h6 class="fw-bold mb-4 px-2 d-flex align-items-center gap-2">
           <i class="ti ti-presentation-analytics text-primary"></i> Indicateurs Clés
        </h6>

        {# Hiring Trend Chart Card #}
        <div class="card border-0 shadow-sm mb-4 bg-white overflow-hidden" style="border-radius: 16px;">
           <div class="card-header bg-white border-0 pt-4 px-5 pb-0">
              <div class="small text-secondary fw-bold text-uppercase tracking-wider">Évolution des Embauches</div>
           </div>
           <div class="card-body p-3" style="height: 160px;">
              <canvas id="hiringTrendChartMini" class="w-100 h-100"></canvas>
           </div>
        </div>

        {# Pending Signatures Card #}
        <div class="card border-0 shadow-sm mb-4 bg-white overflow-hidden" style="border-radius: 16px;">
           <div class="card-body p-5">
              <div class="d-flex justify-content-between align-items-start mb-2">
                 <div class="p-2 bg-warning bg-opacity-10 rounded text-warning">
                    <i class="ti ti-signature fs-4"></i>
                 </div>
              </div>
              <div class="small text-secondary fw-bold text-uppercase tracking-wider mb-1" style="font-size: 0.65rem;">Signatures en attente</div>
              <div class="h3 fw-bolder text-dark mb-0">{{ stats.pending_signatures }} <small class="fs-6 fw-normal text-muted">Contrats</small></div>
           </div>
        </div>

        {# Urgent Alerts Card #}
        <div class="card border-0 shadow-sm mb-4 bg-white overflow-hidden" style="border-radius: 16px;">
           <div class="card-body p-5">
              <div class="d-flex justify-content-between align-items-start mb-2">
                 <div class="p-2 bg-danger bg-opacity-10 rounded text-danger">
                    <i class="ti ti-alert-triangle fs-4"></i>
                 </div>
                 <div class="badge bg-danger-subtle text-danger small">Priorité 1</div>
              </div>
              <div class="small text-secondary fw-bold text-uppercase tracking-wider mb-1" style="font-size: 0.65rem;">Fin de contrat (30j)</div>
              <div class="h3 fw-bolder text-dark mb-0">{{ stats.expiring_soon }} <small class="fs-6 fw-normal text-muted">Alertes</small></div>
           </div>
        </div>

        <div class="mt-6 px-4 text-center">
           <div class="small text-secondary mb-2">Besoin d'aide ?</div>
           <button class="btn btn-outline-primary btn-sm w-100">Contacter le support</button>
        </div>
     </div>
  </div>
</div>

<div class="modal fade" id="previewPdfModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
     <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; height: 90vh;">
        <div class="modal-header border-0 p-4">
           <h5 class="modal-title fw-bold"><i class="ti ti-file-text me-2 text-primary"></i>Aperçu du Contrat</h5>
           <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-0">
           <iframe id="previewIframe" src="" style="width: 100%; height: 100%; border: none;"></iframe>
        </div>
        <div class="modal-footer border-0 p-4">
           <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Fermer</button>
           <button id="downloadButton" type="button" class="btn btn-primary px-4">
              <i class="ti ti-download me-2"></i>Télécharger en PDF
           </button>
        </div>
     </div>
  </div>
</div>

<div id="contractsChartData" style="display:none" data-json="{{ chartData|json_encode }}"></div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
        const dataNode = document.getElementById('contractsChartData');
        if (!dataNode) return;
        const chartData = JSON.parse(dataNode.getAttribute('data-json'));
        
        // Mini Chart Implementation
        const ctx = document.getElementById('hiringTrendChartMini');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['J','F','M','A','M','J','J','A','S','O','N','D'],
                    datasets: [{
                        label: 'Contrats',
                        data: Object.values(chartData.trends),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { 
                        x: { 
                            display: true,
                            grid: { display: false },
                            ticks: { font: { size: 9 }, color: '#94a3b8' }
                        },
                        y: { 
                            display: true,
                            beginAtZero: true,
                            grid: { color: '#f1f5f9' },
                            ticks: { font: { size: 9 }, color: '#94a3b8', stepSize: 1 }
                        }
                    }
                }
            });
        }

        // PDF Preview Logic
        const previewModal = new bootstrap.Modal(document.getElementById('previewPdfModal'));
        const previewIframe = document.getElementById('previewIframe');
        const downloadBtn = document.getElementById('downloadButton');

        document.querySelectorAll('.btn-preview-pdf').forEach(btn => {
            btn.addEventListener('click', function() {
                const url = this.getAttribute('data-url');
                const downloadUrl = this.getAttribute('data-download-url');
                
                previewIframe.src = url;
                downloadBtn.onclick = () => saveAsPdf(downloadUrl, `contrat-${url.split('/').filter(Boolean).pop()}.pdf`);
                previewModal.show();
            });
        });

        // Safe Save As Implementation
        window.saveAsPdf = async function(url, fileName, btn = null) {
            if (window.showSaveFilePicker) {
                try {
                    const handle = await window.showSaveFilePicker({
                        suggestedName: fileName,
                        types: [{
                            description: 'Document PDF',
                            accept: {'application/pdf': ['.pdf']},
                        }],
                    });
                    
                    const originalHtml = btn ? btn.innerHTML : '';
                    if (btn) {
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>...';
                        btn.disabled = true;
                    }

                    const response = await fetch(url);
                    if (!response.ok) throw new Error('Erreur serveur');
                    const blob = await response.blob();
                    
                    const writable = await handle.createWritable();
                    await writable.write(blob);
                    await writable.close();
                    
                    if (btn) {
                        btn.innerHTML = originalHtml;
                        btn.disabled = false;
                    }
                } catch (err) {
                    if (err.name !== 'AbortError') {
                        console.error('Erreur:', err);
                        window.open(url, '_blank');
                    }
                }
            } else {
                window.open(url, '_blank');
            }
        };
    });
  </script>
{% endblock %}
