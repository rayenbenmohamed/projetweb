{% extends 'layout/admin.html.twig' %}

{% block title %}Contrat #{{ contract.id }} | SyfonuRH{% endblock %}
{% block page_title %}Détails du contrat{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
  {# Zone Document (Papier Digital) #}
  <div class="col-lg-8">
     <div class="contract-paper shadow-lg position-relative mx-auto animate__animated animate__fadeInUp">
        <div class="watermark-ia">SYFONURH CERTIFIED</div>
        
        <div class="d-flex justify-content-between align-items-center mb-6">
           <div class="bg-dark p-3 rounded-circle text-white shadow">
              <i class="ti ti-building-skyscraper fs-1"></i>
           </div>
            <div class="text-end">
               <h4 class="mb-0 fw-bold">CERTIFICAT RÉGLEMENTAIRE</h4>
               <p class="text-secondary small mb-0">Identifiant Digital : #{{ contract.id|number_format(0, '', '') }}</p>
               <div class="badge bg-light text-dark border mt-1 px-3">Origine Certifiée</div>
              
               <div class="mt-2 small text-secondary font-monospace" style="font-size: 0.65rem;">
                  ID-SEC: SYF-{{ contract.id }}-{{ contract.candidate ? contract.candidate.id : '0' }}-{{ "now"|date('Ymd') }}
               </div>
           </div>
        </div>

        <div class="my-7">
           <div class="text-center mb-6">
              <h2 class="mb-2 text-dark fw-bolder text-uppercase tracking-widest" style="letter-spacing: 2px;">
                 {{ contract.typeContrat ? contract.typeContrat.name : 'Contrat de Travail' }}
              </h2>
              <div class="h-1 bg-primary w-25 mx-auto rounded-pill" style="height: 4px;"></div>
           </div>
           
           <div class="p-5 border-start border-primary border-4 bg-light-subtle rounded shadow-sm mb-6">
              <h6 class="text-uppercase small fw-bold text-secondary tracking-wider mb-4">Clauses Particulières & Engagements</h6>
              <div class="contract-content" style="white-space: pre-wrap; line-height: 2; font-size: 1.1rem; color: #34495e;">
                 {{ contract.content ?: 'Aucun contenu spécifique n\'a été rattaché à ce certificat digital.' }}
              </div>
           </div>
        </div>

        <div class="mt-auto d-flex justify-content-between align-items-end pt-6 border-top border-2 border-light">
           <div class="text-start">
              <div class="signature-seal shadow-sm">
                 <div class="p-1">
                    CERTIFIÉ<br>SYFONURH<br>DEPT. RH
                 </div>
              </div>
              <p class="small text-secondary mt-2 mb-0 font-monospace">Validé numériquement</p>
           </div>
           
           <div class="text-center" style="min-width: 250px;">
              <p class="small text-secondary mb-3 text-uppercase tracking-tighter">Signature Électronique du Salarié</p>
              <div class="bg-light rounded p-3 mb-2" style="border: 1px dashed #ced4da;">
                 {% if contract.signatureBase64 %}
                    <img src="{{ contract.signatureBase64 }}" alt="Signature Biométrique" 
                         class="img-fluid" style="max-height: 80px; filter: contrast(120%) grayscale(100%);">
                 {% else %}
                    <div class="text-muted small italic py-4">Pas de signature enregistrée</div>
                 {% endif %}
              </div>
              <div class="fw-bold text-dark fs-5">{{ contract.candidate ? (contract.candidate.firstName ~ ' ' ~ contract.candidate.lastName) : 'Document non signé' }}</div>
              <div class="small text-secondary">{{ contract.signedAt ? ('Signé le ' ~ contract.signedAt|date('d/m/Y H:i')) : '' }}</div>
           </div>
        </div>
     </div>
  </div>

  {# Barre Latérale : Authenticité & Actions #}
  <div class="col-lg-4 animate__animated animate__fadeInRight">
     {# Quick Info #}
     <div class="card mb-6 overflow-hidden shadow-sm border-0">
        <div class="card-header bg-dark text-white p-4 d-flex align-items-center justify-content-between">
           <h6 class="mb-0 text-uppercase tracking-wider">Certificat de Validité</h6>
           <i class="ti ti-shield-check text-success fs-4"></i>
        </div>
         <div class="card-body p-6 text-center">
            {% set full_url = url('app_contract_show', {id: contract.id}) %}
            <div class="bg-white p-3 d-inline-block rounded shadow-sm mb-4 border">
               <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={{ full_url|url_encode }}" 
                    alt="Lien de Vérification" class="img-fluid" style="width: 150px;">
            </div>
           
           <div class="d-grid gap-2 mb-4">
              <button onclick="window.print()" class="btn btn-outline-dark d-flex align-items-center justify-content-center gap-2">
                 <i class="ti ti-printer fs-5"></i> Imprimer le Certificat
              </button>
              <button data-bs-toggle="modal" data-bs-target="#emailPreviewModal" class="btn btn-outline-primary d-flex align-items-center justify-content-center gap-2">
                 <i class="ti ti-mail fs-5"></i> Aperçu e-mail
              </button>
              <button id="exportCalendarBtn" class="btn btn-outline-info d-flex align-items-center justify-content-center gap-2">
                 <i class="ti ti-calendar-event fs-5"></i> Ajouter à l'agenda
              </button>
              <a href="https://wa.me/?text={{ '✨ Contrat SyfonuRH Certifié ✨\n\nBonjour ' ~ (contract.candidate ? contract.candidate.firstName : '') ~ ',\nVous pouvez consulter votre contrat officiel ici : '|url_encode }}{{ full_url|url_encode }}" 
                 target="_blank"
                 class="btn btn-success d-flex align-items-center justify-content-center gap-2">
                 <i class="ti ti-brand-whatsapp fs-5"></i> 
                 <span>Partager WhatsApp</span>
              </a>
           </div>
        </div>
     </div>

     {# Assistance RH #}
     <div class="card mb-6 border-0 shadow-sm" style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);">
         <div class="card-body p-6">
            <h6 class="mb-4 d-flex align-items-center gap-2 text-dark">
               <i class="ti ti-info-circle fs-4"></i> Assistance RH
            </h6>
           <div class="alert bg-white border shadow-sm small text-secondary mb-0">
              <ul class="ps-3 mb-0">
                 {% if not contract.signed %}
                    <li class="mb-2">⚠️ <strong class="text-danger">Signature manquante</strong> : Relancer le candidat via WhatsApp.</li>
                 {% endif %}
                 {% if contract.startDate %}
                    <li class="mb-2">📅 <strong>Point de mi-parcours</strong> : Prévoyez un entretien de suivi le <strong>{{ contract.startDate|date_modify('+45 days')|date('d/m/Y') }}</strong>.</li>
                 {% endif %}
                 <li>💡 <strong>Optimisation</strong> : Ce profil semble éligible aux avantages fiscaux tunisiens (Programme SIVP/Karama).</li>
              </ul>
           </div>
        </div>
     </div>

     {# Career Timeline Card #}
     <div class="card mb-6 shadow-sm border-0">
        <div class="card-body p-6">
           <h6 class="mb-6 d-flex align-items-center gap-3">
              <span class="bg-primary p-2 rounded-circle text-white d-flex">
                 <i class="ti ti-timeline fs-6"></i>
              </span>
              Cycle de Vie du Salarié
           </h6>
           <ul class="career-timeline">
              <li class="timeline-item completed">
                 <div class="fw-bold text-dark">Signature du contrat</div>
                 <div class="small text-secondary">{{ contract.startDate ? contract.startDate|date('d F Y', 'Europe/Paris') : '—' }}</div>
                 <div class="badge bg-success-subtle text-success mt-1">Étape Validée</div>
              </li>
              <li class="timeline-item">
                 <div class="fw-bold text-dark">Fin de Période d'essai</div>
                 <div class="small text-secondary">{{ contract.startDate ? contract.startDate|date_modify('+90 days')|date('d F Y', 'Europe/Paris') : '—' }}</div>
                 <div class="small text-primary mt-1 fw-bold">Échéance automatique</div>
              </li>
              <li class="timeline-item {{ contract.endDate and "now"|date('Ymd') > contract.endDate|date('Ymd') ? 'completed' : '' }}">
                 <div class="fw-bold text-dark">Renouvellement ou Fin</div>
                 <div class="small text-secondary">{{ contract.endDate ? contract.endDate|date('d F Y', 'Europe/Paris') : 'Contrat à durée indéterminée' }}</div>
              </li>
           </ul>
        </div>
     </div>

     {# Actions Rapides #}
     <div class="card border-0 shadow-sm">
        <div class="card-body p-5">
           <div class="row g-2">
              <div class="col-12">
                 <a href="{{ path('app_contract_edit', {id: contract.id}) }}" class="btn btn-primary btn-lg w-100 shadow-sm d-flex align-items-center justify-content-center gap-2">
                    <i class="ti ti-pencil fs-4"></i> Modifier
                 </a>
              </div>
              <div class="col-12 mt-3">
                 <a href="{{ path('app_contract_index') }}" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
                    <i class="ti ti-arrow-back-up fs-4"></i> Liste des contrats
                 </a>
              </div>
           </div>
        </div>
     </div>
  </div>
</div>
{% endblock %}

{% block modals %}
  {# Modal Aperçu E-mail #}
  <div class="modal fade" id="emailPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content shadow-lg border-0">
        <div class="modal-header bg-primary text-white p-4">
           <h5 class="modal-title d-flex align-items-center gap-2">
              <i class="ti ti-mail-forward fs-4"></i> Aperçu de l'e-mail Candidat
           </h5>
           <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-5">
           <div class="border rounded p-4 bg-light shadow-inner mb-4">
              <div class="mb-3">
                 <label class="small text-secondary fw-bold text-uppercase">Destinataire :</label>
                 <div class="fw-bold text-dark">{{ contract.candidate ? contract.candidate.email : 'candidat@email.com' }}</div>
              </div>
              <div class="mb-3">
                 <label class="small text-secondary fw-bold text-uppercase">Objet :</label>
                 <div class="text-primary fw-bold">Votre contrat SyfonuRH - Action Requise</div>
              </div>
              <hr>
              <div class="email-mockup p-4 bg-white border shadow-sm rounded">
                 <p>Bonjour <strong>{{ contract.candidate ? contract.candidate.firstName : 'Candidat' }}</strong>,</p>
                 <p>Nous sommes ravis de vous accueillir chez <strong>SyfonuRH Corp</strong>.</p>
                 <p>Votre contrat de type <strong>{{ contract.typeContrat ? contract.typeContrat.name : 'Standard' }}</strong> est maintenant disponible pour signature électronique sur notre plateforme.</p>
                 <div class="my-4 text-center">
                    <button class="btn btn-primary px-5 py-3 fw-bold shadow-sm">Accéder à mon Contrat Digital</button>
                 </div>
                 <p class="text-secondary small">Ce document est certifié par notre système d'IA et dispose d'un identifiant unique de vérification.</p>
                 <p>Cordialement,<br>L'équipe Recrutement SyfonuRH</p>
              </div>
           </div>
        </div>
        <div class="modal-footer p-4 border-top">
           <button type="button" class="btn btn-link link-secondary" data-bs-dismiss="modal">Annuler</button>
           <button id="sendFakeEmailBtn" type="button" class="btn btn-primary px-4 d-flex align-items-center gap-2">
              <i class="ti ti-send fs-5"></i> Envoyer maintenant
           </button>
        </div>
      </div>
    </div>
  </div>
{% endblock %}


