<style>
    .form-glass {
        background: rgba(255, 255, 255, 0.4);
        padding: 2rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .form-control, .form-select {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        border: 1px solid #e5e7eb;
        background-color: white;
        transition: all 0.3s ease;
    }
    .form-control:focus, .form-select:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
</style>

{{ form_start(form, {'attr': {'class': 'form-glass shadow-sm'}}) }}
    <div class="row g-4">
        <div class="col-md-6">
            {{ form_label(form.candidate, 'Candidat') }}
            {{ form_widget(form.candidate, {'attr': {'class': 'form-select select2'}}) }}
            {{ form_errors(form.candidate) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.recruiter, 'Recruteur responsable') }}
            {{ form_widget(form.recruiter, {'attr': {'class': 'form-select select2'}}) }}
            {{ form_errors(form.recruiter) }}
        </div>
        <div class="col-md-12">
            {{ form_label(form.jobOffre, 'Offre d\'emploi associée') }}
            {{ form_widget(form.jobOffre, {'attr': {'class': 'form-select select2'}}) }}
            {{ form_errors(form.jobOffre) }}
        </div>
        <div class="col-md-4">
            {{ form_label(form.typeContrat, 'Type de Contrat') }}
            {{ form_widget(form.typeContrat, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.typeContrat) }}
        </div>
        <div class="col-md-4">
            {{ form_label(form.salary, 'Salaire Brut (DT)') }}
            {{ form_widget(form.salary, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 3500'}}) }}
            {{ form_errors(form.salary) }}
        </div>
        <div class="col-md-4">
            {{ form_label(form.status, 'Statut du contrat') }}
            {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
            {{ form_errors(form.status) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.startDate, 'Date de Début') }}
            {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.startDate) }}
        </div>
        <div class="col-md-6">
            {{ form_label(form.endDate, 'Date de Fin (Optionnel)') }}
            {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.endDate) }}
        </div>
    </div>

    <div class="mt-5 d-flex gap-3">
        <button class="btn btn-primary btn-premium px-5 shadow-sm">
            <i class="fas fa-save me-2"></i>{{ button_label|default('Enregistrer le contrat') }}
        </button>
        <a href="{{ path('app_contract_index') }}" class="btn btn-outline-secondary btn-premium">
            Annuler
        </a>
    </div>
{{ form_end(form) }}
