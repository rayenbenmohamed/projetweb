{% set is_edit = is_edit ?? false %}
{% set form = form ?? {} %}

<form method="post" class="needs-validation" novalidate>
  <div class="row g-4">
    <div class="col-md-6">
      <label class="form-label">Candidat *</label>
      <select class="form-select" name="candidate_id" required data-choices>
        <option value="" disabled {{ (form.candidate_id ?? '') == '' and not contract.candidate ? 'selected' : '' }}>Sélectionner…</option>
        {% if contract.candidate %}
          <option value="{{ contract.candidate.id }}" {{ (form.candidate_id ?? contract.candidate.id) == contract.candidate.id ? 'selected' : '' }}>
            {{ (contract.candidate.firstName ?? '') ~ ' ' ~ (contract.candidate.lastName ?? '') }} — {{ contract.candidate.email }}
          </option>
        {% endif %}
        {% for u in candidates %}
          <option value="{{ u.id }}" {{ (form.candidate_id ?? (contract.candidate ? contract.candidate.id : '')) == u.id ? 'selected' : '' }}>
            {{ (u.firstName ?? '') ~ ' ' ~ (u.lastName ?? '') }} — {{ u.email }}
          </option>
        {% endfor %}
      </select>
      <div class="invalid-feedback">Candidat obligatoire.</div>
    </div>

    <div class="col-md-6">
      <label class="form-label">Recruteur</label>
      <select class="form-select" name="recruiter_id" data-choices>
        <option value="" {{ (form.recruiter_id ?? '') == '' and not contract.recruiter ? 'selected' : '' }}>—</option>
        {% if contract.recruiter %}
          <option value="{{ contract.recruiter.id }}" {{ (form.recruiter_id ?? contract.recruiter.id) == contract.recruiter.id ? 'selected' : '' }}>
            {{ (contract.recruiter.firstName ?? '') ~ ' ' ~ (contract.recruiter.lastName ?? '') }} — {{ contract.recruiter.email }}
          </option>
        {% endif %}
        {% for u in recruiters %}
          <option value="{{ u.id }}" {{ (form.recruiter_id ?? (contract.recruiter ? contract.recruiter.id : '')) == u.id ? 'selected' : '' }}>
            {{ (u.firstName ?? '') ~ ' ' ~ (u.lastName ?? '') }} — {{ u.email }}
          </option>
        {% endfor %}
      </select>
    </div>

    <div class="col-md-6">
      <label class="form-label">Offre *</label>
      <select class="form-select" name="job_offre_id" required data-choices>
        <option value="" disabled {{ (form.job_offre_id ?? '') == '' and not contract.jobOffre ? 'selected' : '' }}>Sélectionner…</option>
        {% if contract.jobOffre %}
          <option value="{{ contract.jobOffre.id }}" {{ (form.job_offre_id ?? contract.jobOffre.id) == contract.jobOffre.id ? 'selected' : '' }}>
            {{ contract.jobOffre.title }}
          </option>
        {% endif %}
        {% for o in job_offres %}
          <option value="{{ o.id }}" {{ (form.job_offre_id ?? (contract.jobOffre ? contract.jobOffre.id : '')) == o.id ? 'selected' : '' }}>
            {{ o.title }}
          </option>
        {% endfor %}
      </select>
      <div class="invalid-feedback">Offre obligatoire.</div>
    </div>

    <div class="col-md-6">
      <label class="form-label">Type de contrat</label>
      <select class="form-select" name="type_contrat_id" data-choices>
        <option value="" {{ (form.type_contrat_id ?? '') == '' and not contract.typeContrat ? 'selected' : '' }}>—</option>
        {% if contract.typeContrat %}
          <option value="{{ contract.typeContrat.id }}" {{ (form.type_contrat_id ?? contract.typeContrat.id) == contract.typeContrat.id ? 'selected' : '' }}>
            {{ contract.typeContrat.name }}
          </option>
        {% endif %}
        {% for t in types %}
          <option value="{{ t.id }}" {{ (form.type_contrat_id ?? (contract.typeContrat ? contract.typeContrat.id : '')) == t.id ? 'selected' : '' }}>
            {{ t.name }}
          </option>
        {% endfor %}
      </select>
    </div>

    <div class="col-md-4">
      <label class="form-label">Date début *</label>
      <input class="form-control" type="date" name="start_date" required
             value="{{ form.start_date ?? (contract.startDate ? contract.startDate|date('Y-m-d') : '') }}">
      <div class="invalid-feedback">Date de début obligatoire.</div>
    </div>

    <div class="col-md-4">
      <label class="form-label">Date fin</label>
      <input class="form-control" type="date" name="end_date"
             value="{{ form.end_date ?? (contract.endDate ? contract.endDate|date('Y-m-d') : '') }}">
    </div>

    <div class="col-md-4">
      <label class="form-label">Salaire brut (TND) *</label>
      <input class="form-control" type="number" name="salary" min="0" step="1" required
             value="{{ form.salary ?? (contract.salary ?? '') }}">
      <div class="invalid-feedback">Salaire obligatoire.</div>
    </div>

    <div class="col-md-6">
      <label class="form-label">Statut</label>
      {% set statuses = ['En Attente','Actif','Suspendu','Terminé'] %}
      <select class="form-select" name="status" data-choices>
        {% for s in statuses %}
          <option value="{{ s }}" {{ (form.status ?? (contract.status ?? 'En Attente')) == s ? 'selected' : '' }}>{{ s }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="col-md-6 d-flex align-items-end">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="isSignedSwitch"
               name="is_signed" value="1" {{ (form.is_signed ?? (contract.signed ? '1' : '0')) == '1' ? 'checked' : '' }}>
        <label class="form-check-label" for="isSignedSwitch">Contrat signé</label>
      </div>
    </div>
  </div>

  {# Division Innovante : Dashboard Financier & Signature #}
  <div class="row g-4 mt-4">
    <div class="col-lg-6">
      <div class="card bg-primary-subtle border-primary-subtle h-100 shadow-sm">
        <div class="card-body p-4">
          <h6 class="mb-4 d-flex align-items-center gap-2">
            <i class="ti ti-calculator text-primary fs-4"></i> Synthèse des Coûts
          </h6>
          <div class="d-flex justify-content-between mb-3">
            <span class="text-secondary">Salaire Brut Annuel</span>
            <span class="fw-bold fs-5" id="brutDisplay">0 TND</span>
          </div>
          <div class="d-flex justify-content-between mb-3 text-success">
            <span class="fw-semibold">Salaire Net Mensuel (Est.)</span>
            <span class="fw-bold fs-5" id="netDisplay">0 TND</span>
          </div>
          <hr class="my-4"/>
          <div class="d-flex justify-content-between mb-2 small">
            <span class="text-secondary">Coût de l'entreprise (Charges pat.)</span>
            <span class="fw-semibold" id="totalCostDisplay">0 TND</span>
          </div>
          <div class="progress mt-3" style="height: 8px; border-radius: 4px;">
            <div id="salaryProgress" class="progress-bar bg-primary" role="progressbar" style="width: 0%"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card h-100 shadow-sm">
        <div class="card-body p-4">
          <h6 class="mb-4 d-flex align-items-center justify-content-between">
            <span class="d-flex align-items-center gap-2">
              <i class="ti ti-signature text-primary fs-4"></i> Signature du Salarié
            </span>
            <button type="button" class="btn btn-ghost btn-xs text-danger" id="clearSignature">Réinitialiser</button>
          </h6>
          <div class="border rounded bg-light-subtle position-relative overflow-hidden" style="height: 140px; border: 2px dashed #dee2e6 !important;">
            <canvas id="signaturePad" width="500" height="140" class="w-100 h-100" style="cursor: crosshair; touch-action: none;"></canvas>
            <div id="securityOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-none bg-white bg-opacity-75 d-flex align-items-center justify-content-center flex-column">
               <div class="spinner-grow text-primary mb-2" role="status" style="width: 1.5rem; height: 1.5rem;"></div>
               <span class="small fw-bold text-primary text-uppercase tracking-wider">Traitement sécurisé...</span>
            </div>
            <div id="verifySuccessBadge" class="position-absolute top-0 end-0 m-2 d-none">
               <span class="badge bg-success shadow-sm"><i class="ti ti-shield-check me-1"></i> Vérifié numériquement</span>
            </div>
          </div>
          <input type="hidden" name="signature_base64" id="signatureInput" value="{{ form.signature_base64 ?? (contract.signatureBase64 ?? '') }}">
          <div class="mt-3">
            <button type="button" class="btn btn-outline-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2 py-2" id="verifySignatureBtn">
              <i class="ti ti-fingerprint fs-5"></i> Analyser l'authenticité
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# AI Content Generator Card #}
  <div class="card mt-4 border-dashed bg-light-subtle shadow-none">
    <div class="card-body p-4 d-md-flex align-items-center justify-content-between gap-4">
      <div class="d-flex align-items-center gap-3 mb-3 mb-md-0">
        <div class="bg-dark p-3 rounded-circle text-warning shadow-sm">
           <i class="ti ti-sparkles fs-4"></i>
        </div>
        <div>
          <h6 class="mb-1">Assistant de rédaction de clauses</h6>
          <p class="small text-secondary mb-0">Rédiger automatiquement un projet de document basé sur le profil du candidat.</p>
        </div>
      </div>
      <button type="button" class="btn btn-dark px-4 py-2 shadow-sm" id="generateSuggestedContent">
        Générer le texte
      </button>
    </div>
  </div>

  {# Contract Content Textarea #}
  <div class="col-12 mt-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
      <label class="form-label mb-0 fw-bold text-dark">Contenu du contrat (Clauses légales)</label>
      <span class="badge bg-light text-dark border"><i class="ti ti-edit me-1"></i> Mode Édition</span>
    </div>
    <textarea class="form-control shadow-sm" name="content" id="contractContentMain" rows="12" 
              style="border-radius: 8px; border: 1px solid #d1d9e6;"
              placeholder="Rédigez ici ou utilisez le bouton 'Générer le texte' ci-dessus pour un remplissage automatique...">{{ form.content ?? (contract.content ?? '') }}</textarea>
  </div>

  {% if candidates is empty %}
    <div class="alert alert-warning mt-5 mb-0">
      Aucun utilisateur avec le rôle <code>ROLE_CANDIDAT</code> n’a été trouvé. Vérifie la valeur du champ <code>role</code> en base.
    </div>
  {% endif %}

  <div class="d-flex justify-content-end gap-2 mt-6">
    <a href="{{ path('app_contract_index') }}" class="btn btn-outline-secondary">Annuler</a>
    <button type="submit" class="btn btn-primary">
      {{ is_edit ? 'Enregistrer' : 'Créer le contrat' }}
    </button>
  </div>
</form>

{# Modal pour le contenu suggéré #}
<div class="modal fade" id="suggestionModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header bg-dark text-white border-0">
        <h5 class="modal-title d-flex align-items-center gap-2">
          <i class="ti ti-file-text text-white"></i> Assistant de Rédaction
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="alert alert-info border-0 bg-info-subtle small mb-4">
          Le module d'assistance a généré ce projet de contrat en se basant sur les informations saisies.
        </div>
        <textarea id="suggestedText" class="form-control bg-light" rows="12" style="font-family: 'Courier New', Courier, monospace; font-size: 14px;"></textarea>
      </div>
      <div class="modal-footer border-0 p-4 pt-0">
        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Annuler</button>
        <button type="button" class="btn btn-primary px-4" id="useAiText">Valider & Insérer</button>
      </div>
    </div>
  </div>
</div>

