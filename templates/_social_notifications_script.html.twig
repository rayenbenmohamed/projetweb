<script>
(function () {
    var wrap = document.getElementById('socialNotifyWrap');
    if (!wrap || !wrap.dataset.notifyUrl) {
        return;
    }
    var notifyTargetMessage = '{{ path('app_friends_index') }}#section-friends';
    var notifyTargetFriend = '{{ path('app_friends_index') }}#section-incoming-requests';
    var prevDetail = {
        friend_requests: parseInt(wrap.dataset.initialFr || '0', 10) || 0,
        unread_messages: parseInt(wrap.dataset.initialUm || '0', 10) || 0
    };

    function isDesktopNotificationAvailable() {
        return typeof window !== 'undefined' && 'Notification' in window;
    }

    function requestDesktopPermission() {
        if (!isDesktopNotificationAvailable()) {
            return;
        }
        if (Notification.permission === 'default') {
            Notification.requestPermission().catch(function () {
            });
        }
    }

    function ensureDesktopPermissionWithFeedback() {
        if (!isDesktopNotificationAvailable()) {
            showToast('SyfonuRH', 'Votre navigateur ne supporte pas les notifications desktop.');
            return;
        }
        if (Notification.permission === 'granted') {
            showDesktopNotification('SyfonuRH', 'Notifications desktop activées.', notifyTargetMessage);
            showToast('SyfonuRH', 'Notifications desktop déjà activées.');
            return;
        }
        if (Notification.permission === 'denied') {
            showToast('SyfonuRH', 'Notifications bloquées par le navigateur. Autorisez-les depuis le cadenas de l’URL.');
            return;
        }
        Notification.requestPermission().then(function (perm) {
            if (perm === 'granted') {
                showDesktopNotification('SyfonuRH', 'Notifications desktop activées.', notifyTargetMessage);
                showToast('SyfonuRH', 'Notifications desktop activées.');
            } else {
                showToast('SyfonuRH', 'Autorisation refusée. Activez-la depuis le navigateur.');
            }
        }).catch(function () {
            showToast('SyfonuRH', 'Impossible de demander la permission desktop.');
        });
    }

    function showDesktopNotification(title, message, url) {
        if (!isDesktopNotificationAvailable() || Notification.permission !== 'granted') {
            return;
        }
        try {
            var n = new Notification(title, {
                body: message,
                icon: '{{ asset('dasher/images/brand/logo/logo-icon.svg') }}',
                tag: 'syfonurh-social'
            });
            n.onclick = function () {
                window.focus();
                if (url) {
                    window.location.href = url;
                }
                n.close();
            };
        } catch (e) {
        }
    }

    function shouldShowDesktopNotification() {
        // Show desktop notifications whenever user is not actively focused on this tab/window.
        // This covers both hidden tabs and visible tabs when another app/window is in front.
        return document.visibilityState !== 'visible' || !document.hasFocus();
    }

    function showToast(title, message) {
        var host = document.getElementById('socialNotifyToastHost');
        if (!host || typeof bootstrap === 'undefined' || !bootstrap.Toast) {
            return;
        }
        var el = document.createElement('div');
        el.className = 'toast';
        el.setAttribute('role', 'alert');
        el.innerHTML = '<div class="toast-header"><i class="ti ti-bell me-2"></i><strong class="me-auto">'
            + title + '</strong><button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Fermer"></button></div>'
            + '<div class="toast-body">' + message + '</div>';
        host.appendChild(el);
        var t = new bootstrap.Toast(el, {delay: 7000});
        el.addEventListener('hidden.bs.toast', function () {
            el.remove();
        });
        t.show();
    }

    function apply(data) {
        var fr = parseInt(String(data.friend_requests || 0), 10) || 0;
        var um = parseInt(String(data.unread_messages || 0), 10) || 0;
        var total = fr + um;

        if (fr > prevDetail.friend_requests) {
            showToast('SyfonuRH', 'Vous avez une nouvelle demande d’ami.');
            if (shouldShowDesktopNotification()) {
                showDesktopNotification('SyfonuRH', 'Nouvelle demande d’ami reçue.', notifyTargetFriend);
            }
        }
        if (um > prevDetail.unread_messages) {
            showToast('SyfonuRH', 'Vous avez reçu un nouveau message.');
            if (shouldShowDesktopNotification()) {
                showDesktopNotification('SyfonuRH', 'Vous avez reçu un nouveau message.', notifyTargetMessage);
            }
        }

        prevDetail = {friend_requests: fr, unread_messages: um};

        var badge = document.getElementById('socialNotifyBadge');
        if (badge) {
            badge.dataset.count = String(total);
            badge.textContent = total > 99 ? '99+' : String(total);
            badge.classList.toggle('d-none', total === 0);
        }
        document.querySelectorAll('[data-sn-friend-requests]').forEach(function (el) {
            el.textContent = String(fr);
        });
        document.querySelectorAll('[data-sn-unread-messages]').forEach(function (el) {
            el.textContent = String(um);
        });
        document.querySelectorAll('[data-sidebar-social-total]').forEach(function (el) {
            el.textContent = total > 99 ? '99+' : String(total);
            el.classList.toggle('d-none', total === 0);
        });
    }

    function poll() {
        fetch(wrap.dataset.notifyUrl, {headers: {'Accept': 'application/json'}, credentials: 'same-origin'})
            .then(function (r) {
                return r.ok ? r.json() : null;
            })
            .then(function (data) {
                if (data) {
                    apply(data);
                }
            })
            .catch(function () {
            });
    }

    var bellButton = document.getElementById('socialNotifyToggle');
    if (bellButton) {
        bellButton.addEventListener('click', requestDesktopPermission, {once: true});
    }
    var desktopButton = document.getElementById('socialNotifyEnableDesktop');
    if (desktopButton) {
        desktopButton.addEventListener('click', ensureDesktopPermissionWithFeedback);
    }
    // Ask permission on first page load if user hasn't decided yet.
    requestDesktopPermission();

    setInterval(poll, 10000);
    document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') {
            poll();
        }
    });
})();
</script>
