{% extends 'layout/admin.html.twig' %}

{% block page_title %}Lettres de Motivation{% endblock %}

{% block content %}
<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Lettres de Motivation</h1>
        <a href="{{ path('app_cover_letter_new') }}" class="btn btn-primary shadow-sm">
            <i class="ti ti-plus"></i> Nouvelle lettre
        </a>
    </div>

    <div class="card shadow-sm border-0 border-top border-primary border-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Entreprise</th>
                            <th>Poste Ciblé</th>
                            <th>Destinataire</th>
                            <th>Créée le</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for cover_letter in cover_letters %}
                        <tr>
                            <td class="fw-bold">#{{ cover_letter.id }}</td>
                            <td><span class="text-primary fw-semibold">{{ cover_letter.companyName }}</span></td>
                            <td>{{ cover_letter.position }}</td>
                            <td>{{ cover_letter.recipientName ?: '-' }}</td>
                            <td>{{ cover_letter.createdAt ? cover_letter.createdAt|date('d/m/Y H:i') : '' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_cover_letter_show', {'id': cover_letter.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                                    <i class="ti ti-eye"></i>
                                </a>
                                <a href="{{ path('app_cover_letter_edit', {'id': cover_letter.id}) }}" class="btn btn-sm btn-outline-primary ms-1" title="Modifier">
                                    <i class="ti ti-edit"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="ti ti-mail-off fs-1 d-block mb-2"></i>
                                Aucune lettre de motivation n'a été trouvée.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
