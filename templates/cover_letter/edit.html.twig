{% extends 'layout/admin.html.twig' %}

{% block page_title %}Modifier Lettre{% endblock %}

{% block content %}
    <div class="container-fluid mt-4 mb-5">
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">Modifier la lettre : {{ cover_letter.companyName }}</h1>
                <div>
                    <a href="{{ path('app_cover_letter_index') }}" class="btn btn-outline-secondary shadow-sm me-2">
                        <i class="ti ti-list"></i> Liste des Lettres
                    </a>
                    <a href="{{ path('app_cover_letter_show', {'id': cover_letter.id}) }}" class="btn btn-outline-info shadow-sm">
                        <i class="ti ti-eye"></i> Aperçu
                    </a>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12 col-xl-8 mx-auto">
                <div class="card shadow border-0 border-top border-warning border-3">
                    <div class="card-body p-4">
                        <div class="alert alert-info d-flex align-items-center" role="alert">
                            <i class="ti ti-info-circle fs-4 me-2"></i>
                            <div>Assurez-vous de personnaliser la lettre. Modifiée pour la dernière fois le <strong>{{ cover_letter.updatedAt ? cover_letter.updatedAt|date('d/m/Y H:i') : '' }}</strong>.</div>
                        </div>
                        {{ include('cover_letter/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
