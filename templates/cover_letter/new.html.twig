{% extends 'layout/admin.html.twig' %}

{% block page_title %}Nouvelle Lettre{% endblock %}

{% block content %}
    <div class="container-fluid mt-4 mb-5">
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">Créer une lettre de motivation</h1>
                <a href="{{ path('app_cover_letter_index') }}" class="btn btn-outline-secondary">
                    <i class="ti ti-arrow-left"></i> Retour à la liste
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-12 col-xl-8 mx-auto">
                <div class="card shadow border-0 border-top border-primary border-3">
                    <div class="card-header bg-white border-bottom p-4">
                        <h5 class="mb-0 text-primary"><i class="ti ti-mail me-2"></i>Détails de la lettre</h5>
                    </div>
                    <div class="card-body p-4">
                        {{ include('cover_letter/_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
