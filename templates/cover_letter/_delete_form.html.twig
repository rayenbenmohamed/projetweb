<form method="post" action="{{ path('app_cover_letter_delete', {'id': cover_letter.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette lettre de motivation ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cover_letter.id) }}">
    <button class="btn btn-outline-danger w-100"><i class="ti ti-trash"></i> Supprimer cette lettre</button>
</form>
