{% extends 'layout/front.html.twig' %}

{% block title %}Mon calendrier | SyfonuRH{% endblock %}
{% block page_title %}Mon calendrier{% endblock %}

{% block content %}
<div class="card card-lg mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Vue calendrier</h5>
        <small class="text-secondary">Mois / semaine / jour</small>
    </div>
    <div class="card-body">
        <div id="calendar-holder"></div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-xl-5">
        <div class="card card-lg">
            <div class="card-header">
                <h5 class="mb-0">Planifier une journée</h5>
            </div>
            <div class="card-body p-4">
                <form method="post" action="{{ path('app_calendar_index') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('calendar_create') }}">

                    <div class="mb-3">
                        <label class="form-label">Titre <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" maxlength="150" required placeholder="Ex: Réunion équipe">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Début <span class="text-danger">*</span></label>
                        <input type="datetime-local" name="startAt" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Fin</label>
                        <input type="datetime-local" name="endAt" class="form-control">
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="4" placeholder="Notes, objectifs, lien visio..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Ajouter l'événement</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card card-lg">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Mes événements</h5>
                <span class="badge bg-primary rounded-pill">{{ events|length }}</span>
            </div>
            <div class="list-group list-group-flush">
                {% for event in events %}
                    <div class="list-group-item py-3">
                        <div class="d-flex justify-content-between gap-3 flex-wrap">
                            <div>
                                <h6 class="mb-1">{{ event.title }}</h6>
                                <div class="text-secondary small mb-2">
                                    {{ event.startAt|date('d/m/Y H:i') }}
                                    {% if event.endAt %}
                                        — {{ event.endAt|date('d/m/Y H:i') }}
                                    {% endif %}
                                </div>
                                {% if event.description %}
                                    <p class="mb-0 small">{{ event.description }}</p>
                                {% endif %}
                            </div>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_calendar_edit', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                                <form method="post" action="{{ path('app_calendar_delete', {id: event.id}) }}" onsubmit="return confirm('Supprimer cet événement ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('calendar_delete' ~ event.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="list-group-item text-secondary small">
                        Aucun événement pour le moment. Ajoutez votre premier planning à gauche.
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const calendarEl = document.getElementById('calendar-holder');
            if (!calendarEl || typeof FullCalendar === 'undefined') {
                return;
            }

            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                timeZone: 'local',
                firstDay: 1,
                headerToolbar: {
                    start: 'prev,next today',
                    center: 'title',
                    end: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: 'Aujourd\'hui',
                    month: 'Mois',
                    week: 'Semaine',
                    day: 'Jour'
                },
                eventSources: [
                    {
                        url: '{{ path('fc_load_events') }}',
                        method: 'POST',
                        failure: () => {
                            console.error('Chargement des événements impossible.');
                        }
                    }
                ],
                eventClick: (info) => {
                    if (info.event.url) {
                        info.jsEvent.preventDefault();
                        window.location.href = info.event.url;
                    }
                }
            });

            calendar.render();
        });
    </script>
{% endblock %}

