{% extends 'layout/admin.html.twig' %}

{% block title %}Types de Contrat | SyfonuRH{% endblock %}
{% block page_title %}Types de Contrat{% endblock %}

{% block content %}
<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 15px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    }
    .hero-gradient {
        background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);
        color: white;
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
    }
    .btn-premium {
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
</style>

<div class="container mt-4">
    <div class="hero-gradient d-flex justify-content-between align-items-center">
        <div>
            <h1 class="display-5 fw-bold mb-0">Types de Contrat</h1>
            <p class="lead opacity-75">Gérez les catégories de contrats disponibles</p>
        </div>
        <div>
            <a href="{{ path('app_type_contrat_new') }}" class="btn btn-light btn-premium shadow-sm text-success">
                <i class="fas fa-plus me-2"></i>Nouveau Type
            </a>
        </div>
    </div>

    {# Search Bar #}
    <div class="glass-card p-4 mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label small fw-bold text-muted">Rechercher un type</label>
                <input type="text" name="search" class="form-control border-0 bg-light-subtle shadow-sm" 
                       placeholder="Nom, description..." value="{{ current_search }}">
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-success btn-premium">
                    <i class="fas fa-search me-2"></i>Rechercher
                </button>
            </div>
        </form>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for type_contrat in type_contrats %}
            <div class="col">
                <div class="glass-card h-100 p-4 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-success-subtle p-3 rounded-3 text-success">
                            <i class="fas fa-file-contract fa-2x"></i>
                        </div>
                        <span class="badge bg-light text-muted">#{{ type_contrat.id }}</span>
                    </div>
                    <h3 class="h4 fw-bold text-dark mb-2">{{ type_contrat.name }}</h3>
                    <p class="text-secondary flex-grow-1">
                        {{ type_contrat.description|default('Aucune description fournie.') }}
                    </p>
                    <hr class="opacity-10 my-3">
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ path('app_type_contrat_edit', {'id': type_contrat.id}) }}" class="btn btn-outline-warning btn-sm btn-premium border-0 bg-warning-subtle text-warning-emphasis">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        {{ include('type_contrat/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 w-100">
                <div class="glass-card p-5 text-center">
                    <i class="fas fa-search fa-3x text-muted mb-3 opacity-25"></i>
                    <p class="lead text-muted">Aucun type de contrat trouvé.</p>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="mt-5 mb-5">
        <a href="{{ path('app_contract_index') }}" class="btn btn-outline-secondary btn-premium">
            <i class="fas fa-arrow-left me-2"></i>Retour aux Contrats
        </a>
    </div>
</div>
{% endblock %}
