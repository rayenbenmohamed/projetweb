{% extends 'layout/admin.html.twig' %}

{% block title %}Modifier le type {{ type.name }} | SyfonuRH{% endblock %}
{% block page_title %}Modifier le type de contrat{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
  <div class="col-12">
    <div class="card card-lg">
      <div class="card-body p-6">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-5">
          <h5 class="mb-0">Type : {{ type.name }}</h5>
          <div class="d-flex gap-2">
            <form method="post" action="{{ path('app_type_contrat_delete', {id: type.id}) }}"
                  onsubmit="return confirm('Confirmer la suppression ?');">
              <input type="hidden" name="_token" value="{{ csrf_token('delete_type_contrat_' ~ type.id) }}">
              <button class="btn btn-outline-danger btn-sm">
                <i class="ti ti-trash me-1"></i> Supprimer
              </button>
            </form>
            <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_type_contrat_index') }}">Retour</a>
          </div>
        </div>
        {% include 'type_contrat/_form.html.twig' with { type: type, is_edit: true } %}
      </div>
    </div>
  </div>
</div>
{% endblock %}

