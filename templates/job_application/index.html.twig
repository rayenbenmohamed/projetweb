{% extends 'layout/admin.html.twig' %}

{% block title %}Pipeline RH | SyfonuRH{% endblock %}
{% block page_title %}Gestion des candidatures{% endblock %}

{% block content %}

{% set statusMap = {
    'PENDING':             {label: 'Nouveau',        color: 'secondary', icon: 'ti-clock'},
    'HR_SCREENING':        {label: 'Tri RH',          color: 'info',      icon: 'ti-shield-check'},
    'INTERVIEW_SCHEDULED': {label: 'Entretien',        color: 'warning',   icon: 'ti-calendar'},
    'TECHNICAL_TEST':      {label: 'Test Technique',   color: 'purple',    icon: 'ti-code'},
    'FINAL_REVIEW':        {label: 'Revue Finale',     color: 'indigo',    icon: 'ti-clipboard-check'},
    'READY_FOR_CONTRACT':  {label: 'Prêt Contrat',      color: 'indigo',    icon: 'ti-file-text'},
    'ACCEPTED':            {label: 'Accepté ✓',        color: 'success',   icon: 'ti-circle-check'},
    'REJECTED':            {label: 'Refusé',           color: 'danger',    icon: 'ti-circle-x'},
} %}

<style>
    /* ── Layout ── */
    .section-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
    }
    .premium-card { border-radius: 16px; border: none; box-shadow: 0 4px 24px rgba(0,0,0,0.07); overflow: hidden; }

    /* ── Candidate Row ── */
    .candidate-row { transition: background 0.2s ease; border-left: 3px solid transparent; }
    .candidate-row:hover { background: #f8faff !important; border-left-color: #6366f1; }
    .candidate-row.top-candidate { border-left-color: #f59e0b; background: #fffbeb10; }
    .candidate-avatar {
        width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.9rem; color: white;
        box-shadow: 0 4px 12px rgba(99,102,241,0.35);
    }

    /* ── Smart Badges ── */
    .badge-top-match {
        background: linear-gradient(135deg, #f59e0b, #ea580c);
        color: white; font-weight: 800; text-transform: uppercase;
        letter-spacing: 0.8px; padding: 4px 12px; border-radius: 8px;
        font-size: 0.65rem; display: inline-flex; align-items: center;
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.25);
    }
    .badge-ai-fav {
        background: linear-gradient(135deg, #8b5cf6, #ec4899);
        color: white; font-weight: 800; text-transform: uppercase;
        letter-spacing: 0.8px; padding: 4px 12px; border-radius: 8px;
        font-size: 0.65rem; display: inline-flex; align-items: center;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);
    }
    .pulse-rank-1 { animation: pulse-rank 2s infinite; }
    @keyframes pulse-rank {
        0%   { transform: scale(1); box-shadow: 0 0 0 0 rgba(234, 88, 12, 0.6); }
        70%  { transform: scale(1.02); box-shadow: 0 0 0 10px rgba(234, 88, 12, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(234, 88, 12, 0); }
    }

    /* ── Pipeline Steps ── */
    .pipeline-stepper { position: relative; display: flex; justify-content: space-between; gap: 4px; }
    .pipeline-stepper::before {
        content: ''; position: absolute; left: 10px; right: 10px; top: 50%; height: 3px;
        background: #e2e8f0; transform: translateY(-50%); z-index: 0;
    }
    .step-circle {
        width: 32px; height: 32px; border-radius: 50%; background: #fff;
        border: 2px solid #e2e8f0; display: flex; align-items: center;
        justify-content: center; color: #cbd5e1; font-size: 13px;
        z-index: 1; position: relative; transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .step-item.past .step-circle  { background: #22c55e; border-color: #22c55e; color: white; }
    .step-item.active .step-circle { background: #fff; border-color: #6366f1; color: #6366f1; transform: scale(1.2); box-shadow: 0 0 0 5px rgba(99,102,241,0.15); border-width: 3px; }
    .step-item.rejected .step-circle { border-color: #ef4444; color: #ef4444; background: #fee2e2; }

    /* ── Score Badge ── */
    .score-badge {
        width: 58px; height: 58px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 0.95rem; cursor: pointer;
        transition: all .2s ease;
    }
    .score-high   { background: #dcfce7; color: #166534; border: 4px solid #f0fdf4; box-shadow: 0 0 0 1px #22c55e; }
    .score-medium { background: #fffbeb; color: #b45309; border: 4px solid #fffdf2; box-shadow: 0 0 0 1px #f59e0b; }
    .score-low    { background: #fee2e2; color: #991b1b; border: 4px solid #fff5f5; box-shadow: 0 0 0 1px #ef4444; }
    .score-badge:hover { transform: scale(1.1) rotate(5deg); }

    /* ── Offer Group Row ── */
    .offer-group-row { background: #f8faff !important; }
    .offer-group-row td { padding: 10px 16px !important; }

    /* ── My Applications ── */
    .sent-section-header {
        background: linear-gradient(135deg, #064e3b, #065f46);
        color: white; border-radius: 16px 16px 0 0; padding: 1.25rem 1.5rem;
    }
    .status-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 50px; font-size: 0.75rem;
        font-weight: 600;
    }

    /* ── Filter Bar ── */
    .filter-bar .form-control, .filter-bar .form-select {
        border-radius: 10px; border-color: rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.1); color: white; font-size: 0.85rem;
    }
    .filter-bar .form-control::placeholder { color: rgba(255,255,255,0.6); }
    .filter-bar .input-group-text { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.8); }
</style>

{# --- SECTION 1 — Pipeline Recruteur --- #}
<div class="card premium-card mb-5">
    <div class="section-header d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h5 class="mb-0 fw-bold"><i class="ti ti-users me-2"></i>Pipeline des Candidatures Reçues</h5>
            <p class="mb-0 small" style="opacity:.7;">Triées automatiquement par Score IA — Smart Ranking actif</p>
        </div>
        <form method="get" action="{{ path('app_job_application_index') }}" class="d-flex gap-2 filter-bar">
            <div class="input-group input-group-sm" style="width:220px;">
                <span class="input-group-text"><i class="ti ti-search"></i></span>
                <input type="text" class="form-control" name="recv_offer" value="{{ recvOffer|default('') }}" placeholder="Filtrer par offre...">
            </div>
            <select class="form-select form-select-sm" name="recv_status" onchange="this.form.submit()" style="width:160px;">
                <option value="">Tous les statuts</option>
                {% for key, s in statusMap %}
                    <option value="{{ key }}" {% if recvStatus|default('') == key %}selected{% endif %}>{{ s.label }}</option>
                {% endfor %}
            </select>
        </form>
    </div>

    {% if applications_by_offer is not empty %}
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr style="background:#f8faff;">
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Candidat</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Pipeline</th>
                    <th class="py-3 text-center text-uppercase small fw-bold text-muted">Score IA</th>
                    <th class="py-3 text-center text-uppercase small fw-bold text-muted">Dernière action</th>
                    <th class="py-3 pe-4 text-end text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for offerTitle, apps in applications_by_offer %}
                <tr class="offer-group-row">
                    <td colspan="5">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-2">
                                <span style="width:10px;height:10px;background:#6366f1;border-radius:50%;display:inline-block;"></span>
                                <span class="fw-bold text-dark fs-6">{{ offerTitle }}</span>
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill ms-1">{{ apps|length }}</span>
                            </div>
                        </div>
                    </td>
                </tr>

                {% for job_app in apps %}
                {% set isTop = (loop.index <= 3 and job_app.aiScore is not null and job_app.aiScore >= 70) %}
                <tr class="candidate-row {{ isTop ? 'top-candidate' : '' }}">
                    <td class="ps-4 py-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="candidate-avatar">{{ job_app.candidat.firstName|first|upper }}{{ job_app.candidat.lastName|first|upper }}</div>
                            <div>
                                <div class="fw-bold text-dark">
                                    {{ job_app.candidat.firstName }} {{ job_app.candidat.lastName }}
                                    {% if isTop %}
                                        <span class="badge-top-match ms-1"><i class="ti ti-sparkles me-1"></i>TOP</span>
                                    {% endif %}
                                </div>
                                <div class="text-muted small">{{ job_app.candidat.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-3">
                        {% set stages = ['PENDING', 'HR_SCREENING', 'INTERVIEW_SCHEDULED', 'TECHNICAL_TEST', 'FINAL_REVIEW', 'READY_FOR_CONTRACT', 'ACCEPTED'] %}
                        {% set current_found = false %}
                        <div class="pipeline-stepper mb-2">
                            {% for key in stages %}
                                {% set is_active = (job_app.status == key) %}
                                {% set is_past   = (not is_active and not current_found and job_app.status != 'REJECTED') %}
                                {% if is_active %}{% set current_found = true %}{% endif %}
                                <div class="step-item {{ is_active ? 'active' : '' }} {{ is_past ? 'past' : '' }} {{ job_app.status == 'REJECTED' ? 'rejected' : '' }}">
                                    <div class="step-circle"><i class="ti {{ statusMap[key].icon|default('ti-circle') }}"></i></div>
                                </div>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="text-center py-3">
                        {% if job_app.aiScore is not null %}
                            {% set scoreClass = job_app.aiScore >= 70 ? 'score-high' : (job_app.aiScore >= 40 ? 'score-medium' : 'score-low') %}
                            <span class="score-badge {{ scoreClass }}" data-bs-toggle="modal" data-bs-target="#aiModal{{ job_app.id }}">
                                {{ job_app.aiScore }}%
                            </span>
                        {% else %}
                            <form method="post" action="{{ path('app_job_application_analyze', {id: job_app.id}) }}">
                                <button type="submit" class="btn btn-sm rounded-pill btn-light border">
                                    <i class="ti ti-brain me-1"></i>Analyser
                                </button>
                            </form>
                        {% endif %}
                    </td>
                    <td class="text-center py-3">
                        <div class="small fw-bold">{{ job_app.applyDate|date('d/m/Y') }}</div>
                    </td>
                    <td class="text-end pe-4">
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm" type="button" data-bs-toggle="dropdown"><i class="ti ti-dots-vertical"></i></button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a href="{{ path('app_job_application_show', {id: job_app.id}) }}" class="dropdown-item"><i class="ti ti-eye me-2"></i>Détails</a></li>
                                <li><hr class="dropdown-divider"></li>
                                {% for key, s in statusMap %}
                                    {% if key != job_app.status %}
                                    <li>
                                        <form action="{{ path('app_job_application_status', {id: job_app.id}) }}" method="post">
                                            <input type="hidden" name="status" value="{{ key }}">
                                            <button class="dropdown-item"><i class="ti {{ s.icon }} me-2"></i>{{ s.label }}</button>
                                        </form>
                                    </li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </div>
                    </td>
                </tr>
                {% endfor %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="text-center py-5"><p class="text-muted">Aucune candidature reçue.</p></div>
    {% endif %}
</div>

{# --- SECTION 2 — Mes candidatures envoyées --- #}
{% if my_applications is not empty %}
<div class="card premium-card">
    <div class="sent-section-header">
        <h5 class="mb-0 fw-bold"><i class="ti ti-send me-2"></i>Mes Candidatures Envoyées</h5>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Offre</th>
                    <th>Date</th>
                    <th class="text-center">Statut</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for job_app in my_applications %}
                {% set s = statusMap[job_app.status] ?? {label: job_app.status, color:'secondary', icon:'ti-info-circle'} %}
                <tr>
                    <td class="ps-4">
                        <div class="fw-bold">{{ job_app.jobOffre.title }}</div>
                        <div class="small text-muted">{{ job_app.jobOffre.location }}</div>
                    </td>
                    <td>{{ job_app.applyDate|date('d/m/Y') }}</td>
                    <td class="text-center">
                        <span class="status-pill bg-{{ s.color }}-subtle text-{{ s.color }}-emphasis">
                            <i class="ti {{ s.icon }}"></i> {{ s.label }}
                        </span>
                    </td>
                    <td class="text-end pe-4">
                        <a href="{{ path('app_job_application_show', {id: job_app.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill">Voir</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if applications_by_offer is not empty %}
{% for offerTitle, apps in applications_by_offer %}
{% for job_app in apps %}
{% if job_app.aiAnalysis %}
{% set analysis = job_app.aiAnalysis|json_decode %}
<div class="modal fade" id="aiModal{{ job_app.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title"><i class="ti ti-sparkles me-2"></i>Analyse IA : {{ job_app.candidat.firstName }}</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">{{ analysis.score }}%</h2>
                    <p class="text-muted small">Score de compatibilité</p>
                </div>
                <div class="mb-3">
                    <h6 class="fw-bold small">Résumé</h6>
                    <p class="small text-muted">{{ analysis.summary|default('N/A') }}</p>
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="p-2 bg-success-subtle rounded small">
                            <div class="fw-bold text-success">Points Forts</div>
                            {% for p in analysis.verdict.pros|default([]) %}<div>• {{ p }}</div>{% endfor %}
                            {% for p in analysis.pros|default([]) %}<div>• {{ p }}</div>{% endfor %}
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-danger-subtle rounded small">
                            <div class="fw-bold text-danger">Vigilance</div>
                            {% for c in analysis.verdict.cons|default([]) %}<div>• {{ c }}</div>{% endfor %}
                            {% for c in analysis.cons|default([]) %}<div>• {{ c }}</div>{% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}

{% endblock %}
