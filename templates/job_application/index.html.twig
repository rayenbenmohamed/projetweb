{% extends 'layout/front.html.twig' %}

{% block title %}Candidatures | SyfonuRH{% endblock %}
{% block page_title %}Gestion des candidatures{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
    <div class="col-12">
        <div class="card h-100">
            <div class="card-header border-bottom-0">
                <h5 class="mb-0">Toutes les candidatures</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>Candidat</th>
                            <th>Offre</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for app in job_applications %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar avatar-sm rounded-circle bg-secondary-subtle">
                                        <i class="ti ti-user fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">{{ app.candidat.firstName }} {{ app.candidat.lastName }}</h6>
                                        <span class="small text-secondary">{{ app.candidat.email }}</span>
                                    </div>
                                </div>
                            </td>
                            <td>{{ app.jobOffre.title }}</td>
                            <td>{{ app.applyDate|date('d/m/Y') }}</td>
                            <td>
                                <span class="badge bg-{{ app.status == 'ACCEPTED' ? 'success' : (app.status == 'REJECTED' ? 'danger' : 'info') }}-subtle text-{{ app.status == 'ACCEPTED' ? 'success' : (app.status == 'REJECTED' ? 'danger' : 'info') }}-emphasis px-2 py-1">
                                    {{ app.status }}
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <a href="{{ path('app_job_application_show', {id: app.id}) }}" class="btn btn-ghost btn-icon btn-sm rounded-circle text-primary" title="Voir détails">
                                        <i class="ti ti-eye fs-4"></i>
                                    </a>
                                    <a href="{{ path('app_job_application_edit', {id: app.id}) }}" class="btn btn-ghost btn-icon btn-sm rounded-circle text-warning" title="Modifier">
                                        <i class="ti ti-pencil fs-4"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_job_application_delete', {id: app.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ app.id) }}">
                                        <button type="submit" class="btn btn-ghost btn-icon btn-sm rounded-circle text-danger" title="Supprimer">
                                            <i class="ti ti-trash fs-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-8">
                                <p class="text-secondary mb-0">Aucune candidature pour le moment.</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
