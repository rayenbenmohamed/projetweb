{% extends 'layout/front.html.twig' %}

{% block title %}Postuler | SyfonuRH{% endblock %}
{% block page_title %}Candidater à l'offre{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-6">
        <div class="card card-lg overflow-hidden">
            <div class="bg-primary p-6 py-8">
                <h4 class="text-white mb-2">{{ job_offre.title }}</h4>
                <div class="d-flex gap-4 text-white-50 small">
                    <span><i class="ti ti-map-pin me-1"></i>{{ job_offre.location }}</span>
                    <span><i class="ti ti-calendar me-1"></i>Publiée le {{ job_offre.createdAt|date('d/m/Y') }}</span>
                </div>
            </div>
            <div class="card-body p-6">
                <form method="post">
                    <div class="mb-4">
                        <label class="form-label">Lettre de motivation</label>
                        <textarea name="cover_letter" class="form-control" rows="6" placeholder="Expliquez pourquoi vous êtes le candidat idéal..."></textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label">Lien vers votre CV (ou chemin de fichier)</label>
                        <input type="text" name="cv_path" class="form-control" placeholder="C:\Users\...\CV.pdf">
                        <div class="form-text small opacity-75 mt-2">Simulation d'upload pour le squelette.</div>
                    </div>

                    <div class="d-grid mt-6">
                        <button type="submit" class="btn btn-primary">Envoyer ma candidature</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_job_offre_index') }}" class="small text-secondary">Retour aux offres</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
