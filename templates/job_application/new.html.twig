{% extends 'layout/admin.html.twig' %}

{% block title %}Postuler | SyfonuRH{% endblock %}
{% block page_title %}Candidater à l'offre{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-6">
        <div class="card card-lg overflow-hidden">
            <div class="bg-primary p-6 py-8">
                <h4 class="text-white mb-2">{{ job_offre.title }}</h4>
                <div class="d-flex gap-4 text-white-50 small">
                    <span><i class="ti ti-map-pin me-1"></i>{{ job_offre.location }}</span>
                    <span><i class="ti ti-calendar me-1"></i>Publiée le {{ job_offre.createdAt|date('d/m/Y') }}</span>
                </div>
            </div>
            <div class="card-body p-6">
                <form method="post" enctype="multipart/form-data" id="jobAppForm" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label class="form-label">Lettre de motivation <span class="text-danger">*</span></label>
                        <textarea name="cover_letter" class="form-control" rows="6" placeholder="Expliquez pourquoi vous êtes le candidat idéal... (Min: 400 caractères)" minlength="400" required></textarea>
                        <div class="invalid-feedback">La lettre de motivation est importante. Elle doit contenir au moins 400 caractères.</div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label">Votre CV (PDF, Image) <span class="text-danger">*</span></label>
                        <input type="file" name="cv_file" class="form-control" accept=".pdf,.doc,.docx,image/*" required>
                        <div class="form-text small opacity-75 mt-2">Le fichier sera hébergé sur Cloudinary.</div>
                    </div>

                    <div class="d-grid mt-6">
                        <button type="submit" class="btn btn-primary">Envoyer ma candidature</button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_job_offre_index') }}" class="small text-secondary">Retour aux offres</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById('jobAppForm');
    form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
});
</script>
{% endblock %}
