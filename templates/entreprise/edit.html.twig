{% extends 'layout/admin.html.twig' %}

{% block title %}Modifier l'entreprise | SyfonuRH{% endblock %}
{% block page_title %}Modifier mon entreprise{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.logo-ring-wrapper { position:relative; width:140px; height:140px; }
.logo-ring-inner {
    width:140px; height:140px; border-radius:18px;
    background:linear-gradient(135deg,#eef0ff,#dde1ff);
    border:3px solid #c7cbf5;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden; transition:all .25s;
    box-shadow:0 4px 20px rgba(92,103,245,.12);
}
.logo-ring-inner img { width:100%; height:100%; object-fit:cover; }
.logo-ring-overlay {
    position:absolute; inset:0; border-radius:18px;
    background:rgba(92,103,245,.78); backdrop-filter:blur(3px);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    color:#fff; opacity:0; transition:opacity .22s;
}
.logo-ring-wrapper:hover .logo-ring-inner { border-color:#5c67f5; transform: translateY(-3px); }
.logo-ring-wrapper:hover .logo-ring-overlay { opacity:1; }
</style>
{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-7">
        <div class="card card-lg overflow-hidden border-0 shadow-sm">
            <div class="card-body p-6">
                <form method="post" enctype="multipart/form-data" novalidate>
                    
                    <div class="logo-upload-section mb-6 text-center">
                        <div class="d-flex flex-column align-items-center" style="cursor:pointer;" onclick="document.getElementById('logoInput').click()">
                            <div class="logo-ring-wrapper">
                                <div id="logoPreview" class="logo-ring-inner">
                                    {% if entreprise.logo %}
                                        <img src="{{ entreprise.logo }}" alt="{{ entreprise.name }}">
                                    {% else %}
                                        <i class="ti ti-building-factory-2" style="font-size:3.5rem;color:#5c67f5;"></i>
                                    {% endif %}
                                </div>
                                <div class="logo-ring-overlay">
                                    <i class="ti ti-camera fs-3"></i>
                                    <span class="small fw-bold mt-1">Changer</span>
                                </div>
                            </div>
                            <div class="mt-4">
                                <h5 class="fw-bold mb-1">{{ entreprise.name }}</h5>
                                <p class="text-secondary small mb-0">Modifier le logo • Max 2Mo</p>
                            </div>
                            <input type="file" id="logoInput" name="logo" accept="image/*" class="d-none" onchange="previewLogo(this)">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-600">Nom de l'entreprise <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control {% if errors.name is defined %}is-invalid{% endif %}" 
                               value="{{ entreprise.name }}">
                        {% if errors.name is defined %}
                            <div class="invalid-feedback">{{ errors.name }}</div>
                        {% endif %}
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-600">Site Web</label>
                            <input type="url" name="website" class="form-control {% if errors.website is defined %}is-invalid{% endif %}" 
                                   value="{{ entreprise.website }}">
                            {% if errors.website is defined %}
                                <div class="invalid-feedback">{{ errors.website }}</div>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Adresse / Siège</label>
                            <input type="text" name="address" class="form-control" value="{{ entreprise.address }}">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-600">Présentation</label>
                        <textarea name="description" class="form-control" rows="5">{{ entreprise.description }}</textarea>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a href="{{ path('app_entreprise_my') }}" class="text-secondary small fw-bold">Annuler</a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">
                            Enregistrer les modifications <i class="ti ti-check ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function previewLogo(input) {
    const preview = document.getElementById('logoPreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.innerHTML = '<img src="' + e.target.result + '" alt="Aperçu">';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
{% endblock %}
