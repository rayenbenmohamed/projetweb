{% extends 'layout/admin.html.twig' %}

{% block title %}Profil Entreprise | SyfonuRH{% endblock %}
{% block page_title %}Mon Entreprise{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm overflow-hidden mb-4">
            <div class="card-body p-0">
                <div class="p-6 bg-primary bg-opacity-10 d-sm-flex align-items-center gap-5">
                    <div class="flex-shrink-0">
                        {% if entreprise.logo %}
                            <img src="{{ entreprise.logo }}" alt="{{ entreprise.name }}" 
                                 class="rounded-4 border bg-white p-1" style="width:120px;height:120px;object-fit:cover;box-shadow:0 8px 30px rgba(0,0,0,0.05);">
                        {% else %}
                            <div class="icon-shape icon-xxl rounded-4 bg-white border text-primary shadow-sm" style="width:120px;height:120px;">
                                <i class="ti ti-building fs-1"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div class="mt-4 mt-sm-0 flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h2 class="fw-bold mb-0" style="color:#1e2343;">{{ entreprise.name }}</h2>
                                {% if entreprise.slogan %}
                                    <p class="text-primary fw-600 small mb-2">{{ entreprise.slogan }}</p>
                                {% endif %}
                                <div class="d-flex flex-wrap gap-4 text-secondary small mt-1">
                                    {% if entreprise.website %}
                                        <span><i class="ti ti-world me-1"></i><a href="{{ entreprise.website }}" target="_blank" class="text-secondary">{{ entreprise.website|replace({'https://': '', 'http://': ''}) }}</a></span>
                                    {% endif %}
                                    {% if entreprise.address %}
                                        <span><i class="ti ti-map-pin me-1"></i>{{ entreprise.address }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_entreprise_edit') }}" class="btn btn-white btn-sm border shadow-sm">
                                    <i class="ti ti-edit me-1"></i>Modifier
                                </a>
                                <form method="post" action="{{ path('app_entreprise_delete') }}" style="display:inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_entreprise') }}">
                                    <button type="submit" class="btn btn-danger btn-sm shadow-sm">
                                        <i class="ti ti-trash me-1"></i>Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="row g-6">
                        <div class="col-md-7">
                            <h5 class="fw-bold mb-3"><i class="ti ti-info-circle me-2 text-primary"></i>À propos</h5>
                            <div class="text-secondary lh-lg mb-0">
                                {{ entreprise.description ? entreprise.description|nl2br : "Aucune description fournie." }}
                            </div>
                        </div>
                        <div class="col-md-5">
                            <h5 class="fw-bold mb-3"><i class="ti ti-list-details me-2 text-primary"></i>Informations</h5>
                            <div class="card bg-light border-0 rounded-4 p-4">
                                <div class="d-flex flex-column gap-3">
                                    {% if entreprise.sector %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-category text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">Secteur</p><p class="small fw-bold mb-0 text-dark">{{ entreprise.sector }}</p></div>
                                        </div>
                                    {% endif %}
                                    {% if entreprise.size %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-users text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">Taille</p><p class="small fw-bold mb-0 text-dark">{{ entreprise.size }}</p></div>
                                        </div>
                                    {% endif %}
                                    {% if entreprise.foundedAt %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-calendar-event text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">Création</p><p class="small fw-bold mb-0 text-dark">{{ entreprise.foundedAt }}</p></div>
                                        </div>
                                    {% endif %}
                                    {% if entreprise.phone %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-phone text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">Téléphone</p><p class="small fw-bold mb-0 text-dark">{{ entreprise.phone }}</p></div>
                                        </div>
                                    {% endif %}
                                    {% if entreprise.contactEmail %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-mail text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">Email</p><p class="small fw-bold mb-0 text-dark"><a href="mailto:{{ entreprise.contactEmail }}" class="text-dark">{{ entreprise.contactEmail }}</a></p></div>
                                        </div>
                                    {% endif %}
                                    {% if entreprise.socialLinkedin %}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="icon-shape icon-sm bg-white rounded-circle shadow-sm"><i class="ti ti-brand-linkedin text-primary"></i></div>
                                            <div><p class="small text-secondary mb-0">LinkedIn</p><p class="small fw-bold mb-0 text-dark"><a href="{{ entreprise.socialLinkedin }}" target="_blank" class="text-dark">Profil Entreprise</a></p></div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center p-4">
                <h5 class="card-title mb-0 fw-bold"><i class="ti ti-briefcase me-2 text-success"></i>Offres d'emploi ({{ entreprise.jobOffres|length }})</h5>
                <a href="{{ path('app_job_offre_new') }}" class="btn btn-primary btn-sm">
                    <i class="ti ti-plus me-1"></i>Nouvelle offre
                </a>
            </div>
            <div class="card-body p-0">
                {% if entreprise.jobOffres|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light-subtle small text-uppercase fw-bold text-secondary">
                            <tr>
                                <th class="px-4 py-3">Titre</th>
                                <th class="py-3 text-center">Type</th>
                                <th class="py-3 text-center">Date</th>
                                <th class="py-3 text-center">Candidatures</th>
                                <th class="px-4 py-3 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for job in entreprise.jobOffres %}
                            <tr>
                                <td class="px-4">
                                    <div class="fw-bold text-dark">{{ job.title }}</div>
                                    <div class="small text-secondary">{{ job.location }}</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">{{ job.employmentType }}</span>
                                </td>
                                <td class="text-center small text-secondary">
                                    {{ job.createdAt|date('d/m/Y') }}
                                </td>
                                <td class="text-center">
                                    <div class="badge bg-info-subtle text-info fw-bold">{{ job.jobApplications|length }}</div>
                                </td>
                                <td class="px-4 text-end">
                                    <a href="{{ path('app_job_offre_show', {id: job.id}) }}" class="btn btn-icon btn-light btn-sm rounded-circle">
                                        <i class="ti ti-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="p-6 text-center text-secondary opacity-75">
                    <i class="ti ti-ghost fs-1 d-block mb-2"></i>
                    <p>Aucune offre publiée pour le moment.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
