{% extends 'layout/admin.html.twig' %}

{% block title %}Modifier {{ user.email }} | Admin{% endblock %}
{% block page_title %}Modifier l'utilisateur{% endblock %}

{% block content %}
<div class="row justify-content-center mt-2">
    <div class="col-lg-8">
        <div class="card card-lg">
            <div class="card-body p-6">
                {% if 'ROLE_ADMIN' not in user.roles %}
                    {% if user.blocked %}
                        <div class="alert alert-warning border mb-4">Ce compte est <strong>bloqué</strong> : l’utilisateur ne peut pas se connecter. Utilisez « Bloquer / Déverrouiller » dans la liste des utilisateurs pour le réactiver.</div>
                    {% endif %}
                {% endif %}
                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_edit' ~ user.id) }}">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Prénom</label>
                            <input type="text" name="firstName" class="form-control" value="{{ user.firstName|default('') }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nom</label>
                            <input type="text" name="lastName" class="form-control" value="{{ user.lastName|default('') }}">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">E-mail <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control" required value="{{ user.email }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Téléphone</label>
                        <input type="text" name="phone" class="form-control" value="{{ user.phone|default('') }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rôle</label>
                        <select name="role" class="form-select" id="adminUserRole">
                            {% for value, label in role_choices %}
                                <option value="{{ value }}" {{ current_role == value ? 'selected' }}>{{ label }} ({{ value }})</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3 border-top pt-3" id="adminEditRecruiterFields">
                        <h6 class="text-secondary small">Données recruteur (si rôle recruteur)</h6>
                        <div class="mb-2">
                            <label class="form-label">Entreprise</label>
                            <input type="text" name="companyname" class="form-control" value="{{ companyname|default('') }}">
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Département</label>
                            <input type="text" name="departement" class="form-control" value="{{ departement|default('') }}">
                        </div>
                        <div class="mb-2">
                            <label class="form-label">RNE / SIREN / SIRET</label>
                            <input type="text" name="companyRne" class="form-control" maxlength="32" value="{{ company_rne|default('') }}">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Nouveau mot de passe</label>
                        <input type="password" name="password" class="form-control" autocomplete="new-password" placeholder="Laisser vide pour ne pas changer">
                        <div class="form-text">Minimum 4 caractères si vous changez le mot de passe.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                        <a href="{{ path('admin_users_index') }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
(function () {
    var role = document.getElementById('adminUserRole');
    var extra = document.getElementById('adminEditRecruiterFields');
    function toggle() {
        extra.style.display = role.value === 'ROLE_RECRUTEUR' ? 'block' : 'none';
    }
    role.addEventListener('change', toggle);
    toggle();
})();
</script>
{% endblock %}
