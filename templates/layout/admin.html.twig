{% extends 'base.html.twig' %}

{% block body %}
{% set sn = social_notifications() %}
<div id="miniSidebar">
    <div class="brand-logo">
        <a class="d-none d-md-flex align-items-center gap-2" href="{{ path('admin_dashboard') }}">
            <img src="{{ asset('dasher/images/brand/logo/logo-icon.svg') }}" alt="Logo"/>
            <span class="fw-bold fs-4 site-logo-text">SyfonuRH</span>
        </a>
    </div>
    <ul class="navbar-nav flex-column">

        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_home') }}">
                <span class="nav-icon"><i class="ti ti-world"></i></span>
                <span class="text">Site public</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_friends' or app.request.attributes.get('_route') starts with 'app_chat' ? 'active' }}"
               href="{{ path('app_friends_index') }}">
                <span class="nav-icon"><i class="ti ti-users-group"></i></span>
                <span class="text">Amis &amp; messages</span>
                <span class="badge bg-danger rounded-pill ms-1 {{ sn.total > 0 ? '' : 'd-none' }}" data-sidebar-social-total>{{ sn.total > 99 ? '99+' : sn.total }}</span>
            </a>
        </li>
        {# --- Tableau de bord --- #}
        <li class="nav-item">
            <a class="nav-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' }}"
               href="{{ path('admin_dashboard') }}">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-layout-dashboard">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M4 4h6v8h-6z"/><path d="M4 16h6v4h-6z"/>
                        <path d="M14 12h6v8h-6z"/><path d="M14 4h6v4h-6z"/>
                    </svg>
                </span>
                <span class="text">Tableau de bord</span>
            </a>
        </li>

        {# --- Section RH --- #}
        <li class="nav-item">
            <div class="nav-heading">Gestion RH</div>
            <hr class="mx-5 nav-line mb-1"/>
        </li>

        <li class="nav-item">
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_users' ? 'active' }}"
               href="{{ path('admin_users_index') }}">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-users">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M9 7m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                        <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        <path d="M21 21v-2a4 4 0 0 0 -3 -3.85"/>
                    </svg>
                </span>
                <span class="text">Utilisateurs</span>
            </a>
        </li>

        {# Contrats #}
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-file-description">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                        <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
                        <path d="M9 17h6"/><path d="M9 13h6"/>
                    </svg>
                </span>
                <span class="text">Contrats</span>
            </a>
            <ul class="dropdown-menu flex-column">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_contract_index') }}">Liste des contrats</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_type_contrat_index') }}">Type de contrats</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_contract_new') }}">Nouveau contrat</a></li>
            </ul>
        </li>

        {# Offres d'emploi #}
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-briefcase">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z"/>
                        <path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"/>
                        <path d="M12 12l0 .01"/><path d="M3 13a20 20 0 0 0 18 0"/>
                    </svg>
                </span>
                <span class="text">Recrutement</span>
            </a>
            <ul class="dropdown-menu flex-column">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_entreprise_my') }}">Ma Société</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_job_offre_index') }}">Toutes les offres</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_job_offre_my') }}">Mes offres</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_job_offre_new') }}">Nouvelle offre</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_job_application_index') }}">Candidatures reçues</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_interview_index') }}">Mes Entretiens</a></li>
            </ul>
        </li>

        {# Forum #}
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-message-2">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M8 9h8"/><path d="M8 13h6"/>
                        <path d="M9 18h-3a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-3l-3 3l-3 -3z"/>
                    </svg>
                </span>
                <span class="text">Forum</span>
            </a>
            <ul class="dropdown-menu flex-column">
                <li class="nav-item"><a class="nav-link" href="#">Posts</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Catégories</a></li>
            </ul>
        </li>

        {# CV #}
        <li class="nav-item">
            <a class="nav-link" href="#">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-id-badge">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M5 4m0 2a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2z"/>
                        <path d="M9 4v4"/><path d="M15 4v4"/>
                        <path d="M9 12l.01 0"/><path d="M13 12l2 0"/>
                        <path d="M9 16l.01 0"/><path d="M13 16l2 0"/>
                    </svg>
                </span>
                <span class="text">CV</span>
            </a>
        </li>

        {# --- Profil / Authentification --- #}
        <li class="nav-item">
            <div class="nav-heading">Compte</div>
            <hr class="mx-5 nav-line mb-1"/>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_profile') }}">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-user-circle">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/>
                        <path d="M12 10m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"/>
                        <path d="M6.168 18.849a4 4 0 0 1 3.832 -2.849h4a4 4 0 0 1 3.834 2.855"/>
                    </svg>
                </span>
                <span class="text">Mon profil</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                         class="icon icon-tabler icon-tabler-logout">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                        <path d="M9 12h12l-3 -3"/><path d="M18 15l3 -3"/>
                    </svg>
                </span>
                <span class="text">Déconnexion</span>
            </a>
        </li>

    </ul>
</div>

{# Main Content #}
<div id="content" class="position-relative h-100">
    {# Topbar #}
    <nav class="navbar navbar-expand-md bg-body-tertiary px-4 py-3 border-bottom">
        <button class="btn d-md-none me-2" id="sidebarToggle" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                 class="icon icon-tabler icon-tabler-menu-2">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M4 6l16 0"/><path d="M4 12l16 0"/><path d="M4 18l16 0"/>
            </svg>
        </button>
        <span class="navbar-brand fw-semibold">{% block page_title 'Tableau de bord' %}</span>
        <div class="ms-auto d-flex align-items-center gap-3">
            {% include '_social_notifications_nav.html.twig' with { sn: sn } only %}
            <span class="badge bg-primary-subtle text-primary-emphasis">SyfonuRH</span>
            <img src="{{ asset('dasher/images/avatar/avatar-1.jpg') }}" alt="Avatar" class="avatar avatar-sm rounded-circle"/>
        </div>
    </nav>

    {# Flash Messages #}
    <div class="custom-container mt-3">
        {% include '_flashes.html.twig' %}
    </div>

    {# Page Content #}
    <div class="custom-container">
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {% include '_social_notifications_script.html.twig' %}
{% endblock %}
