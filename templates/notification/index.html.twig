{% extends 'layout/front.html.twig' %}

{% block page_title %}Mes Notifications{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">
            <i class="ti ti-bell me-2 text-warning"></i>Mes Notifications
        </h1>
        <p class="text-muted small mb-0">Candidatures acceptées, entretiens planifiés...</p>
    </div>
    {% set unread = notifications|filter(n => not n.isRead())|length %}
    {% if unread > 0 %}
    <form method="POST" action="{{ path('app_notifications_read_all') }}">
        <button type="submit" class="btn btn-outline-secondary btn-sm">
            <i class="ti ti-checks me-1"></i>Tout marquer comme lu ({{ unread }})
        </button>
    </form>
    {% endif %}
</div>

{% if notifications is empty %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="ti ti-bell-off fs-1 text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Aucune notification</h5>
            <p class="text-muted small">Vous n'avez pas encore de notifications.</p>
            <a href="{{ path('app_job_application_index') }}" class="btn btn-primary btn-sm mt-2">
                Voir les candidatures
            </a>
        </div>
    </div>
{% else %}
    <div class="card border-0 shadow-sm">
        <ul class="list-group list-group-flush">
            {% for notification in notifications %}
            <li class="list-group-item d-flex align-items-start gap-3 py-3 {{ not notification.isRead() ? 'bg-warning bg-opacity-10' : '' }}">
                <div class="mt-1">
                    {% if 'entretien' in notification.message|lower %}
                        <span class="badge rounded-circle bg-info p-2"><i class="ti ti-calendar-event fs-6"></i></span>
                    {% elseif 'acceptée' in notification.message|lower %}
                        <span class="badge rounded-circle bg-success p-2"><i class="ti ti-check fs-6"></i></span>
                    {% elseif 'retenue' in notification.message|lower %}
                        <span class="badge rounded-circle bg-danger p-2"><i class="ti ti-x fs-6"></i></span>
                    {% else %}
                        <span class="badge rounded-circle bg-secondary p-2"><i class="ti ti-bell fs-6"></i></span>
                    {% endif %}
                </div>
                <div class="flex-grow-1">
                    <p class="mb-1 {{ not notification.isRead() ? 'fw-semibold' : 'text-muted' }}">
                        {{ notification.message }}
                    </p>
                    <small class="text-muted">
                        <i class="ti ti-clock me-1"></i>
                        {{ notification.createdAt|date('d/m/Y à H:i') }}
                    </small>
                </div>
                {% if not notification.isRead() %}
                <form method="POST" action="{{ path('app_notification_read', {id: notification.id}) }}" class="ms-2">
                    <button type="submit" class="btn btn-sm btn-outline-success" title="Marquer comme lu">
                        <i class="ti ti-check"></i>
                    </button>
                </form>
                {% else %}
                <span class="text-success ms-2" title="Lu"><i class="ti ti-circle-check fs-5"></i></span>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

<div class="mt-3">
    <a href="{{ path('app_job_application_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="ti ti-arrow-left me-1"></i> Retour aux candidatures
    </a>
</div>
{% endblock %}
