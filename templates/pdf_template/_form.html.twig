{{ form_start(form) }}
<div class="row g-6">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-6">
            <div class="card-header bg-white border-bottom-0 p-4">
                <h6 class="mb-0 fw-bold">Structure du Document</h6>
            </div>
            <div class="card-body p-4 pt-0">
                <div class="mb-4">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-control form-control-lg'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.headerHtml) }}
                    {{ form_widget(form.headerHtml, {'attr': {'class': 'form-control font-monospace', 'style': 'font-size: 0.85rem;'}}) }}
                    <div class="form-text">Placeholders: {{ '{{candidate_name}}, {{recruiter_name}}, {{today}}, {{contract_id}}' }}</div>
                </div>

                <div class="mb-4">
                    {{ form_label(form.bodyHtml) }}
                    {{ form_widget(form.bodyHtml, {'attr': {'class': 'form-control font-monospace', 'style': 'font-size: 0.85rem;'}}) }}
                    <div class="form-text">Ce bloc constitue le cœur du document.</div>
                </div>

                <div class="mb-0">
                    {{ form_label(form.footerHtml) }}
                    {{ form_widget(form.footerHtml, {'attr': {'class': 'form-control font-monospace', 'style': 'font-size: 0.85rem;'}}) }}
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-6">
            <div class="card-header bg-white border-bottom-0 p-4">
                <h6 class="mb-0 fw-bold">Style & Identité</h6>
            </div>
            <div class="card-body p-4 pt-0">
                <div class="mb-4">
                    {{ form_label(form.logoFile) }}
                    {{ form_widget(form.logoFile, {'attr': {'class': 'form-control'}}) }}
                    {% if pdf_template.logoPath %}
                        <div class="mt-2 text-center p-3 border rounded bg-light">
                            <img src="{{ pdf_template.logoPath }}" alt="Logo" style="max-height: 60px;">
                        </div>
                    {% endif %}
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        {{ form_label(form.primaryColor) }}
                        {{ form_widget(form.primaryColor, {'attr': {'class': 'form-control form-control-color w-100'}}) }}
                    </div>
                    <div class="col-6">
                        {{ form_label(form.secondaryColor) }}
                        {{ form_widget(form.secondaryColor, {'attr': {'class': 'form-control form-control-color w-100'}}) }}
                    </div>
                </div>

                <hr class="my-6">

                <div class="alert alert-info border-0 shadow-sm small mb-0">
                    <h6 class="alert-heading fw-bold small mb-2"><i class="ti ti-info-circle me-1"></i> Guide des variables</h6>
                    <ul class="ps-3 mb-0">
                        <li><code>{{ '{{candidate_name}}' }}</code> : Nom complet</li>
                        <li><code>{{ '{{salary}}' }}</code> : Salaire brut</li>
                        <li><code>{{ '{{start_date}}' }}</code> : Début contrat</li>
                        <li><code>{{ '{{job_title}}' }}</code> : Titre du poste</li>
                    </ul>
                </div>

                <hr class="my-6">

                {# --- AI ASSISTANT BLOCK --- #}
                <div class="card bg-primary-subtle border-0 shadow-sm overflow-hidden">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                            <i class="ti ti-sparkles fs-4"></i> Assistant IA Créatif
                        </h6>
                        <p class="small text-secondary mb-3">Décrivez le style ou le contenu que vous souhaitez générer (ex: "Contrat moderne bleu", "Style juridique classique").</p>
                        
                        <div class="mb-3">
                            <textarea id="ai-prompt" class="form-control form-control-sm" rows="3" placeholder="Tapez votre prompt ici..."></textarea>
                        </div>
                        
                        <button type="button" id="btn-generate-ai" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-2">
                             <i class="ti ti-wand"></i> Générer le style
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2">
            <button class="btn btn-primary btn-lg shadow-sm">
                <i class="ti ti-device-floppy me-2"></i> {{ button_label|default('Enregistrer le modèle') }}
            </button>
            <a href="{{ path('app_pdf_template_index') }}" class="btn btn-link link-secondary">Annuler</a>
        </div>
    </div>
</div>
{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const btnGenerate = document.getElementById('btn-generate-ai');
    const promptInput = document.getElementById('ai-prompt');
    const headerField = document.getElementById('pdf_template_headerHtml');
    const bodyField = document.getElementById('pdf_template_bodyHtml');
    const footerField = document.getElementById('pdf_template_footerHtml');

    if (btnGenerate) {
        btnGenerate.addEventListener('click', async function() {
            const prompt = promptInput.value.trim();
            if (!prompt) {
                Swal.fire('Erreur', 'Veuillez saisir un prompt pour l\'IA.', 'error');
                return;
            }

            const originalHtml = btnGenerate.innerHTML;
            btnGenerate.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Génération...';
            btnGenerate.disabled = true;

            try {
                const response = await fetch('{{ path('api_ai_generate_pdf_style') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt: prompt })
                });

                let result;
                try {
                    result = await response.json();
                } catch (e) {
                    throw new Error('Le serveur a renvoyé une réponse invalide.');
                }
                
                if (result.success) {
                    if (headerField) headerField.value = result.header;
                    if (bodyField) bodyField.value = result.body;
                    if (footerField) footerField.value = result.footer;
                    
                    Swal.fire({
                        title: 'Généré !',
                        text: 'Le contenu a été généré et inséré dans les champs.',
                        icon: 'success',
                        confirmButtonColor: '#0d6efd'
                    });
                } else {
                    throw new Error(result.error || 'Erreur inconnue');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Erreur', 'Impossible de générer le contenu : ' + err.message, 'error');
            } finally {
                btnGenerate.innerHTML = originalHtml;
                btnGenerate.disabled = false;
            }
        });
    }
});
</script>
