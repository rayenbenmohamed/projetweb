{% extends 'layout/admin.html.twig' %}

{% block title %}Entretien Vidéo - SyfonuRH{% endblock %}
{% block page_title %}Entretien en direct{% endblock %}

{% block stylesheets %}
<style>
    .video-wrapper {
        background-color: #0f172a;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        height: calc(100vh - 160px);
        min-height: 550px;
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    #jitsi-container {
        width: 100%;
        height: 100%;
        background: #000;
    }
    .video-header {
        background: linear-gradient(90deg, #1e293b 0%, #0f172a 100%);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        z-index: 10;
    }
    .video-header h5 {
        margin: 0;
        color: #ffffff;
        font-weight: 600;
        letter-spacing: -0.01em;
    }
    .video-header p {
        margin: 0;
        color: #94a3b8;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .status-dot {
        width: 8px;
        height: 8px;
        background-color: #10b981;
        border-radius: 50%;
        display: inline-block;
        animation: pulse 2s infinite;
    }
    @keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }
</style>
{% endblock %}

{% block content %}
<div class="row">
    <div class="col-12">
        <div class="video-wrapper">
            <div class="video-header">
                <div>
                    <h5><i class="ti ti-briefcase me-2 text-primary"></i>{{ interview.application.jobOffre.title }}</h5>
                    <p>
                        <span class="status-dot"></span>
                        Entretien avec {{ interview.application.candidat.firstName }} {{ interview.application.candidat.lastName }}
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <button id="toggleTileView" class="btn btn-sm btn-outline-light me-2">
                        <i class="ti ti-layout-grid-add me-1"></i> Mode Grille
                    </button>
                    <a href="{{ path('app_interview_show', {'id': interview.id}) }}" class="btn btn-sm btn-danger px-4 rounded-pill shadow-sm">
                        <i class="ti ti-phone-off me-1"></i> Quitter
                    </a>
                </div>
            </div>
            <div id="jitsi-container"></div>
        </div>
    </div>
</div>

<script src="https://meet.jit.si/external_api.js"></script>
<script>
    window.onload = () => {
        const domain = "meet.jit.si";
        const options = {
            roomName: "{{ roomName }}",
            width: '100%',
            height: '100%',
            parentNode: document.querySelector('#jitsi-container'),
            userInfo: {
                displayName: "{{ userName }}"
            },
            configOverwrite: {
                startWithAudioMuted: false,
                disableThirdPartyRequests: true,
                prejoinPageEnabled: false,
                enableWelcomePage: false,
                enableClosePage: false,
                chromeExtensionBanner: null,
                // Masquage des éléments de branding
                hideConferenceTimer: false,
                remoteVideoMenu: {
                    disableKick: false
                }
            },
            interfaceConfigOverwrite: {
                TOOLBAR_BUTTONS: [
                    'microphone', 'camera', 'desktop', 'fullscreen',
                    'fodeviceselection', 'hangup', 'chat', 'raisehand',
                    'videoquality', 'filmstrip', 'tileview', 'videobackgroundblur', 'settings'
                ],
                DEFAULT_REMOTE_DISPLAY_NAME: 'Membre Syfonu',
                SHOW_JITSI_WATERMARK: false,
                SHOW_WATERMARK_FOR_GUESTS: false,
                SHOW_BRAND_WATERMARK: false,
                BRAND_WATERMARK_LINK: '',
                SHOW_POWERED_BY: false,
                GENERATE_ROOMNAMES_ON_WELCOME_PAGE: false,
                DISPLAY_WELCOME_PAGE_CONTENT: false,
                MOBILE_APP_PROMO: false
            }
        };
        const api = new JitsiMeetExternalAPI(domain, options);
        
        // Synchronisation du bouton Mode Grille
        document.getElementById('toggleTileView').addEventListener('click', () => {
            api.executeCommand('toggleTileView');
        });

        // Redirection à la fin
        api.addEventListener('videoConferenceLeft', () => {
            window.location.href = "{{ path('app_interview_show', {'id': interview.id}) }}";
        });
    };
</script>
{% endblock %}
