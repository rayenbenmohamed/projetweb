{% extends 'layout/admin.html.twig' %}

{% block title %}Détails de l'entretien | SyfonuRH{% endblock %}
{% block page_title %}Consultation de l'entretien{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-8">
        <div class="card card-lg border-0 shadow-sm overflow-hidden">
            <div class="bg-primary p-6 py-8 border-bottom border-primary-subtle">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-4">
                        <div class="icon-shape icon-xl rounded-circle bg-white text-primary shadow-sm">
                            <i class="ti ti-calendar-event fs-1"></i>
                        </div>
                        <div>
                            <h3 class="mb-1 text-white fw-bold">Entretien RH</h3>
                            <p class="mb-0 text-white-50">Offre : {{ interview.application.jobOffre.title }}</p>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-white text-primary border-0 fs-6 px-3 py-2 shadow-sm">
                            <i class="ti ti-circle-filled me-1 small"></i> {{ interview.status }}
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-6">
                <div class="row g-6 mb-8">
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 bg-light border border-dashed border-secondary-subtle h-100">
                            <h6 class="text-uppercase text-secondary fw-semibold small mb-3 tracking-wider">
                                <i class="ti ti-clock me-2"></i>Date et Heure
                            </h6>
                            <h4 class="mb-1 fw-bold">{{ interview.scheduledAt|date('d F Y') }}</h4>
                            <p class="mb-0 text-secondary fs-5 text-primary-emphasis fw-medium">
                                {{ interview.scheduledAt|date('H:i') }}
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 bg-primary-subtle border border-primary border-opacity-25 h-100 d-flex flex-column justify-content-center align-items-center text-center">
                            <h6 class="text-uppercase text-primary fw-bold small mb-3 tracking-wider">
                                <i class="ti ti-video me-2"></i>Entretien Vidéo Native
                            </h6>
                            <a href="{{ path('app_interview_video', {id: interview.id}) }}" class="btn btn-primary btn-lg w-100 shadow-sm">
                                <i class="ti ti-phone-call me-2"></i> Rejoindre l'appel
                            </a>
                            <p class="mt-3 mb-0 text-primary-emphasis small">
                                <i class="ti ti-info-circle me-1"></i> Réunion sécurisée sur la plateforme
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mb-8">
                    <h5 class="mb-4 d-flex align-items-center gap-2">
                        <i class="ti ti-notes fs-4 text-primary"></i>
                        Notes et Instructions
                    </h5>
                    <div class="p-5 bg-light rounded-4 border-0">
                        <p class="mb-0 lead text-secondary-emphasis" style="white-space: pre-line;">
                            {{ interview.notes ?: 'Aucune consigne particulière.' }}
                        </p>
                    </div>
                </div>

                <hr class="my-8 opacity-10">

                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="avatar avatar-md rounded-circle bg-secondary-subtle">
                            <i class="ti ti-user fs-4 text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">Candidat : {{ interview.application.candidat.firstName }} {{ interview.application.candidat.lastName }}</h6>
                            <span class="small text-secondary">{{ interview.application.candidat.email }}</span>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <a href="{{ path('app_job_application_index') }}" class="btn btn-outline-secondary px-5">
                            <i class="ti ti-arrow-left me-2"></i> Retour
                        </a>
                        {% if app.user and interview.application.jobOffre.user and interview.application.jobOffre.user.id == app.user.id %}
                            <a href="{{ path('app_interview_edit', {id: interview.id}) }}" class="btn btn-warning px-5 text-white">
                                <i class="ti ti-pencil me-2"></i> Modifier
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
