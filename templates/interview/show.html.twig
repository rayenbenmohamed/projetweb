{% extends 'layout/admin.html.twig' %}

{% block title %}Détails de l'entretien | SyfonuRH{% endblock %}
{% block page_title %}Consultation de l'entretien{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-8">
        <div class="card card-lg border-0 shadow-sm overflow-hidden mb-6">
            <div class="bg-primary p-6 py-8 border-bottom border-primary-subtle">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-4">
                        <div class="icon-shape icon-xl rounded-circle bg-white text-primary shadow-sm">
                            <i class="ti ti-calendar-event fs-1"></i>
                        </div>
                        <div>
                            <h3 class="mb-1 text-white fw-bold">Entretien RH</h3>
                            <p class="mb-0 text-white-50">Offre : {{ interview.application.jobOffre.title }}</p>
                        </div>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-white text-primary border-0 fs-6 px-3 py-2 shadow-sm">
                            <i class="ti ti-circle-filled me-1 small"></i> {{ interview.status }}
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-6">
                <!-- Infos principales -->
                <div class="row g-6 mb-8">
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 bg-light border border-dashed border-secondary-subtle h-100">
                            <h6 class="text-uppercase text-secondary fw-semibold small mb-3 tracking-wider">
                                <i class="ti ti-clock me-2"></i>Date et Heure
                            </h6>
                            <h4 class="mb-1 fw-bold">{{ interview.scheduledAt|date('d F Y') }}</h4>
                            <p class="mb-0 text-secondary fs-5 text-primary-emphasis fw-medium">
                                {{ interview.scheduledAt|date('H:i') }}
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 rounded-4 bg-primary-subtle border border-primary border-opacity-25 h-100 d-flex flex-column justify-content-center align-items-center text-center">
                            <h6 class="text-uppercase text-primary fw-bold small mb-3 tracking-wider">
                                <i class="ti ti-video me-2"></i>Entretien Vidéo Native
                            </h6>
                            <a href="{{ path('app_interview_video', {id: interview.id}) }}" class="btn btn-primary btn-lg w-100 shadow-sm">
                                <i class="ti ti-phone-call me-2"></i> Rejoindre l'appel
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="mb-8">
                    <h5 class="mb-4 d-flex align-items-center gap-2">
                        <i class="ti ti-notes fs-4 text-primary"></i>
                        Notes et Instructions
                    </h5>
                    <div class="p-5 bg-light rounded-4 border-0">
                        <p class="mb-0 lead text-secondary-emphasis" style="white-space: pre-line;">
                            {{ interview.notes ?: 'Aucune consigne particulière.' }}
                        </p>
                    </div>
                </div>

                <!-- Évaluation (Si déjà faite) -->
                {% if interview.finalVerdict %}
                <div class="mt-8 p-6 bg-success-subtle rounded-4 border border-success border-opacity-25">
                    <h5 class="mb-4 text-success d-flex align-items-center gap-2">
                        <i class="ti ti-award fs-4"></i> Évaluation de l'entretien
                    </h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="small text-uppercase fw-bold text-secondary d-block">Technique</label>
                            <div class="text-warning fs-4">
                                {% for i in 1..5 %}<i class="ti ti-star{{ i <= interview.technicalRating ? '-filled' : '' }}"></i>{% endfor %}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="small text-uppercase fw-bold text-secondary d-block">Communication</label>
                            <div class="text-warning fs-4">
                                {% for i in 1..5 %}<i class="ti ti-star{{ i <= interview.communicationRating ? '-filled' : '' }}"></i>{% endfor %}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="small text-uppercase fw-bold text-secondary d-block">Motivation</label>
                            <div class="text-warning fs-4">
                                {% for i in 1..5 %}<i class="ti ti-star{{ i <= interview.motivationRating ? '-filled' : '' }}"></i>{% endfor %}
                            </div>
                        </div>
                    </div>
                    <div class="p-4 bg-white rounded-3 shadow-sm mb-3">
                        <h6 class="fw-bold mb-2">Verdict final :</h6>
                        <p class="mb-0 text-secondary-emphasis italic">"{{ interview.finalVerdict }}"</p>
                    </div>
                    
                    <div class="d-flex align-items-center justify-content-between p-3 bg-white rounded-3 shadow-sm">
                        <span class="fw-bold">Décision :</span>
                        {% if interview.outcome == 'ACCEPTED' %}
                            <span class="badge bg-success px-3 py-2"><i class="ti ti-check me-1"></i> Accepté</span>
                        {% elseif interview.outcome == 'REJECTED' %}
                            <span class="badge bg-danger px-3 py-2"><i class="ti ti-x me-1"></i> Refusé</span>
                        {% else %}
                            <span class="badge bg-warning text-dark px-3 py-2"><i class="ti ti-clock me-1"></i> En attente</span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                <hr class="my-8 opacity-10">

                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="avatar avatar-md rounded-circle bg-secondary-subtle">
                            <i class="ti ti-user fs-4 text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">{{ interview.application.candidat.firstName }} {{ interview.application.candidat.lastName }}</h6>
                            <span class="small text-secondary">{{ interview.application.candidat.email }}</span>
                        </div>
                    </div>
                    <div class="d-flex gap-3">
                        <a href="{{ path('app_job_application_index') }}" class="btn btn-outline-secondary px-4">Retour</a>
                        {% if app.user and interview.application.jobOffre.user and interview.application.jobOffre.user.id == app.user.id and not interview.finalVerdict %}
                            <button type="button" class="btn btn-success px-4" data-bs-toggle="modal" data-bs-target="#evaluateModal">
                                <i class="ti ti-award me-2"></i>Évaluer le candidat
                            </button>
                        {% elseif interview.status == 'Réalisée' %}
                            <form action="{{ path('app_interview_archive', {id: interview.id}) }}" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-dark px-4">
                                    <i class="ti ti-archive me-2"></i>Archiver
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal d'évaluation -->
<div class="modal fade" id="evaluateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form action="{{ path('app_interview_evaluate', {id: interview.id}) }}" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="ti ti-award me-2"></i>Fiche d'Évaluation</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-primary-subtle rounded-3">
                        <div>
                            <span class="fw-bold text-primary"><i class="ti ti-sparkles me-1"></i> Besoin d'aide ?</span>
                            <p class="mb-0 small text-muted">L'IA peut analyser le CV et vos notes pour suggérer des scores.</p>
                        </div>
                        <button type="button" id="btnAISuggest" class="btn btn-primary btn-sm rounded-pill px-3">
                            <span class="spinner-border spinner-border-sm d-none me-1" id="aiSpinner"></span>
                            <i class="ti ti-wand me-1"></i> Suggérer par IA
                        </button>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Compétences Techniques</label>
                        <select id="technicalRating" name="technicalRating" class="form-select">
                            <option value="1">1 - Insuffisant</option>
                            <option value="2">2 - Passable</option>
                            <option value="3" selected>3 - Moyen</option>
                            <option value="4">4 - Bon</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Communication & Soft Skills</label>
                        <select id="communicationRating" name="communicationRating" class="form-select">
                            <option value="1">1 - Insuffisant</option>
                            <option value="2">2 - Passable</option>
                            <option value="3" selected>3 - Moyen</option>
                            <option value="4">4 - Bon</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Motivation & Fit Culturel</label>
                        <select id="motivationRating" name="motivationRating" class="form-select">
                            <option value="1">1 - Insuffisant</option>
                            <option value="2">2 - Passable</option>
                            <option value="3" selected>3 - Moyen</option>
                            <option value="4">4 - Bon</option>
                            <option value="5">5 - Excellent</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-primary">Décision de l'entretien</label>
                        <select name="outcome" class="form-select border-primary">
                            <option value="PENDING_DECISION">En attente de décision</option>
                            <option value="ACCEPTED">Accepter le profil pour la suite</option>
                            <option value="REJECTED">Rejeter le profil</option>
                        </select>
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-bold">Verdict / Commentaires finaux</label>
                        <textarea id="finalVerdict" name="finalVerdict" class="form-control" rows="4" placeholder="Résumé de vos impressions..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success px-4">Valider l'évaluation</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('btnAISuggest').addEventListener('click', function() {
    const btn = this;
    const spinner = document.getElementById('aiSpinner');
    
    btn.disabled = true;
    spinner.classList.remove('d-none');

    fetch("{{ path('app_interview_ai_suggest', {id: interview.id}) }}", {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => response.json())
    .then(data => {
        if (data.technicalRating) document.getElementById('technicalRating').value = data.technicalRating;
        if (data.communicationRating) document.getElementById('communicationRating').value = data.communicationRating;
        if (data.motivationRating) document.getElementById('motivationRating').value = data.motivationRating;
        if (data.suggestedVerdict) document.getElementById('finalVerdict').value = data.suggestedVerdict;
        
        // Notification de succès visuel
        btn.classList.replace('btn-primary', 'btn-success');
        btn.innerHTML = '<i class="ti ti-check-double me-1"></i> Suggestion appliquée !';
    })
    .catch(error => {
        console.error('Erreur IA:', error);
        alert("L'IA n'a pas pu générer de suggestion pour le moment.");
    })
    .finally(() => {
        spinner.classList.add('d-none');
        setTimeout(() => {
            btn.disabled = false;
            btn.classList.replace('btn-success', 'btn-primary');
            btn.innerHTML = '<i class="ti ti-wand me-1"></i> Suggérer par IA';
        }, 3000);
    });
});
</script>
{% endblock %}
