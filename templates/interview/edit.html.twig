{% extends 'layout/admin.html.twig' %}

{% block title %}Modifier l'entretien | SyfonuRH{% endblock %}
{% block page_title %}Modifier l'entretien{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-6">
        <div class="card card-lg overflow-hidden border-0 shadow-sm">
            <div class="bg-warning-subtle p-6 py-8 border-bottom border-warning-subtle">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-shape icon-lg rounded-circle bg-warning text-white">
                        <i class="ti ti-calendar-event fs-2"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 text-warning-emphasis">Modifier l'entretien</h4>
                        <p class="mb-0 text-secondary small">Candidat : {{ job_application.candidat.firstName }} {{ job_application.candidat.lastName }}</p>
                    </div>
                </div>
            </div>
            <div class="card-body p-6">
                {{ form_start(form, {'attr': {'id': 'interviewForm', 'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    <div class="mb-4">
                        <label class="form-label fw-semibold">{{ form_label(form.scheduledAt) }} <span class="text-danger">*</span></label>
                        {{ form_widget(form.scheduledAt, {'id': 'interview_scheduledAt', 'attr': {'class': 'form-control form-control-lg'}}) }}
                        <div class="invalid-feedback">Veuillez indiquer une date future.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">{{ form_label(form.status) }}</label>
                        {{ form_widget(form.status, {'attr': {'class': 'form-select form-control-lg'}}) }}
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">{{ form_label(form.notes) }} <span class="text-danger">*</span></label>
                        {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                        <div class="invalid-feedback">Un minimum de 10 caractères est requis.</div>
                    </div>
                    
                    <div class="d-grid gap-3 mt-6">
                        <button type="submit" class="btn btn-warning btn-lg text-white">Mettre à jour l'entretien</button>
                        <a href="{{ path('app_interview_index') }}" class="btn btn-light btn-lg">Annuler</a>
                    </div>
                    {{ form_rest(form) }}
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const dateInput = document.getElementById('interview_scheduledAt');
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        // For editing, we don't strictly enforce future-only if it was already scheduled,
        // but we keep the helper for new changes.
        // dateInput.min = now.toISOString().slice(0, 16);
        
        const form = document.getElementById('interviewForm');
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            }
            form.classList.add('was-validated');
        }, false);
    });
</script>
{% endblock %}
