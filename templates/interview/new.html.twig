{% extends 'layout/admin.html.twig' %}

{% block title %}Planifier un entretien | SyfonuRH{% endblock %}
{% block page_title %}Planifier un entretien{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
    <!-- Colonne de gauche : Calendrier des entretiens -->
    <div class="col-xl-7">
        <div class="card h-100 overflow-hidden">
            <div class="card-header bg-light-subtle d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="ti ti-calendar-event me-2"></i>Mon Calendrier RH</h5>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3">Visualisation des créneaux</span>
            </div>
            <div class="card-body p-0">
                <div id="calendar" style="height: 600px;"></div>
            </div>
        </div>
    </div>

    <!-- Colonne de droite : Formulaire de planification -->
    <div class="col-xl-5">
        <div class="card card-lg h-100 overflow-hidden shadow-sm">
            <div class="bg-primary p-5">
                <h5 class="text-white mb-1"><i class="ti ti-clock-plus me-2"></i>Détails du rendez-vous</h5>
                <p class="text-white-50 small mb-0">Candidat : {{ job_application.candidat.firstName }} {{ job_application.candidat.lastName }}</p>
                <div class="badge bg-white text-primary mt-2">{{ job_application.jobOffre.title }}</div>
            </div>
            <div class="card-body p-5">
                {{ form_start(form, {'attr': {'id': 'interviewForm', 'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    <div class="mb-4">
                        <label class="form-label fw-bold">{{ form_label(form.scheduledAt) }} <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="ti ti-calendar"></i></span>
                            {{ form_widget(form.scheduledAt, {'id': 'interview_scheduledAt'}) }}
                        </div>
                        <div class="form-text small">Cliquez sur un créneau dans le calendrier pour remplir automatiquement ce champ.</div>
                        {{ form_errors(form.scheduledAt) }}
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">{{ form_label(form.notes) }} <span class="text-danger">*</span></label>
                        {{ form_widget(form.notes) }}
                        {{ form_errors(form.notes) }}
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="ti ti-device-floppy me-2"></i>Enregistrer l'entretien
                        </button>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_job_application_index') }}" class="btn btn-link btn-sm text-secondary">Annuler</a>
                    </div>
                    {{ form_rest(form) }}
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<!-- Scripts FullCalendar -->
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/fr.js'></script>

<style>
    #calendar { padding: 10px; }
    .fc-header-toolbar { padding: 5px; font-size: 0.9em; }
    .fc-event { cursor: pointer; border: none; padding: 2px 5px; }
    .fc-v-event { background-color: #5a5fee !important; }
    .fc-daygrid-event { background-color: #5a5fee !important; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const dateInput = document.getElementById('interview_scheduledAt');
        
        // Configuration de la date min (aujourd'hui)
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        if (dateInput) dateInput.min = now.toISOString().slice(0, 16);

        // Initialisation de FullCalendar
        const calendarEl = document.getElementById('calendar');
        if (calendarEl) {
            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                locale: 'fr',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                slotMinTime: '08:00:00',
                slotMaxTime: '20:00:00',
                selectable: true,
                allDaySlot: false,
                events: [
                    {% for interview in existingInterviews %}
                    {
                        title: "Rendez-vous ({{ interview.application.candidat.firstName }})",
                        start: "{{ interview.scheduledAt|date('Y-m-d\\TH:i:s') }}",
                        end: "{{ interview.scheduledAt|date_modify('+1 hour')|date('Y-m-d\\TH:i:s') }}",
                        color: '#dc3545', // Rouge pour les rendez-vous existants
                        display: 'block'
                    },
                    {% endfor %}
                ],
                dateClick: function(info) {
                    if (dateInput) {
                        const clickedDate = info.date;
                        clickedDate.setMinutes(clickedDate.getMinutes() - clickedDate.getTimezoneOffset());
                        dateInput.value = clickedDate.toISOString().slice(0, 16);
                        
                        dateInput.classList.add('is-valid');
                        setTimeout(() => dateInput.classList.remove('is-valid'), 1000);
                    }
                }
            });
            calendar.render();

            if (dateInput) {
                dateInput.addEventListener('change', function() {
                    if (this.value) {
                        const selectedDate = new Date(this.value);
                        calendar.gotoDate(selectedDate);
                        calendar.changeView('timeGridDay');
                    }
                });
            }
        }

        const form = document.getElementById('interviewForm');
        if (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        }
    });
</script>
{% endblock %}
