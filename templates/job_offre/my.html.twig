{% extends 'layout/admin.html.twig' %}

{% block title %}Mes offres d'emploi | SyfonuRH{% endblock %}
{% block page_title %}Mes offres d'emploi{% endblock %}

{% block content %}

{# Modals de confirmation de suppression #}
{% for offre in job_offres %}
<div class="modal fade" id="deleteModal{{ offre.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger"><i class="ti ti-alert-triangle me-2"></i>Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir supprimer l'offre <strong>{{ offre.title }}</strong> ? Cette action est irréversible.
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('app_job_offre_delete', {id: offre.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ offre.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="ti ti-trash me-1"></i>Supprimer
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endfor %}

<div class="row g-6 mt-2">
    <div class="col-12">
        <div class="card h-100">
            <div class="card-header border-bottom-0 d-md-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-0">Mes offres publiées</h5>
                    <small class="text-secondary">Seules vos offres sont affichées ici. Les candidats voient toutes les offres sur la <a href="{{ path('app_job_offre_index') }}">vue publique</a>.</small>
                </div>
                <a href="{{ path('app_job_offre_new') }}" class="btn btn-primary btn-sm mt-2 mt-md-0">
                    <i class="ti ti-plus me-1"></i> Nouvelle offre
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>Titre</th>
                            <th>Lieu</th>
                            <th>Salaire</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Candidatures</th>
                            <th>Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for offre in job_offres %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-shape icon-md rounded-3 bg-primary-subtle text-primary">
                                        <i class="ti ti-briefcase fs-4"></i>
                                    </div>
                                    <div>
                                        <a href="{{ path('app_job_offre_show', {id: offre.id}) }}" class="text-body text-decoration-none">
                                            <h6 class="mb-0">{{ offre.title }}</h6>
                                        </a>
                                        <span class="small text-secondary">{{ offre.location ?: '—' }}</span>
                                    </div>
                                </div>
                            </td>
                            <td>{{ offre.location ?: '—' }}</td>
                            <td>{{ offre.salary ? offre.salary|number_format(0, ',', ' ') ~ ' €' : '—' }}</td>
                            <td>{{ offre.employmentType ?: '—' }}</td>
                            <td>
                                {% set statusClass = offre.status == 'PUBLISHED' ? 'success' : (offre.status == 'DRAFT' ? 'warning' : 'secondary') %}
                                {% set statusLabel = offre.status == 'PUBLISHED' ? 'Publiée' : (offre.status == 'DRAFT' ? 'Brouillon' : offre.status) %}
                                <span class="badge bg-{{ statusClass }}-subtle text-{{ statusClass }}-emphasis">{{ statusLabel }}</span>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info-emphasis">
                                    <i class="ti ti-users me-1"></i>{{ offre.jobApplications|length }}
                                </span>
                            </td>
                            <td>{{ offre.createdAt|date('d/m/Y') }}</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    {# Voir #}
                                    <a href="{{ path('app_job_offre_show', {id: offre.id}) }}"
                                       class="btn btn-icon btn-sm btn-outline-info rounded-circle"
                                       title="Voir les détails">
                                        <i class="ti ti-eye"></i>
                                    </a>
                                    {# Modifier #}
                                    <a href="{{ path('app_job_offre_edit', {id: offre.id}) }}"
                                       class="btn btn-icon btn-sm btn-outline-warning rounded-circle"
                                       title="Modifier">
                                        <i class="ti ti-pencil"></i>
                                    </a>
                                    {# Dupliquer #}
                                    <form method="post" action="{{ path('app_job_offre_duplicate', {id: offre.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ offre.id) }}">
                                        <button type="submit" class="btn btn-icon btn-sm btn-outline-primary rounded-circle" title="Dupliquer">
                                            <i class="ti ti-copy"></i>
                                        </button>
                                    </form>
                                    {# Supprimer (ouvre modal) #}
                                    <button type="button"
                                            class="btn btn-icon btn-sm btn-outline-danger rounded-circle"
                                            title="Supprimer"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal{{ offre.id }}">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-8">
                                <i class="ti ti-briefcase-off fs-1 text-secondary d-block mb-2"></i>
                                <p class="text-secondary mb-0">Vous n'avez pas encore créé d'offre.</p>
                                <a href="{{ path('app_job_offre_new') }}" class="btn btn-primary btn-sm mt-3">
                                    <i class="ti ti-plus me-1"></i> Créer une offre
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
