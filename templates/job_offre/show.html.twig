{% extends 'layout/admin.html.twig' %}

{% block title %}{{ job_offre.title }} | SyfonuRH{% endblock %}

{% block content %}
<div class="row g-6 mt-2">

    {# === COLONNE PRINCIPALE === #}
    <div class="col-xl-8">

        {# En-tête de l'offre #}
        <div class="card card-lg mb-4">
            <div class="card-body p-6">
                    <div class="d-flex gap-3 align-items-center">
                        {% if job_offre.entreprise and job_offre.entreprise.logo %}
                        <div class="flex-shrink-0">
                            <img src="{{ job_offre.entreprise.logo }}" alt="Logo {{ job_offre.entreprise.name }}"
                                 style="width:82px;height:82px;object-fit:cover;border-radius:18px;border:2.5px solid #eef0f8;box-shadow:0 4px 18px rgba(92,103,245,.14);">
                        </div>
                        {% elseif job_offre.companyLogo %}
                        <div class="flex-shrink-0">
                            <img src="{{ job_offre.companyLogo }}" alt="Logo {{ job_offre.title }}"
                                 style="width:82px;height:82px;object-fit:cover;border-radius:18px;border:2.5px solid #eef0f8;box-shadow:0 4px 18px rgba(92,103,245,.14);">
                        </div>
                        {% else %}
                        <div class="icon-shape icon-xl rounded-4 bg-primary-subtle text-primary">
                            <i class="ti ti-building fs-2"></i>
                        </div>
                        {% endif %}
                        <div>
                            <h2 class="mb-1 fs-4 fw-bold">{{ job_offre.title }}</h2>
                            <div class="d-flex flex-wrap gap-3 text-secondary small">
                                <span class="fw-bold text-primary"><i class="ti ti-building me-1"></i>{{ job_offre.entreprise.name|default('Entreprise') }}</span>
                                {% if job_offre.location %}
                                <span><i class="ti ti-map-pin me-1"></i>{{ job_offre.location }}</span>
                                {% endif %}
                                {% if job_offre.employmentType %}
                                <span><i class="ti ti-briefcase me-1"></i>{{ job_offre.employmentType }}</span>
                                {% endif %}
                                <span><i class="ti ti-calendar me-1"></i>Publiée le {{ job_offre.createdAt|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </div>
                    {% set dStatus = job_offre.displayStatus %}
                    {% set statusClass = dStatus == 'PUBLISHED' ? 'success' : (dStatus == 'DRAFT' ? 'warning' : 'secondary') %}
                    {% set statusLabel = dStatus == 'PUBLISHED' ? 'Publiée' : (dStatus == 'DRAFT' ? 'Brouillon' : 'Archivée') %}
                    <span class="badge bg-{{ statusClass }}-subtle text-{{ statusClass }}-emphasis px-3 py-2 fs-6">
                        {{ statusLabel }}
                    </span>
                </div>

                {# Infos rapides #}
                <div class="row g-3 mb-4">
                    <div class="col-sm-4">
                        <div class="bg-primary-subtle rounded-3 p-3 text-center">
                            <i class="ti ti-coin fs-3 text-primary d-block mb-1"></i>
                            <div class="fw-semibold">
                                {% if job_offre.salary %}
                                    {{ job_offre.salary|number_format(0, ',', ' ') }} €/an
                                {% else %}
                                    Non précisé
                                {% endif %}
                            </div>
                            <div class="small text-secondary">
                                {% if job_offre.isSalaryNegotiable %}<span class="badge bg-success-subtle text-success-emphasis">Négociable</span>{% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="bg-info-subtle rounded-3 p-3 text-center">
                            <i class="ti ti-users fs-3 text-info d-block mb-1"></i>
                            <div class="fw-semibold">{{ job_offre.jobApplications|length }} candidature(s)</div>
                            <div class="small text-secondary">reçues</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="bg-{{ job_offre.expiresAt and job_offre.expiresAt < date() ? 'danger' : 'warning' }}-subtle rounded-3 p-3 text-center">
                            <i class="ti ti-alarm fs-3 text-{{ job_offre.expiresAt and job_offre.expiresAt < date() ? 'danger' : 'warning' }} d-block mb-1"></i>
                            {% if job_offre.expiresAt %}
                                <div class="fw-semibold">{{ job_offre.expiresAt|date('d/m/Y') }}</div>
                                <div class="small text-secondary">Date d'expiration</div>
                            {% else %}
                                <div class="fw-semibold">—</div>
                                <div class="small text-secondary">Pas de date limite</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Description #}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="ti ti-file-description me-2"></i>Description du poste</h5>
            </div>
            <div class="card-body">
                <div class="text-secondary lh-lg">
                    {{ job_offre.description|nl2br }}
                </div>
            </div>
        </div>

        {# Avantages (Table) #}
        {% if job_offre.linkedAvantages|length > 0 %}
        <div class="card mb-4 border-primary-subtle">
            <div class="card-header bg-primary-subtle bg-opacity-10">
                <h5 class="card-title mb-0 text-primary"><i class="ti ti-gift me-2"></i>Avantages inclus</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for av in job_offre.linkedAvantages %}
                    <div class="col-sm-6 col-md-4">
                        <div class="d-flex align-items-center gap-2 p-2 border rounded-3 bg-light-subtle">
                            <div class="icon-shape icon-sm rounded-circle bg-primary text-white">
                                <i class="ti {{ av.icon ?: 'ti-check' }}"></i>
                            </div>
                            <span class="fw-medium small">{{ av.name }}</span>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {# Avantages (Legacy Text) #}
        {% if job_offre.advantages %}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="ti ti-star me-2"></i>Autres avantages</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    {% for advantage in job_offre.advantages|split(',') %}
                        {% set advantage = advantage|trim %}
                        {% if advantage %}
                        <span class="badge bg-secondary-subtle text-secondary-emphasis px-3 py-2 rounded-pill fs-6">
                            <i class="ti ti-plus me-1"></i>{{ advantage }}
                        </span>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {# Compétences #}
        {% if job_offre.skills %}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="ti ti-bulb me-2"></i>Compétences attendues & Niveaux</h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    {% for skill_part in job_offre.skills|split(',') %}
                        {% set skill_part = skill_part|trim %}
                        {% if skill_part %}
                            {# Tenter d'extraire le nom et le pourcentage si présent #}
                            {% set name = skill_part %}
                            {% set percent = null %}

                            {# Vérifier sil y a des parenthèses #}
                            {% if '(' in skill_part and ')' in skill_part %}
                                {% set name_percent = skill_part|split('(') %}
                                {% set name = name_percent[0]|trim %}
                                {% set percent_raw = name_percent[1]|split(')') %}
                                {% set percent = percent_raw[0]|replace({'%': ''})|trim %}
                            {% endif %}

                            <div class="col-md-6">
                                <div class="skill-display-item mb-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-semibold text-dark">{{ name }}</span>
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill" style="font-size: 0.7rem;">
                                            {{ percent is not null ? percent ~ '%' : 'Requis' }}
                                        </span>
                                    </div>
                                    {% if percent is not null %}
                                    <div class="progress" style="height: 6px; background-color: #f1f5f9; border-radius: 10px; overflow: hidden;">
                                        <div class="progress-bar progress-bar-animated" 
                                             role="progressbar" 
                                             style="width: {{ percent }}%; background: linear-gradient(90deg, #5c67f5, #8892f7); transition: width 1s ease-in-out;" 
                                             aria-valuenow="{{ percent }}" 
                                             aria-valuemin="0" 
                                             aria-valuemax="100"></div>
                                    </div>
                                    {% else %}
                                    <div class="progress" style="height: 6px; background-color: #f1f5f9; border-radius: 10px;">
                                        <div class="progress-bar" role="progressbar" style="width: 100%; background-color: #94a3b8;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {# Candidatures #}
        {% if job_offre.jobApplications|length > 0 %}
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="ti ti-users me-2"></i>Candidatures reçues ({{ job_offre.jobApplications|length }})</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Candidat</th>
                            <th>Date</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for application in job_offre.jobApplications %}
                        <tr>
                            <td>{{ application.candidate.firstName ?? 'Candidat' }} {{ application.candidate.lastName ?? '' }}</td>
                            <td>{{ application.createdAt is defined ? application.createdAt|date('d/m/Y') : '—' }}</td>
                            <td><span class="badge bg-secondary-subtle text-secondary-emphasis">{{ application.status ?? 'En attente' }}</span></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>

    {# === COLONNE LATÉRALE === #}
    <div class="col-xl-4">
        {# Actions #}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">

                    {# Actions réservées à l'auteur de l'offre #}
                    {% if app.user and job_offre.user == app.user %}
                    <a href="{{ path('app_job_offre_edit', {id: job_offre.id}) }}" class="btn btn-warning">
                        <i class="ti ti-pencil me-2"></i>Modifier l'offre
                    </a>
                    <form method="post" action="{{ path('app_job_offre_duplicate', {id: job_offre.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ job_offre.id) }}">
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="ti ti-copy me-2"></i>Dupliquer l'offre
                        </button>
                    </form>
                    {% endif %}
                    
                    {# Postuler button #}
                    {% if app.user %}
                        {% if app.user != job_offre.user %}
                            {% if user_application %}
                                <form method="post" action="{{ path('app_job_application_delete', {id: user_application.id}) }}" 
                                      onsubmit="return confirm('Voulez-vous vraiment retirer votre candidature ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user_application.id) }}">
                                    <button type="submit" class="btn btn-outline-danger w-100">
                                        <i class="ti ti-trash me-2"></i>Retirer ma candidature
                                    </button>
                                </form>
                            {% else %}
                                <a href="{{ path('app_job_application_new', {id: job_offre.id}) }}" class="btn btn-success w-100">
                                    <i class="ti ti-send me-2"></i>Postuler
                                </a>
                            {% endif %}
                            <hr class="my-1">
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary w-100">
                            <i class="ti ti-login me-2"></i>Se connecter pour postuler
                        </a>
                        <hr class="my-1">
                    {% endif %}
                    
                    <hr class="my-1">
                    {# Retour adapté : si on est connecté, on peut retourner à ses offres #}
                    {% if app.user %}
                    <a href="{{ path('app_job_offre_my') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="ti ti-arrow-left me-2"></i>Mes offres
                    </a>
                    {% else %}
                    <a href="{{ path('app_job_offre_index') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="ti ti-arrow-left me-2"></i>Retour à la liste
                    </a>
                    {% endif %}
                    {% if app.user and job_offre.user == app.user %}
                    <form method="post" action="{{ path('app_job_offre_delete', {id: job_offre.id}) }}"
                          onsubmit="return confirm('Confirmer la suppression de cette offre ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job_offre.id) }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="ti ti-trash me-2"></i>Supprimer l'offre
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Entreprise Profile #}
        {% if job_offre.entreprise %}
        <div class="card mb-4 border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0 small text-uppercase fw-bold text-secondary">À propos de l'entreprise</h5>
                {% if job_offre.entreprise.website %}
                    <a href="{{ job_offre.entreprise.website }}" target="_blank" class="small fw-bold text-primary text-decoration-none">Site Web <i class="ti ti-external-link"></i></a>
                {% endif %}
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="avatar avatar-lg rounded-3 bg-white border p-1" style="width:54px;height:54px;">
                        {% if job_offre.entreprise.logo %}
                            <img src="{{ job_offre.entreprise.logo }}" alt="{{ job_offre.entreprise.name }}" class="w-100 h-100 object-fit-cover rounded-2">
                        {% else %}
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-primary bg-primary-subtle rounded-2">
                                <i class="ti ti-building fs-3"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">{{ job_offre.entreprise.name }}</h6>
                        <span class="small text-secondary"><i class="ti ti-map-pin me-1"></i>{{ job_offre.entreprise.address|default('Localisation non précisée') }}</span>
                    </div>
                </div>
                <p class="small text-secondary mb-0 lh-base">
                    {{ job_offre.entreprise.description|slice(0, 200) }}{{ job_offre.entreprise.description|length > 200 ? '...' : '' }}
                </p>
            </div>
        </div>
        {% endif %}

        {# Recruteur #}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Recruteur</h5>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar avatar-md rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="ti ti-user fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">{{ job_offre.user ? (job_offre.user.firstName ~ ' ' ~ job_offre.user.lastName) : 'Non renseigné' }}</h6>
                        <span class="small text-secondary">{{ job_offre.user ? job_offre.user.email : 'Service Recrutement' }}</span>
                    </div>
                </div>
            </div>
        </div>

        {# Infos dates #}
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Informations</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-secondary small">Créée le</span>
                        <span class="fw-semibold small">{{ job_offre.createdAt|date('d/m/Y à H:i') }}</span>
                    </li>
                    {% if job_offre.publishedAt %}
                    <li class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-secondary small">Publiée le</span>
                        <span class="fw-semibold small">{{ job_offre.publishedAt|date('d/m/Y à H:i') }}</span>
                    </li>
                    {% endif %}
                    {% if job_offre.updatedAt %}
                    <li class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-secondary small">Modifiée le</span>
                        <span class="fw-semibold small">{{ job_offre.updatedAt|date('d/m/Y à H:i') }}</span>
                    </li>
                    {% endif %}
                    {% if job_offre.expiresAt %}
                    <li class="d-flex justify-content-between py-2">
                        <span class="text-secondary small">Expire le</span>
                        <span class="fw-semibold small text-danger">{{ job_offre.expiresAt|date('d/m/Y à H:i') }}</span>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
