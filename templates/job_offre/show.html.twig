{% extends 'layout/public.html.twig' %}

{% block title %}{{ job_offre.title }} | SyfonuRH{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
    <div class="col-xl-8">
        <div class="card card-lg mb-6">
            <div class="card-body p-6">
                <div class="d-flex justify-content-between align-items-start mb-6">
                    <div>
                        <h2 class="mb-1">{{ job_offre.title }}</h2>
                        <div class="d-flex gap-4 text-secondary small">
                            <span><i class="ti ti-map-pin me-1"></i>{{ job_offre.location }}</span>
                            <span><i class="ti ti-briefcase me-1"></i>{{ job_offre.employmentType }}</span>
                            <span><i class="ti ti-calendar me-1"></i>Publiée le {{ job_offre.createdAt|date('d/m/Y') }}</span>
                        </div>
                    </div>
                    <span class="badge bg-success-subtle text-success-emphasis px-3 py-2">
                        {{ job_offre.status|capitalize }}
                    </span>
                </div>

                <div class="mb-8">
                    <h5 class="mb-3">Description du poste</h5>
                    <div class="text-secondary lh-lg">
                        {{ job_offre.description|nl2br }}
                    </div>
                </div>

                <div class="mb-8">
                    <h5 class="mb-3">Informations complémentaires</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="ti ti-coin text-primary fs-4"></i>
                                <span class="fw-semibold">{{ job_offre.salary|number_format(0, ',', ' ') }} € / an</span>
                            </div>
                            <p class="text-secondary small">
                                Salaire <span class="badge bg-{{ job_offre.isSalaryNegotiable ? 'success' : 'secondary' }}-subtle text-{{ job_offre.isSalaryNegotiable ? 'success' : 'secondary' }}-emphasis">
                                    {{ job_offre.isSalaryNegotiable ? 'négociable' : 'non négociable' }}
                                </span>
                            </p>
                        </div>
                        {% if job_offre.expiresAt %}
                        <div class="col-md-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="ti ti-alarm text-danger fs-4"></i>
                                <span class="fw-semibold">Date d'expiration</span>
                            </div>
                            <p class="text-secondary small">Cette offre expire le {{ job_offre.expiresAt|date('d/m/Y à H:i') }}.</p>
                        </div>
                        {% endif %}
                    </div>
                    
                    {% if job_offre.advantages %}
                    <h5 class="mb-3">Avantages</h5>
                    <div class="d-flex flex-wrap gap-2 mb-6">
                        {% for advantage in job_offre.advantages|split(',') %}
                            {% set advantage = advantage|trim %}
                            {% if advantage %}
                            <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2 rounded-pill fs-6">
                                {{ advantage }}
                            </span>
                            {% endif %}
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card card-lg mb-6">
            <div class="card-body p-6">
                <h5 class="mb-4">Actions</h5>
                <div class="d-grid gap-3">
                    {% if is_granted('ROLE_CANDIDAT') %}
                    <a href="{{ path('app_job_application_new', {id: job_offre.id}) }}" class="btn btn-primary">
                        <i class="ti ti-send me-1"></i> Postuler maintenant
                    </a>
                    {% elseif not app.user %}
                    <a href="{{ path('app_login') }}" class="btn btn-primary">Connectez-vous pour postuler</a>
                    {% endif %}
                    {% if is_granted('ROLE_RECRUTEUR') or is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_job_offre_edit', {id: job_offre.id}) }}" class="btn btn-outline-secondary">
                        <i class="ti ti-pencil me-1"></i> Modifier l'offre
                    </a>
                    {% endif %}
                    <hr class="my-2">
                    <a href="{{ path('app_job_offre_index') }}" class="btn btn-link btn-sm text-secondary">
                        <i class="ti ti-arrow-left me-1"></i> Retour à la liste
                    </a>
                </div>
            </div>
        </div>

        <div class="card card-lg">
            <div class="card-body p-6">
                <h5 class="mb-4">Recruteur</h5>
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar avatar-md rounded-circle bg-primary-subtle text-primary">
                        <i class="ti ti-user fs-3"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">{{ job_offre.user ? (job_offre.user.firstName ~ ' ' ~ job_offre.user.lastName) : 'Non renseigné' }}</h6>
                        <span class="small text-secondary">Service Recrutement</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
