{% extends 'layout/front.html.twig' %}

{% block title %}Modifier l'offre | SyfonuRH{% endblock %}
{% block page_title %}Modifier : {{ job_offre.title }}{% endblock %}

{% block content %}
<div class="row g-6 mt-2 justify-content-center">
    <div class="col-xl-8">
        <div class="card card-lg">
            <div class="card-body p-6">
                <form method="post">
                    <div class="mb-4">
                        <label class="form-label">Titre du poste <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" value="{{ job_offre.title }}" minlength="5" maxlength="150" required>
                        <div class="invalid-feedback">Le titre doit contenir entre 5 et 150 caractères.</div>
                    </div>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Lieu</label>
                            <input type="text" name="location" class="form-control" value="{{ job_offre.location }}" maxlength="255">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Salaire annuel (€)</label>
                            <input type="number" name="salary" class="form-control" value="{{ job_offre.salary }}" min="0" max="500000" step="100">
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="is_salary_negotiable" id="isSalaryNegotiable" {{ job_offre.isSalaryNegotiable ? 'checked' }}>
                                <label class="form-check-label" for="isSalaryNegotiable">Le salaire est négociable</label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label">Type d'emploi <span class="text-danger">*</span></label>
                            <select name="employment_type" class="form-select" required>
                                <option value="CDI" {{ job_offre.employmentType == 'CDI' ? 'selected' }}>CDI</option>
                                <option value="CDD" {{ job_offre.employmentType == 'CDD' ? 'selected' }}>CDD</option>
                                <option value="Freelance" {{ job_offre.employmentType == 'Freelance' ? 'selected' }}>Freelance</option>
                                <option value="Stage" {{ job_offre.employmentType == 'Stage' ? 'selected' }}>Stage</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Date de début (Publiée) <span class="text-danger">*</span></label>
                            <input type="datetime-local" id="publishedAt" name="published_at" class="form-control" value="{{ job_offre.publishedAt ? job_offre.publishedAt|date('Y-m-d\\TH:i') }}" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Date d'expiration</label>
                            <input type="datetime-local" id="expiresAt" name="expires_at" class="form-control" value="{{ job_offre.expiresAt ? job_offre.expiresAt|date('Y-m-d\\TH:i') }}">
                            <div class="invalid-feedback">La date d'expiration doit être postérieure à la date de publication.</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Statut</label>
                        <select name="status" class="form-select">
                            <option value="DRAFT" {{ job_offre.status == 'DRAFT' ? 'selected' }}>Brouillon (DRAFT)</option>
                            <option value="PUBLISHED" {{ job_offre.status == 'PUBLISHED' ? 'selected' }}>Publiée (PUBLISHED)</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Avantages sociaux</label>
                        <div class="border rounded-3 p-3" id="tagsContainer" style="min-height: 56px; cursor: text;" onclick="document.getElementById('tagInput').focus()">
                            <div id="tagsList" class="d-flex flex-wrap gap-2 mb-2"></div>
                            <input type="text" id="tagInput" class="border-0 outline-0 p-0 bg-transparent" placeholder="Ajouter un avantage + Entrée" style="outline:none; width: 200px;">
                        </div>
                        <input type="hidden" name="advantages" id="advantagesHidden" value="{{ job_offre.advantages }}">
                        <div class="small text-secondary mt-1">Appuyez sur <kbd>Entrée</kbd> ou <kbd>,</kbd> pour ajouter chaque avantage. Cliquez sur un tag pour le supprimer.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Description détaillée <span class="text-danger">*</span></label>
                        <textarea name="description" class="form-control" rows="8" minlength="20" maxlength="5000" required>{{ job_offre.description }}</textarea>
                        <div class="invalid-feedback">La description doit contenir entre 20 et 5000 caractères.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-6">
                        <a href="{{ path('app_job_offre_index') }}" class="btn btn-light">Annuler</a>
                        <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    const tagInput = document.getElementById('tagInput');
    const tagsList = document.getElementById('tagsList');
    const hiddenInput = document.getElementById('advantagesHidden');
    // Pre-load existing tags
    let tags = hiddenInput.value ? hiddenInput.value.split(',').map(t => t.trim()).filter(Boolean) : [];

    function renderTags() {
        tagsList.innerHTML = '';
        tags.forEach((tag, i) => {
            const chip = document.createElement('span');
            chip.className = 'badge bg-primary-subtle text-primary-emphasis d-inline-flex align-items-center gap-1 px-3 py-2';
            chip.style.cursor = 'pointer';
            chip.innerHTML = `${tag} <i class="ti ti-x" style="font-size:0.7rem;"></i>`;
            chip.addEventListener('click', () => { tags.splice(i, 1); renderTags(); });
            tagsList.appendChild(chip);
        });
        hiddenInput.value = tags.join(',');
    }

    function addTag(value) {
        const cleaned = value.trim().replace(/,$/, '');
        if (cleaned && !tags.includes(cleaned)) {
            tags.push(cleaned);
            renderTags();
        }
        tagInput.value = '';
    }

    tagInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ',') {
            e.preventDefault();
            addTag(this.value);
        } else if (e.key === 'Backspace' && !this.value && tags.length) {
            tags.pop();
            renderTags();
        }
    });

    document.querySelectorAll('.suggestion-tag').forEach(el => {
        el.addEventListener('click', () => addTag(el.textContent.trim()));
    });

    // Render pre-loaded tags on page load
    renderTags();

    // Date validation
    const pubDateInput = document.getElementById('publishedAt');
    const expDateInput = document.getElementById('expiresAt');
    const form = document.querySelector('form');

    function checkDates() {
        if (expDateInput.value && pubDateInput.value && expDateInput.value <= pubDateInput.value) {
            expDateInput.setCustomValidity('La date d\'expiration doit être après la publication.');
            expDateInput.classList.add('is-invalid');
        } else {
            expDateInput.setCustomValidity('');
            expDateInput.classList.remove('is-invalid');
        }
    }

    pubDateInput.addEventListener('change', checkDates);
    expDateInput.addEventListener('change', checkDates);
    
    // Add bootstrap validation class on submit
    form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
})();
</script>
{% endblock %}
