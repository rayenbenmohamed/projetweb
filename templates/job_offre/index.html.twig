{% extends 'layout/admin.html.twig' %}

{% block title %}Offres d'emploi | SyfonuRH{% endblock %}
{% block page_title %}Toutes les offres d'emploi{% endblock %}

{% block content %}

<div class="row g-6 mt-2">
    <div class="col-12">
        <div class="card h-100">
            <div class="card-header border-bottom-0 d-md-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-0">Offres disponibles</h5>
                    <small class="text-secondary">Toutes les offres publiées — postulez directement depuis cette liste.</small>
                </div>
                {% if app.user %}
                <a href="{{ path('app_job_offre_my') }}" class="btn btn-outline-primary btn-sm mt-2 mt-md-0">
                    <i class="ti ti-briefcase me-1"></i> Gérer mes offres
                </a>
                {% endif %}
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>Titre</th>
                            <th>Recruteur</th>
                            <th>Lieu</th>
                            <th>Salaire</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for offre in job_offres %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-shape icon-md rounded-3 bg-primary-subtle text-primary">
                                        <i class="ti ti-briefcase fs-4"></i>
                                    </div>
                                    <div>
                                        <a href="{{ path('app_job_offre_show', {id: offre.id}) }}" class="text-body text-decoration-none">
                                            <h6 class="mb-0">{{ offre.title }}</h6>
                                        </a>
                                        <span class="small text-secondary">{{ offre.location ?: '—' }}</span>
                                    </div>
                                </div>
                            </td>
                            <td>{{ offre.user ? (offre.user.firstName ~ ' ' ~ offre.user.lastName) : '—' }}</td>
                            <td>{{ offre.location ?: '—' }}</td>
                            <td>{{ offre.salary ? offre.salary|number_format(0, ',', ' ') ~ ' €' : '—' }}</td>
                            <td>{{ offre.employmentType ?: '—' }}</td>
                            <td>
                                {% set statusClass = offre.status == 'PUBLISHED' ? 'success' : (offre.status == 'DRAFT' ? 'warning' : 'secondary') %}
                                {% set statusLabel = offre.status == 'PUBLISHED' ? 'Publiée' : (offre.status == 'DRAFT' ? 'Brouillon' : offre.status) %}
                                <span class="badge bg-{{ statusClass }}-subtle text-{{ statusClass }}-emphasis">{{ statusLabel }}</span>
                                
                                {% if user_applications[offre.id] is defined %}
                                    <span class="badge bg-info-subtle text-info-emphasis ms-1"><i class="ti ti-check me-1"></i>Postulé</span>
                                {% endif %}
                            </td>
                            <td>{{ offre.createdAt|date('d/m/Y') }}</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    {# Voir le détail #}
                                    <a href="{{ path('app_job_offre_show', {id: offre.id}) }}"
                                       class="btn btn-icon btn-sm btn-outline-info rounded-circle"
                                       title="Voir les détails">
                                        <i class="ti ti-eye"></i>
                                    </a>
                                    {# Postuler #}
                                    {% if app.user %}
                                        {% if app.user != offre.user %}
                                            {% if user_applications[offre.id] is defined %}
                                                {% set user_app = user_applications[offre.id] %}
                                                <form method="post" action="{{ path('app_job_application_delete', {id: user_app.id}) }}" 
                                                      onsubmit="return confirm('Voulez-vous vraiment retirer votre candidature ?');" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user_app.id) }}">
                                                    <button type="submit" class="btn btn-icon btn-sm btn-outline-danger rounded-circle" title="Retirer ma candidature">
                                                        <i class="ti ti-trash"></i>
                                                    </button>
                                                </form>
                                            {% else %}
                                                <a href="{{ path('app_job_application_new', {id: offre.id}) }}"
                                                   class="btn btn-icon btn-sm btn-outline-success rounded-circle"
                                                   title="Postuler">
                                                    <i class="ti ti-send"></i>
                                                </a>
                                            {% endif %}
                                        {% endif %}
                                    {% else %}
                                        <a href="{{ path('app_login') }}"
                                           class="btn btn-icon btn-sm btn-outline-secondary rounded-circle"
                                           title="Se connecter pour postuler">
                                            <i class="ti ti-login"></i>
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-8">
                                <i class="ti ti-briefcase-off fs-1 text-secondary d-block mb-2"></i>
                                <p class="text-secondary mb-0">Aucune offre disponible pour le moment.</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
