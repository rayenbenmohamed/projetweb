{% extends 'layout/admin.html.twig' %}

{% block title %}Offres d'emploi | SyfonuRH{% endblock %}
{% block page_title %}Toutes les offres d'emploi{% endblock %}

{% block stylesheets %}
{# Leaflet CSS #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
/* ── Stat cards ──────────────────────────────── */
.stat-card{border:none;border-radius:14px;padding:1.1rem 1.4rem;display:flex;align-items:center;gap:.9rem;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:transform .2s,box-shadow .2s}
.stat-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.10)}
.stat-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
.stat-value{font-size:1.6rem;font-weight:700;line-height:1}
.stat-label{font-size:.75rem;color:#8a95a3;margin-top:2px}

/* ── Type pills ───────────────────────────────── */
.type-pills{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.75rem}
.type-pill{font-size:.73rem;font-weight:600;padding:.24rem .65rem;border-radius:20px;cursor:pointer;border:1.5px solid #e5e7eb;background:#f3f4f6;color:#374151;transition:all .15s;user-select:none}
.type-pill.all-pill{background:#eef0ff;color:#5c67f5;border-color:#c7cbf5}
.type-pill.active,.type-pill:hover{background:#5c67f5!important;color:#fff!important;border-color:#5c67f5!important}

/* ── Filter bar ───────────────────────────────── */
.filter-bar{background:#fff;border-radius:14px;padding:1rem 1.2rem;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.filter-bar .form-control,.filter-bar .form-select{border-radius:9px;font-size:.83rem;border:1.5px solid #e4e9f0;transition:border-color .2s,box-shadow .2s;height:36px;padding:.3rem .75rem}
.filter-bar .form-control:focus,.filter-bar .form-select:focus{border-color:#5c67f5;box-shadow:0 0 0 3px rgba(92,103,245,.12)}
.btn-filter-reset{border-radius:9px;height:36px;width:36px;padding:0;display:flex;align-items:center;justify-content:center;border:1.5px solid #e4e9f0;background:#f7f8fc;color:#5c6782;transition:all .2s;flex-shrink:0}
.btn-filter-reset:hover{background:#eceff8;border-color:#c8cfe8}
.btn-map-toggle{border-radius:9px;height:36px;padding:0 .9rem;display:flex;align-items:center;gap:.35rem;font-size:.8rem;font-weight:600;border:1.5px solid #5c67f5;background:#eef0ff;color:#5c67f5;transition:all .2s;white-space:nowrap;cursor:pointer}
.btn-map-toggle:hover,.btn-map-toggle.active{background:#5c67f5;color:#fff}

/* ── Split layout ─────────────────────────────── */
.split-wrapper{display:flex;gap:1rem;align-items:flex-start}
.split-cards{flex:1;min-width:0}
.split-map{width:420px;flex-shrink:0;position:sticky;top:80px}
@media(max-width:992px){.split-wrapper{flex-direction:column}.split-map{width:100%;position:static}}

/* ── Map container ────────────────────────────── */
.map-panel{background:#fff;border-radius:14px;border:1.5px solid #eef0f8;box-shadow:0 2px 12px rgba(0,0,0,.06);overflow:hidden;display:none}
.map-panel.visible{display:block}
.map-panel-header{padding:.75rem 1rem;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between}
.map-panel-header span{font-size:.82rem;font-weight:600;color:#374151}
#mapContainer{height:520px;width:100%}

/* Leaflet popup customization */
.leaflet-popup-content-wrapper{border-radius:12px!important;box-shadow:0 4px 24px rgba(0,0,0,.12)!important;padding:0!important}
.leaflet-popup-content{margin:0!important;width:220px!important}
.map-popup{padding:.9rem 1rem}
.map-popup .mp-title{font-weight:700;font-size:.9rem;color:#1e2343;margin-bottom:.3rem}
.map-popup .mp-meta{font-size:.75rem;color:#6b7280;display:flex;flex-direction:column;gap:.15rem}
.map-popup .mp-meta span{display:flex;align-items:center;gap:.25rem}
.map-popup .mp-badges{display:flex;gap:.3rem;flex-wrap:wrap;margin:.5rem 0}
.map-popup .mp-salary{font-size:.9rem;font-weight:700;color:#5c67f5;margin-bottom:.5rem}
.map-popup .mp-btn{display:inline-flex;align-items:center;gap:.25rem;font-size:.75rem;font-weight:600;padding:.3rem .75rem;border-radius:8px;background:#5c67f5;color:#fff;text-decoration:none;transition:opacity .2s}
.map-popup .mp-btn:hover{opacity:.85;color:#fff}
.ibadge{font-size:.68rem;font-weight:600;padding:.2rem .55rem;border-radius:20px;white-space:nowrap;display:inline-block}
.ibadge-published{background:#d1fae5;color:#065f46}
.ibadge-draft{background:#fef3c7;color:#92400e}
.ibadge-type{background:#eef0ff;color:#5c67f5}
.ibadge-applied{background:#dbeafe;color:#1e40af}

/* Map geocoding loader */
.map-loader{position:absolute;inset:0;background:rgba(255,255,255,.7);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;z-index:800;border-radius:14px;font-size:.82rem;color:#5c67f5;font-weight:600}
.map-loader .spinner{width:28px;height:28px;border:3px solid #eef0ff;border-top-color:#5c67f5;border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.map-count{font-size:.75rem;color:#8a95a3;margin-top:.25rem}

/* ── Scrollable feed ──────────────────────────── */
.feed-wrapper{height:calc(100vh - 390px);min-height:420px;overflow-y:auto;padding-right:4px}
.feed-wrapper::-webkit-scrollbar{width:5px}
.feed-wrapper::-webkit-scrollbar-track{background:transparent}
.feed-wrapper::-webkit-scrollbar-thumb{background:#dde0f0;border-radius:10px}
.feed-wrapper::-webkit-scrollbar-thumb:hover{background:#b0b8d8}

/* ── Job card ─────────────────────────────────── */
.jcard{background:#fff;border-radius:14px;border:1.5px solid #eef0f8;padding:1rem 1.2rem;margin-bottom:.75rem;display:flex;flex-direction:row;align-items:flex-start;gap:1rem;transition:transform .18s,box-shadow .18s,border-color .18s;box-shadow:0 1px 4px rgba(0,0,0,.04);position:relative;cursor:pointer;overflow:visible}
.jcard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,#5c67f5,#a78bfa);border-radius:3px 0 0 3px;opacity:0;transition:opacity .2s}
.jcard:hover,.jcard.map-highlight{transform:translateX(4px);box-shadow:0 4px 20px rgba(0,0,0,.09);border-color:#d0d5f5}
.jcard:hover::before,.jcard.map-highlight::before{opacity:1}
.jcard.map-highlight{border-color:#5c67f5;box-shadow:0 0 0 2px rgba(92,103,245,.25)}
.jcard-logo{width:62px;height:62px;border-radius:14px;background:linear-gradient(135deg,#eef0ff,#e8f0ff);display:flex;align-items:center;justify-content:center;color:#5c67f5;font-size:1.6rem;flex-shrink:0;margin-top:2px;box-shadow:0 2px 8px rgba(92,103,245,.13);overflow:hidden;border:2px solid #e8eaff}
.jcard-logo img{width:100%;height:100%;object-fit:cover;border-radius:12px}
.jcard-inner{flex:1;min-width:0}
.jcard-heading{font-weight:700;font-size:.95rem;color:#1e2343}
.jcard-heading a{color:inherit;text-decoration:none}
.jcard-heading a:hover{color:#5c67f5}
.jcard-price{font-size:.92rem;font-weight:700;color:#5c67f5;white-space:nowrap;flex-shrink:0}
.jcard-meta{font-size:.78rem;color:#6b7280;display:flex;flex-wrap:wrap;gap:.3rem .8rem;margin-top:.25rem}
.jcard-meta span{display:inline-flex;align-items:center;gap:.2rem}
.jcard-badges{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.35rem}
.rec-chip{display:inline-flex;align-items:center;gap:.35rem;background:#f3f4f6;border-radius:20px;padding:.15rem .5rem .15rem .25rem;font-size:.72rem;color:#374151;font-weight:500;margin-top:.25rem}
.rec-av{width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,#5c67f5,#a78bfa);color:#fff;font-size:.6rem;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.jcard-actions{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.5rem;padding-top:.5rem;border-top:1px solid #f3f4f6}
.jbtn{font-size:.75rem;font-weight:600;padding:.3rem .75rem;border-radius:9px;border:1.5px solid transparent;display:inline-flex;align-items:center;gap:.25rem;transition:all .18s;text-decoration:none;cursor:pointer;background:transparent;white-space:nowrap}
.jbtn-view  {border-color:#06b6d4;color:#06b6d4;background:#f0fffe}
.jbtn-apply {border-color:#10b981;color:#10b981;background:#f0fdf4}
.jbtn-cancel{border-color:#ef4444;color:#ef4444;background:#fff5f5}
.jbtn-login {border-color:#6b7280;color:#6b7280;background:#f9fafb}
.jbtn-trans {border-color:#5c67f5;color:#5c67f5;background:#f5f6ff;position:relative;overflow:hidden}
.jbtn-trans:hover{background:#5c67f5;color:#fff}
.jbtn-trans.loading {pointer-events:none;opacity:.7}
.jbtn-trans.loading::after {content:"";position:absolute;bottom:0;left:0;height:2px;width:100%;background:#5c67f5;animation:load 1s infinite linear}
@keyframes load {0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.jcard-title.translated {color:#059669!important;transition:all .3s}
.jcard:hover{filter:none!important}
.trans-dropdown-menu {z-index:1060;border:none;box-shadow:0 10px 30px rgba(0,0,0,.15);border-radius:12px;padding:.5rem;min-width:140px;background:rgba(255,255,255,.98);backdrop-filter:blur(10px)}
.trans-dropdown-item {border-radius:8px;font-size:.8rem;font-weight:600;padding:.4rem .8rem;display:flex;align-items:center;gap:.5rem;color:#4b5563;transition:all .2s}
.trans-dropdown-item:hover {background:#f5f6ff;color:#5c67f5}
.trans-dropdown-item img {width:18px;border-radius:3px}
.rotate { animation: spin 1s infinite linear; }
@keyframes spin { 100% { transform: rotate(360deg); } }

/* Results */
.results-bar{font-size:.8rem;color:#8a95a3;display:flex;align-items:center;gap:.4rem}

/* Empty */
.empty-feed{text-align:center;padding:3.5rem 2rem;color:#9ca3af}
.empty-feed i{font-size:2.5rem;margin-bottom:.6rem;display:block}
/* ── Chat AI Widget ───────────────────────────── */
.ai-chat-widget { position: fixed; bottom: 25px; right: 25px; z-index: 2000; font-family: 'Inter', sans-serif; }
.ai-chat-bubble { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, #5c67f5, #7c3aed); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; cursor: pointer; box-shadow: 0 4px 15px rgba(92, 103, 245, 0.4); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; }
.ai-chat-bubble:hover { transform: scale(1.1) rotate(10deg); }
.ai-chat-bubble .ai-pulse { position: absolute; inset: -4px; border: 2px solid #5c67f5; border-radius: 50%; opacity: 0; animation: pulse 2s infinite; }
@keyframes pulse { 0% { transform: scale(0.95); opacity: 0.5; } 100% { transform: scale(1.2); opacity: 0; } }

.ai-chat-window { position: absolute; bottom: 70px; right: 0; width: 350px; height: 480px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); display: flex; flex-direction: column; transform: translateY(20px); opacity: 0; pointer-events: none; transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05); }
.ai-chat-window.active { transform: translateY(0); opacity: 1; pointer-events: auto; }
.ai-chat-header { padding: 1.2rem; background: linear-gradient(135deg, #5c67f5, #7c3aed); color: #fff; border-radius: 20px 20px 0 0; display: flex; align-items: center; gap: 10px; }
.ai-chat-header i { font-size: 1.4rem; }
.ai-chat-header-title { font-weight: 700; font-size: 0.95rem; }
.ai-chat-messages { flex: 1; overflow-y: auto; padding: 1.2rem; display: flex; flex-direction: column; gap: 12px; scroll-behavior: smooth; }
.ai-chat-messages::-webkit-scrollbar { width: 4px; }
.ai-chat-messages::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }

.msg { max-width: 85%; padding: 10px 14px; border-radius: 15px; font-size: 0.85rem; line-height: 1.4; position: relative; animation: msgIn 0.3s ease-out; }
@keyframes msgIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
.msg-ai { background: #f3f4f6; color: #1f2937; align-self: flex-start; border-bottom-left-radius: 4px; }
.msg-user { background: #5c67f5; color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; box-shadow: 0 4px 10px rgba(92, 103, 245, 0.2); }
.msg-loading { display: flex; gap: 4px; padding: 12px 14px; }
.msg-loading span { width: 6px; height: 6px; background: #9ca3af; border-radius: 50%; animation: loadingDot 1.4s infinite; }
.msg-loading span:nth-child(2) { animation-delay: 0.2s; }
.msg-loading span:nth-child(3) { animation-delay: 0.4s; }
@keyframes loadingDot { 0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; } 40% { transform: scale(1); opacity: 1; } }

.ai-chat-input-area { padding: 1rem; border-top: 1px solid #f1f5f9; display: flex; gap: 8px; }
.ai-chat-input { flex: 1; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 8px 12px; font-size: 0.85rem; transition: border-color 0.2s; outline: none; }
.ai-chat-input:focus { border-color: #5c67f5; }
.ai-chat-send { width: 38px; height: 38px; border-radius: 10px; background: #eef0ff; color: #5c67f5; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
.ai-chat-send:hover { background: #5c67f5; color: #fff; }

@media (max-width: 576px) {
    .ai-chat-window { width: calc(100vw - 40px); height: 400px; right: -10px; }
}
</style>
{% endblock %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────── #}
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0 fw-bold">Offres disponibles</h4>
        <small class="text-secondary">Toutes les offres publiées — postulez directement.</small>
    </div>
    {% if app.user %}
    <a href="{{ path('app_job_offre_my') }}" class="btn btn-outline-primary btn-sm rounded-3">
        <i class="ti ti-briefcase me-1"></i>Gérer mes offres
    </a>
    {% endif %}
</div>

{# ── Stats ──────────────────────────────────────────────────────────── #}
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#eef0ff,#f3f4ff)">
            <div class="stat-icon" style="background:rgba(92,103,245,.15);color:#5c67f5"><i class="ti ti-briefcase"></i></div>
            <div><div class="stat-value" style="color:#5c67f5">{{ stats.total }}</div><div class="stat-label">Total offres</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#d1fae5,#ecfdf5)">
            <div class="stat-icon" style="background:rgba(16,185,129,.15);color:#059669"><i class="ti ti-circle-check"></i></div>
            <div><div class="stat-value" style="color:#059669">{{ stats.published }}</div><div class="stat-label">Publiées</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#ede9fe,#f5f3ff)">
            <div class="stat-icon" style="background:rgba(139,92,246,.15);color:#7c3aed"><i class="ti ti-users"></i></div>
            <div><div class="stat-value" style="color:#7c3aed">{{ stats.applications }}</div><div class="stat-label">Candidatures</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#fce7f3,#fdf2f8)">
            <div class="stat-icon" style="background:rgba(236,72,153,.15);color:#db2777"><i class="ti ti-tag"></i></div>
            <div><div class="stat-value" style="color:#db2777">{{ stats.types|length }}</div><div class="stat-label">Types de contrat</div></div>
        </div>
    </div>
</div>

{# ── Type pills ─────────────────────────────────────────────────────── #}
{% if stats.types|length > 0 %}
<div class="type-pills" id="typePills">
    <span class="type-pill all-pill active" data-type="">Tous</span>
    {% for type, count in stats.types %}
    <span class="type-pill" data-type="{{ type|lower }}">{{ type }} <span style="opacity:.65">({{ count }})</span></span>
    {% endfor %}
</div>
{% endif %}

{# ── Filter bar ─────────────────────────────────────────────────────── #}
<div class="filter-bar mb-2">
    <div class="row g-2 align-items-center">
        <div class="col-12 col-md-3">
            <input type="text" id="fsQ" class="form-control" placeholder="🔍  Titre, ville, compétences…" value="{{ filters.q }}">
        </div>
        <div class="col-6 col-md-2">
            <input type="text" id="fsLoc" class="form-control" placeholder="📍 Ville / Région" value="{{ filters.location }}">
        </div>
        <div class="col-6 col-md-2">
            <select id="fsType" class="form-select">
                <option value="">Tous les types</option>
                <option value="cdi"        {% if filters.type == 'CDI' %}selected{% endif %}>CDI</option>
                <option value="cdd"        {% if filters.type == 'CDD' %}selected{% endif %}>CDD</option>
                <option value="freelance"  {% if filters.type == 'Freelance' %}selected{% endif %}>Freelance</option>
                <option value="stage"      {% if filters.type == 'Stage' %}selected{% endif %}>Stage</option>
                <option value="alternance" {% if filters.type == 'Alternance' %}selected{% endif %}>Alternance</option>
            </select>
        </div>
        <div class="col-4 col-md-1">
            <input type="number" id="fsSalMin" class="form-control" placeholder="Min €" value="{{ filters.salary_min }}" min="0">
        </div>
        <div class="col-4 col-md-1">
            <input type="number" id="fsSalMax" class="form-control" placeholder="Max €" value="{{ filters.salary_max }}" min="0">
        </div>
        <div class="col-4 col-md-auto d-flex gap-2 align-items-center">
            <button id="btnReset" class="btn-filter-reset" title="Réinitialiser">
                <i class="ti ti-refresh" style="font-size:.95rem"></i>
            </button>
            <button id="btnMapToggle" class="btn-map-toggle" title="Afficher la carte">
                <i class="ti ti-map-pin"></i> Carte
            </button>
        </div>
        <div class="col-12 col-md-auto ms-md-auto">
            <span class="results-bar" id="resCount">
                <span id="resNum">{{ job_offres|length }}</span>&nbsp;offre{{ job_offres|length != 1 ? 's' : '' }} trouvée{{ job_offres|length != 1 ? 's' : '' }}
            </span>
        </div>
    </div>
</div>

{# ── Split layout: cards + map ──────────────────────────────────────── #}
<div class="split-wrapper">

    {# Left: Cards #}
    <div class="split-cards">
        {% if job_offres|length == 0 %}
        <div class="empty-feed">
            <i class="ti ti-mood-empty text-secondary"></i>
            <p class="fw-semibold mb-1">Aucune offre disponible</p>
            <p class="small text-secondary">Revenez plus tard !</p>
        </div>
        {% else %}
        <div class="feed-wrapper" id="feedWrapper">

            {% for offre in job_offres %}
            {% set dStatus = offre.displayStatus %}
            {% set statusCls = dStatus == 'PUBLISHED' ? 'published' : (dStatus == 'DRAFT' ? 'draft' : 'secondary') %}
            {% set statusLbl = dStatus == 'PUBLISHED' ? 'Publiée' : (dStatus == 'DRAFT' ? 'Brouillon' : 'Archivée') %}
            {% set isApplied = user_applications[offre.id] is defined %}

            <div class="jcard"
                 id="card-{{ offre.id }}"
                 data-id="{{ offre.id }}"
                 data-q="{{ (offre.title ~ ' ' ~ offre.location)|lower }}"
                 data-loc="{{ offre.location|lower }}"
                 data-type="{{ offre.employmentType|lower }}"
                 data-salary="{{ offre.salary }}"
                 data-location-raw="{{ offre.location }}">

                <div class="jcard-logo">
                    {% if offre.entreprise and offre.entreprise.logo %}
                        <img src="{{ offre.entreprise.logo }}" alt="{{ offre.entreprise.name }}">
                    {% elseif offre.companyLogo %}
                        <img src="{{ offre.companyLogo }}" alt="Logo">
                    {% else %}
                        <i class="ti ti-building-factory-2"></i>
                    {% endif %}
                </div>

                <div class="jcard-inner">
                    <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                        <div class="jcard-heading">
                            <a href="{{ path('app_job_offre_show', {id: offre.id}) }}">{{ offre.title }}</a>
                        </div>
                        {% if offre.salary %}
                        <span class="jcard-price">{{ offre.salary|number_format(0, ',', ' ') }} €{% if offre.isSalaryNegotiable %}<small class="fw-normal text-secondary"> nég.</small>{% endif %}</span>
                        {% endif %}
                    </div>

                    {% if offre.entreprise %}
                        <div><span class="rec-chip"><i class="ti ti-building me-1 opacity-50"></i>{{ offre.entreprise.name }}</span></div>
                    {% elseif offre.user %}
                        {% set initials = (offre.user.firstName|slice(0,1) ~ offre.user.lastName|slice(0,1))|upper %}
                        <div><span class="rec-chip"><span class="rec-av">{{ initials }}</span>{{ offre.user.firstName }} {{ offre.user.lastName }}</span></div>
                    {% endif %}

                    <div class="jcard-meta">
                        {% if offre.location %}<span><i class="ti ti-map-pin"></i>{{ offre.location }}</span>{% endif %}
                        <span><i class="ti ti-calendar"></i>{{ offre.createdAt|date('d/m/Y') }}</span>
                        <span><i class="ti ti-users"></i>{{ offre.jobApplications|length }} candidature{{ offre.jobApplications|length != 1 ? 's' : '' }}</span>
                    </div>

                    <div class="jcard-badges">
                        <span class="ibadge ibadge-{{ statusCls }}">{{ statusLbl }}</span>
                        {% if offre.employmentType %}<span class="ibadge ibadge-type">{{ offre.employmentType }}</span>{% endif %}
                        {% if isApplied %}<span class="ibadge ibadge-applied"><i class="ti ti-check" style="font-size:.65rem"></i> Postulé</span>{% endif %}
                    </div>

                    {# Linked Avantages (Table) #}
                    {% if offre.linkedAvantages|length > 0 %}
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        {% for av in offre.linkedAvantages %}
                        <span class="badge bg-light text-primary border d-inline-flex align-items-center gap-1 shadow-sm" style="font-size: 0.65rem; font-weight: 500; border-radius: 6px; padding: 0.2rem 0.5rem;">
                            {% if av.icon %}<i class="ti {{ av.icon }}"></i>{% endif %}
                            {{ av.name }}
                        </span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Legacy Advantages (Text) #}
                    {% if offre.advantages %}
                    <div class="small text-secondary mt-1 d-flex align-items-center gap-1" style="font-size: 0.72rem;">
                        <i class="ti ti-plus" style="font-size: 0.65rem;"></i> {{ offre.advantages }}
                    </div>
                    {% endif %}

                    <div class="jcard-actions">
                        <a href="{{ path('app_job_offre_show', {id: offre.id}) }}" class="jbtn jbtn-view"><i class="ti ti-eye"></i>Voir</a>
                        {% if app.user %}
                            {% if app.user != offre.user %}
                                {% if isApplied %}
                                    {% set user_app = user_applications[offre.id] %}
                                    <form method="post" action="{{ path('app_job_application_delete', {id: user_app.id}) }}"
                                          onsubmit="return confirm('Retirer votre candidature ?');" style="display:contents">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user_app.id) }}">
                                        <button type="submit" class="jbtn jbtn-cancel"><i class="ti ti-x"></i>Retirer</button>
                                    </form>
                                {% else %}
                                    <a href="{{ path('app_job_application_new', {id: offre.id}) }}" class="jbtn jbtn-apply"><i class="ti ti-send"></i>Postuler</a>
                                {% endif %}
                            {% endif %}
                        {% else %}
                            <a href="{{ path('app_login') }}" class="jbtn jbtn-login"><i class="ti ti-login"></i>Se connecter</a>
                        {% endif %}
                        
                        {# Dropdown Traduction #}
                        <div class="dropdown">
                            <button type="button" class="jbtn jbtn-trans dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-bs-offset="0,10">
                                <i class="ti ti-language"></i> Traduire
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end trans-dropdown-menu">
                                <li><a class="dropdown-item trans-dropdown-item" href="javascript:void(0)" onclick="translateCard(this, {{ offre.id }}, 'en')">
                                    <img src="https://flagcdn.com/w20/gb.png" alt="EN"> English</a>
                                </li>
                                <li><a class="dropdown-item trans-dropdown-item" href="javascript:void(0)" onclick="translateCard(this, {{ offre.id }}, 'ar')">
                                    <img src="https://flagcdn.com/w20/sa.png" alt="AR"> Arabe</a>
                                </li>
                                <li><a class="dropdown-item trans-dropdown-item" href="javascript:void(0)" onclick="translateCard(this, {{ offre.id }}, 'es')">
                                    <img src="https://flagcdn.com/w20/es.png" alt="ES"> Espagnol</a>
                                </li>
                                <li><a class="dropdown-item trans-dropdown-item" href="javascript:void(0)" onclick="translateCard(this, {{ offre.id }}, 'de')">
                                    <img src="https://flagcdn.com/w20/de.png" alt="DE"> Allemand</a>
                                </li>
                                {# Option retour à l'original si déjà traduit #}
                                <li class="back-to-original d-none"><hr class="dropdown-divider"></li>
                                <li class="back-to-original d-none"><a class="dropdown-item trans-dropdown-item text-danger" href="javascript:void(0)" onclick="resetTranslation(this, {{ offre.id }})">
                                    <i class="ti ti-arrow-back-up"></i> Original</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}

            <div id="emptyMsg" class="empty-feed d-none">
                <i class="ti ti-search-off text-secondary"></i>
                <p class="fw-semibold mb-1">Aucun résultat</p>
                <p class="small text-secondary">Modifiez vos critères.</p>
            </div>
        </div>
        {% endif %}
    </div>

    {# Right: Map panel #}
    <div class="split-map" id="splitMap">
        <div class="map-panel" id="mapPanel">
            <div class="map-panel-header">
                <span><i class="ti ti-map-pin me-1" style="color:#5c67f5"></i>Carte des offres</span>
                <span class="map-count" id="mapCount">Géolocalisation en cours…</span>
            </div>
            <div style="position:relative">
                <div id="mapLoader" class="map-loader">
                    <div class="spinner"></div>
                    Géolocalisation des offres…
                </div>
                <div id="mapContainer"></div>
            </div>
        </div>
    </div>

</div>{# /split-wrapper #}

{# ── Chat AI Widget HTML ───────────────────────────────────────── #}
<div class="ai-chat-widget">
    <div class="ai-chat-bubble" id="aiChatBubble" title="Assistant AI">
        <div class="ai-pulse"></div>
        <i class="ti ti-robot"></i>
    </div>
    <div class="ai-chat-window" id="aiChatWindow">
        <div class="ai-chat-header">
            <i class="ti ti-bolt text-warning"></i>
            <div>
                <div class="ai-chat-header-title">SyfonuRH AI</div>
                <div style="font-size:0.7rem; opacity:0.8">Assistant de recherche intelligent</div>
            </div>
            <button type="button" class="btn-close btn-close-white ms-auto" style="font-size:0.7rem; box-shadow:none" id="aiChatClose"></button>
        </div>
        <div class="ai-chat-messages" id="aiChatMessages">
            <div class="msg msg-ai">
                Bonjour ! Je suis votre assistant AI. Dites-moi ce que vous recherchez ? (ex: "Offres CDI à Tunis", "Salaire > 2000DT")
            </div>
