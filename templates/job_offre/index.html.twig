{% extends 'layout/public.html.twig' %}

{% block title %}Offres d'emploi | SyfonuRH{% endblock %}

{% block content %}
<div class="row g-6 mt-2">
    <div class="col-12">
        <div class="card h-100">
            <div class="card-header border-bottom-0 d-md-flex align-items-center justify-content-between">
                <h5 class="mb-0">Liste des offres</h5>
                {% if is_granted('ROLE_RECRUTEUR') or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_job_offre_new') }}" class="btn btn-primary btn-sm">
                    <i class="ti ti-plus me-1"></i> Nouvelle offre
                </a>
                {% endif %}
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>Titre</th>
                            <th>Lieu</th>
                            <th>Salaire</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for offre in job_offres %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-shape icon-md rounded-3 bg-primary-subtle text-primary">
                                        <i class="ti ti-briefcase fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">{{ offre.title }}</h6>
                                        <span class="small text-secondary">{{ offre.user ? offre.user.firstName : '—' }}</span>
                                    </div>
                                </div>
                            </td>
                            <td>{{ offre.location }}</td>
                            <td>{{ offre.salary|number_format(0, ',', ' ') }} DT</td>
                            <td>{{ offre.employmentType }}</td>
                            <td>
                                <span class="badge bg-{{ offre.status == 'PUBLISHED' ? 'success' : 'warning' }}-subtle text-{{ offre.status == 'PUBLISHED' ? 'success' : 'warning' }}-emphasis">
                                    {{ offre.status|capitalize }}
                                </span>
                            </td>
                            <td>{{ offre.createdAt|date('d/m/Y') }}</td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-ghost btn-icon btn-sm rounded-circle" type="button" data-bs-toggle="dropdown">
                                        <i class="ti ti-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="{{ path('app_job_offre_show', {id: offre.id}) }}">Voir l'offre</a></li>
                                        {% if is_granted('ROLE_CANDIDAT') %}
                                        <li><a class="dropdown-item" href="{{ path('app_job_application_new', {id: offre.id}) }}">Postuler</a></li>
                                        {% endif %}
                                        {% if is_granted('ROLE_RECRUTEUR') or is_granted('ROLE_ADMIN') %}
                                        <li><a class="dropdown-item" href="{{ path('app_job_offre_edit', {id: offre.id}) }}">Modifier</a></li>
                                        <li>
                                            <form method="post" action="{{ path('app_job_offre_delete', {id: offre.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ offre.id) }}">
                                                <button class="dropdown-item text-danger">Supprimer</button>
                                            </form>
                                        </li>
                                        {% endif %}
                                    </ul>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-8">
                                <p class="text-secondary mb-0">Aucune offre trouvée.</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
