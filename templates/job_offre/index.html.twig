{# Raw offer data for JS geocoding #}
<script id="offersData" type="application/json">
[
{% for offre in job_offres %}
{
    "id": {{ offre.id }},
    "title": {{ offre.title|json_encode|raw }},
    "location": {{ (offre.location ?: '')|json_encode|raw }},
    "salary": {{ offre.salary ? offre.salary : 'null' }},
    "salaryNeg": {{ offre.isSalaryNegotiable ? 'true' : 'false' }},
    "type": {{ (offre.employmentType ?: '')|json_encode|raw }},
    "status": {{ offre.status|json_encode|raw }},
    "applications": {{ offre.jobApplications|length }},
    "url": {{ path('app_job_offre_show', {id: offre.id})|json_encode|raw }}
}{{ not loop.last ? ',' : '' }}
{% endfor %}
]
</script>

{% endblock %}

{% block javascripts %}
{# Leaflet JS #}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
(function () {
'use strict';

/* ─── Filter logic ────────────────────────────────────────────── */
var cards    = document.querySelectorAll('#feedWrapper .jcard');
var emptyMsg = document.getElementById('emptyMsg');
var resCount = document.getElementById('resCount');
var fsQ      = document.getElementById('fsQ');
var fsLoc    = document.getElementById('fsLoc');
var fsType   = document.getElementById('fsType');
var fsSalMin = document.getElementById('fsSalMin');
var fsSalMax = document.getElementById('fsSalMax');
var btnReset = document.getElementById('btnReset');
var pills    = document.querySelectorAll('#typePills .type-pill');

// Track currently visible offer IDs
var visibleIds = new Set();

function filterCards() {
    var q      = fsQ     ? fsQ.value.toLowerCase().trim()          : '';
    var loc    = fsLoc   ? fsLoc.value.toLowerCase().trim()        : '';
    var type   = fsType  ? fsType.value.toLowerCase()              : '';
    var salMin = fsSalMin ? parseFloat(fsSalMin.value) || 0        : 0;
    var salMax = fsSalMax ? parseFloat(fsSalMax.value) || Infinity : Infinity;
    var hasF   = !!(q || loc || type || (fsSalMin && fsSalMin.value) || (fsSalMax && fsSalMax.value));

    visibleIds.clear();
    var visible = 0;

    cards.forEach(function (card) {
        var cq   = card.dataset.q    || '';
        var cloc = card.dataset.loc  || '';
        var ctyp = card.dataset.type || '';
        var csal = parseFloat(card.dataset.salary) || 0;
        var ok   = (!q   || cq.includes(q))
                && (!loc  || cloc.includes(loc))
                && (!type || ctyp === type)
                && (csal === 0 || (csal >= salMin && csal <= salMax));
        card.style.display = ok ? '' : 'none';
        if (ok) { visible++; visibleIds.add(+card.dataset.id); }
    });

    if (emptyMsg) emptyMsg.classList.toggle('d-none', visible > 0);
    if (resCount) {
        resCount.innerHTML = '<span id="resNum">' + visible + '</span>&nbsp;offre' + (visible !== 1 ? 's' : '') +
            ' trouvée' + (visible !== 1 ? 's' : '') +
            (hasF ? ' <span style="width:7px;height:7px;border-radius:50%;background:#5c67f5;display:inline-block;vertical-align:middle;margin-left:3px"></span>' : '');
    }

    // Sync map markers
    updateMapMarkers();
}

[fsQ, fsLoc, fsSalMin, fsSalMax].forEach(function (el) { el && el.addEventListener('input', filterCards); });
[fsType].forEach(function (el) { el && el.addEventListener('change', filterCards); });

pills.forEach(function (pill) {
    if (fsType && pill.dataset.type && pill.dataset.type === fsType.value.toLowerCase()) {
        pills.forEach(function (p) { p.classList.remove('active'); });
        pill.classList.add('active');
    }
    pill.addEventListener('click', function () {
        pills.forEach(function (p) { p.classList.remove('active'); });
        this.classList.add('active');
        if (fsType) { fsType.value = this.dataset.type; }
        filterCards();
    });
});

if (btnReset) {
    btnReset.addEventListener('click', function () {
        if (fsQ)      fsQ.value      = '';
        if (fsLoc)    fsLoc.value    = '';
        if (fsType)   fsType.value   = '';
        if (fsSalMin) fsSalMin.value = '';
        if (fsSalMax) fsSalMax.value = '';
        pills.forEach(function (p) { p.classList.toggle('active', p.dataset.type === ''); });
        filterCards();
    });
}

/* ─── Map toggle button ──────────────────────────────────────── */
var btnMapToggle = document.getElementById('btnMapToggle');
var mapPanel     = document.getElementById('mapPanel');
var mapInitialized = false;

if (btnMapToggle) {
    btnMapToggle.addEventListener('click', function () {
        this.classList.toggle('active');
        if (mapPanel.classList.toggle('visible')) {
            if (!mapInitialized) {
                mapInitialized = true;
                initMap();
            } else {
                map.invalidateSize();
            }
        }
    });
}

/* ─── Leaflet map ────────────────────────────────────────────── */
var map = null;
var markerMap = {};   // id → {marker, lat, lng}
var offersData = [];

try {
    offersData = JSON.parse(document.getElementById('offersData').textContent || '[]');
} catch(e) { offersData = []; }

// Custom SVG marker
function makeIcon(color) {
    color = color || '#5c67f5';
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="40" viewBox="0 0 32 40">'
        + '<ellipse cx="16" cy="38" rx="6" ry="2.5" fill="rgba(0,0,0,.18)"/>'
        + '<path d="M16 0C9.4 0 4 5.4 4 12c0 9 12 26 12 26S28 21 28 12C28 5.4 22.6 0 16 0z" fill="' + color + '"/>'
        + '<circle cx="16" cy="12" r="5" fill="#fff"/>'
        + '</svg>';
    return L.divIcon({ html: svg, className: '', iconSize: [32, 40], iconAnchor: [16, 40], popupAnchor: [0, -42] });
}

function badgeHtml(statusCls, type) {
    var h = '<span class="ibadge ibadge-' + statusCls + '">' + (statusCls === 'published' ? 'Publiée' : 'Brouillon') + '</span>';
    if (type) h += ' <span class="ibadge ibadge-type">' + type + '</span>';
    return h;
}

function popupHtml(offer) {
    var scls = offer.status === 'PUBLISHED' ? 'published' : 'draft';
    var sal  = offer.salary ? offer.salary.toLocaleString('fr-FR') + ' €' + (offer.salaryNeg ? ' nég.' : '') : '';
    return '<div class="map-popup">'
        + '<div class="mp-title">' + offer.title + '</div>'
        + (sal ? '<div class="mp-salary">' + sal + '</div>' : '')
        + '<div class="mp-meta">'
        + (offer.location ? '<span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>' + offer.location + '</span>' : '')
        + '<span>👥 ' + offer.applications + ' candidature' + (offer.applications !== 1 ? 's' : '') + '</span>'
        + '</div>'
        + '<div class="mp-badges">' + badgeHtml(scls, offer.type) + '</div>'
        + '<a href="' + offer.url + '" class="mp-btn">Voir l\'offre →</a>'
        + '</div>';
}

// Geocode a location string using Nominatim (OSM, free, no key)
var geocodeCache = {};
function geocode(locationStr, callback) {
    if (!locationStr || locationStr.trim() === '') { callback(null); return; }
    var key = locationStr.trim().toLowerCase();
    if (geocodeCache[key] !== undefined) { callback(geocodeCache[key]); return; }
    var url = 'https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(locationStr);
    fetch(url, { headers: { 'Accept-Language': 'fr' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data && data.length > 0) {
                var r = { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon) };
                geocodeCache[key] = r;
                callback(r);
            } else {
                geocodeCache[key] = null;
                callback(null);
            }
        })
        .catch(function () { geocodeCache[key] = null; callback(null); });
}

function updateMapMarkers() {
    if (!map) return;
    Object.keys(markerMap).forEach(function (id) {
        var entry = markerMap[id];
        if (!entry.marker) return;
        var show = visibleIds.size === 0 || visibleIds.has(+id);
        if (show) {
            entry.marker.addTo(map);
        } else {
            map.removeLayer(entry.marker);
        }
    });
}

function initMap() {
    if (map) return;

    map = L.map('mapContainer', { zoomControl: true, scrollWheelZoom: true }).setView([33.9, 9.5], 5);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    // Collect unique locations
    var locationMap = {}; // location string → [offers]
    offersData.forEach(function (offer) {
        var loc = (offer.location || '').trim();
        if (!loc) return;
        if (!locationMap[loc]) locationMap[loc] = [];
        locationMap[loc].push(offer);
    });

    var locations = Object.keys(locationMap);
    var done = 0;
    var total = locations.length;
    var bounds = [];
    var loader = document.getElementById('mapLoader');
    var mapCount = document.getElementById('mapCount');

    if (total === 0) {
        if (loader) loader.style.display = 'none';
        if (mapCount) mapCount.textContent = 'Aucune localisation disponible';
        return;
    }

    function geocodeNext(idx) {
        if (idx >= locations.length) return;
        var loc = locations[idx];
        setTimeout(function () {
            geocode(loc, function (coords) {
                done++;
                if (mapCount) mapCount.textContent = done + '/' + total + ' géolocalisées';
                if (coords) {
                    var offers = locationMap[loc];
                    bounds.push([coords.lat, coords.lng]);

                    // If multiple offers at same location, cluster popup
                    var popupContent;
                    if (offers.length === 1) {
                        popupContent = popupHtml(offers[0]);
                    } else {
                        popupContent = '<div class="map-popup"><div class="mp-title" style="font-size:.82rem">📍 ' + loc + ' — ' + offers.length + ' offres</div><div style="margin-top:.5rem;display:flex;flex-direction:column;gap:.5rem">';
                        offers.forEach(function (o) {
                            var sal = o.salary ? o.salary.toLocaleString('fr-FR') + ' €' : '';
                            popupContent += '<div style="padding:.5rem;background:#f8f9ff;border-radius:8px">'
                                + '<div style="font-weight:700;font-size:.82rem;color:#1e2343">' + o.title + '</div>'
                                + (sal ? '<div style="font-size:.78rem;color:#5c67f5;font-weight:600">' + sal + '</div>' : '')
                                + '<a href="' + o.url + '" class="mp-btn" style="margin-top:.35rem;font-size:.7rem">Voir →</a>'
                                + '</div>';
                        });
                        popupContent += '</div></div>';
                    }

                    var marker = L.marker([coords.lat, coords.lng], {
                        icon: makeIcon(offers.length > 1 ? '#7c3aed' : '#5c67f5')
                    }).bindPopup(popupContent, { maxWidth: 260, minWidth: 220 });

                    // Highlight card on marker hover
                    marker.on('mouseover', function () {
                        offers.forEach(function (o) {
                            var card = document.getElementById('card-' + o.id);
                            if (card && card.style.display !== 'none') {
                                card.classList.add('map-highlight');
                                card.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                            }
                        });
                    });
                    marker.on('mouseout', function () {
                        document.querySelectorAll('.jcard.map-highlight').forEach(function (c) { c.classList.remove('map-highlight'); });
                    });

                    marker.addTo(map);

                    // Store marker keyed by each offer id
                    offers.forEach(function (o) {
                        markerMap[o.id] = { marker: marker, lat: coords.lat, lng: coords.lng };
                    });
                }

                if (done === total) {
                    if (loader) loader.style.display = 'none';
                    if (mapCount) mapCount.textContent = bounds.length + ' localisation' + (bounds.length !== 1 ? 's' : '') + ' affichée' + (bounds.length !== 1 ? 's' : '');
                    if (bounds.length > 0) {
                        try { map.fitBounds(bounds, { padding: [30, 30], maxZoom: 12 }); } catch(e) {}
                    }
                    // Apply current filter state
                    filterCards();
                }

                geocodeNext(idx + 1);
            });
        }, idx * 300); // 300 ms between requests to respect Nominatim rate limit
    }

    geocodeNext(0);
}

// Click card → open marker popup on map
cards.forEach(function (card) {
    card.addEventListener('click', function (e) {
        if (e.target.closest('a, button, form')) return;
        var id = +card.dataset.id;
        var entry = markerMap[id];
        if (entry && entry.marker && map) {
            map.setView([entry.lat, entry.lng], 13, { animate: true });
            entry.marker.openPopup();
        }
    });
});

// Initialize visible IDs with all
offersData.forEach(function (o) { visibleIds.add(o.id); });

// Run filter on load
filterCards();

// ─── Translation Feature ───────────────────────────────────
window.translateCard = async function(el, id, targetLang) {
    const btn = el.closest('.dropdown').querySelector('.dropdown-toggle');
    if (btn.classList.contains('loading')) return;
    
    const card = document.getElementById('card-' + id);
    if (!card) return;

    const titleEl = card.querySelector('.jcard-heading a');
    if (!btn.dataset.original) {
        btn.dataset.original = titleEl.innerText;
    }

    btn.classList.add('loading');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="ti ti-refresh rotate"></i> ...';

    try {
        const response = await fetch('/job/offre/translate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                text: btn.dataset.original,
                target: targetLang
            })
        });
        const data = await response.json();

        if (data.translation) {
            titleEl.innerText = data.translation;
            titleEl.classList.add('translated');
            
            // Show reset options
            el.closest('.dropdown').querySelectorAll('.back-to-original').forEach(i => i.classList.remove('d-none'));
            btn.innerHTML = '<i class="ti ti-language"></i> ' + targetLang.toUpperCase();
        }
    } catch (e) {
        console.error('Translation error:', e);
        btn.innerHTML = originalHtml;
        alert('Erreur de traduction. Veuillez réessayer.');
    } finally {
        btn.classList.remove('loading');
    }
};

window.resetTranslation = function(el, id) {
    const card = document.getElementById('card-' + id);
    const dropdown = el.closest('.dropdown');
    const btn = dropdown.querySelector('.dropdown-toggle');
    const titleEl = card.querySelector('.jcard-heading a');

    if (btn.dataset.original) {
        titleEl.innerText = btn.dataset.original;
        titleEl.classList.remove('translated');
        btn.innerHTML = '<i class="ti ti-language"></i> Traduire';
        dropdown.querySelectorAll('.back-to-original').forEach(i => i.classList.add('d-none'));
    }
};

// ─── AI Chat Interaction Logic ─────────────────────────────
const aiChatBubble  = document.getElementById('aiChatBubble');
const aiChatWindow  = document.getElementById('aiChatWindow');
const aiChatClose   = document.getElementById('aiChatClose');
const aiChatForm    = document.getElementById('aiChatForm');
const aiChatInput   = document.getElementById('aiChatInput');
const aiChatMsgs    = document.getElementById('aiChatMessages');

const toggleChat = () => {
    aiChatWindow.classList.toggle('active');
    if (aiChatWindow.classList.contains('active')) {
        aiChatInput.focus();
    }
};

aiChatBubble.addEventListener('click', toggleChat);
aiChatClose.addEventListener('click', () => aiChatWindow.classList.remove('active'));

const addMessage = (text, type = 'ai') => {
    const div = document.createElement('div');
    div.className = `msg msg-${type}`;
    div.innerText = text;
    aiChatMsgs.appendChild(div);
    aiChatMsgs.scrollTop = aiChatMsgs.scrollHeight;
    return div;
};

const showLoading = () => {
    const div = document.createElement('div');
    div.className = 'msg msg-ai msg-loading';
    div.innerHTML = '<span></span><span></span><span></span>';
    aiChatMsgs.appendChild(div);
    aiChatMsgs.scrollTop = aiChatMsgs.scrollHeight;
    return div;
};

aiChatForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = aiChatInput.value.trim();
    if (!msg) return;

    aiChatInput.value = '';
    addMessage(msg, 'user');

    const loader = showLoading();

    try {
        const response = await fetch('{{ path("app_job_offre_ai_chat") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg })
        });
        
        const data = await response.json();
        loader.remove();

        if (data.reply) {
            addMessage(data.reply, 'ai');
        }

        if (data.filters) {
            const f = data.filters;
            // Apply filters to UI inputs to keep them in sync
            if (f.q !== undefined) {
                fsQ.value = f.q || '';
            }
            if (f.location !== undefined) {
                fsLoc.value = f.location || '';
            }
            if (f.type !== undefined) {
                fsType.value = (f.type || '').toLowerCase();
                // Update pills
                pills.forEach(p => {
                    p.classList.toggle('active', p.dataset.type === fsType.value);
                });
            }
            if (f.salary_min !== undefined) {
                fsSalMin.value = f.salary_min || '';
            }
            if (f.salary_max !== undefined) {
                fsSalMax.value = f.salary_max || '';
            }
            
            // Trigger the existing filtering logic
            filterCards();
        }

    } catch (err) {
        loader.remove();
        addMessage("Désolé, une erreur est survenue lors de la communication avec l'assistant.", 'ai');
        console.error(err);
    }
});

})();
