{% extends 'layout/admin.html.twig' %}

{% block title %}Tableau de bord | SyfonuRH{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block content %}
<div class="row mb-6 g-6 mt-2">
    {# Welcome banner #}
    <div class="col-xl-8 col-lg-6">
        <div class="bg-gradient-mixed p-8 py-10 rounded-3 p-lg-7">
            <h1 class="fs-3">👋 Bienvenue sur SyfonuRH</h1>
            <p class="mb-0">Gérez vos ressources humaines, contrats, candidatures,</p>
            <p>entretiens et bien plus depuis ce tableau de bord.</p>
            <a href="#" class="btn btn-dark">Démarrer</a>
        </div>
    </div>
    {# Quick stats card #}
    <div class="col-xl-4 col-lg-6">
        <div class="card card-lg h-100">
            <div class="card-body d-flex flex-column justify-content-center gap-4">
                <h5 class="mb-0">Accès rapide</h5>
                <a href="{{ path('app_forum_category_new') }}" class="btn btn-outline-primary btn-sm">📄 Nouvelle Catégorie</a>
                <a href="{{ path('app_forum_post_new') }}" class="btn btn-outline-success btn-sm">💼 Nouveau Post</a>
                <a href="#" class="btn btn-outline-info btn-sm">👤 Ajouter un utilisateur</a>
            </div>
        </div>
    </div>
</div>

{# KPI cards #}
<div class="row row-cols-1 row-cols-xl-4 row-cols-md-2 mb-6 g-6">
    {# Utilisateurs #}
    <div class="col">
        <div class="card card-lg">
            <div class="card-body d-flex flex-column gap-8">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-shape icon-lg rounded-circle bg-primary-subtle text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M9 7m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                            <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            <path d="M21 21v-2a4 4 0 0 0 -3 -3.85"/>
                        </svg>
                    </div>
                    <div>Utilisateurs</div>
                </div>
                <div class="d-flex justify-content-between align-items-center lh-1">
                    <div class="fs-3 fw-bold">{{ count_users }}</div>
                    <span class="badge bg-primary-subtle text-primary-emphasis small">Total</span>
                </div>
            </div>
        </div>
    </div>

    {# Contrats #}
    <div class="col">
        <div class="card card-lg">
            <div class="card-body d-flex flex-column gap-8">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-shape icon-lg rounded-circle bg-success-darker text-success-lighter">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M14 3v4a1 1 0 0 0 1 1h4"/>
                            <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>
                            <path d="M9 17h6"/><path d="M9 13h6"/>
                        </svg>
                    </div>
                    <div>Contrats</div>
                </div>
                <div class="d-flex justify-content-between align-items-center lh-1">
                    <div class="fs-3 fw-bold">0</div>
                    <span class="badge bg-success-subtle text-success-emphasis small">Actifs</span>
                </div>
            </div>
        </div>
    </div>

    {# Offres d'emploi #}
    <div class="col">
        <div class="card card-lg">
            <div class="card-body d-flex flex-column gap-8">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-shape icon-lg rounded-circle bg-warning-darker text-warning-lighter">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z"/>
                            <path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                    </div>
                    <div>Forum Posts</div>
                </div>
                <div class="d-flex justify-content-between align-items-center lh-1">
                    <div class="fs-3 fw-bold">{{ count_posts }}</div>
                    <span class="badge bg-warning-subtle text-warning-emphasis small">Publiés</span>
                </div>
            </div>
        </div>
    </div>

    {# Candidatures #}
    <div class="col">
        <div class="card card-lg">
            <div class="card-body d-flex flex-column gap-8">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-shape icon-lg rounded-circle bg-info-darker text-info-lighter">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"/>
                            <path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/>
                        </svg>
                    </div>
                    <div>Catégories</div>
                </div>
                <div class="d-flex justify-content-between align-items-center lh-1">
                    <div class="fs-3 fw-bold">{{ count_categories }}</div>
                    <span class="badge bg-info-subtle text-info-emphasis small">Actives</span>
                </div>
            </div>
        </div>
    </div>
</div>

{# Recent activity: Latest Jobs #}
<div class="row g-6 mb-6">
    <div class="col-xl-8">
        <div class="card card-lg">
            <div class="card-header border-bottom-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Derniers Posts</h5>
                <a href="{{ path('app_forum_index') }}" class="small">Voir tout</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th>Titre</th>
                            <th>Auteur</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for post in latest_posts %}
                        <tr>
                            <td>{{ post.title }}</td>
                            <td>{{ post.user.email|default('Anonyme') }}</td>
                            <td>
                                <span class="badge bg-success-subtle text-success-emphasis">
                                    {{ post.createdAt|date('Y-m-d') }}
                                </span>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="3" class="text-center py-4 text-secondary">
                                Aucun post pour le moment.
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card card-lg">
            <div class="card-body">
                <h5 class="mb-6">Statut des entretiens</h5>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span>Planifiés</span>
                        <span class="badge bg-info-subtle text-info-emphasis">—</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Complétés</span>
                        <span class="badge bg-success-subtle text-success-emphasis">—</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Annulés</span>
                        <span class="badge bg-danger-subtle text-danger-emphasis">—</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
